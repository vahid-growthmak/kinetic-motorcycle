{%- comment -%}
  Generic page template — auto-renders the right layout based on page handle.
  Handles: faq, about, reviews → custom snippet pages.
  Anything else → standard editor-content layout.
{%- endcomment -%}

{%- case page.handle -%}
  {%- when 'faq' or 'faqs' or 'frequently-asked-questions' -%}
    {% render 'page-faq' %}

  {%- when 'about' or 'about-us' or 'about-kinetic-motorcycles' -%}
    {% render 'page-about' %}

  {%- when 'reviews' or 'customer-reviews' -%}
    {% render 'page-reviews' %}

  {%- else -%}
    <section class="km-section km-page">
      <div class="km-container km-container--narrow">
        <header class="km-page__header">
          <h1 class="km-page__title">{{ page.title }}</h1>
        </header>
        <div class="km-page__body km-rte">
          {{ page.content }}
        </div>
      </div>
    </section>

    <style>
      .km-page { background: var(--km-surface, #fff); padding: 80px 0; }
      .km-container--narrow { max-width: 820px; }
      .km-page__header { margin-bottom: 28px; }
      .km-page__title {
        font-size: clamp(32px, 4vw, 48px); font-weight: 700; letter-spacing: -.02em;
        color: var(--km-heading, #000); line-height: 1.1;
      }
      .km-rte { font-size: 16px; line-height: 1.7; color: var(--km-text, #4B5563); }
      .km-rte h2, .km-rte h3, .km-rte h4 { color: var(--km-heading, #000); margin-top: 1.5em; }
      .km-rte a { color: var(--km-heading, #000); text-decoration: underline; }
      .km-rte img { max-width: 100%; height: auto; border-radius: var(--km-radius, 12px); }
    </style>
{%- endcase -%}
