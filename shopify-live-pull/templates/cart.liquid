{%- comment -%}
  Cart page — clones Webflow cart modal features end-to-end:
  header, item list (image/name/variant/qty/remove), subtotal,
  Apple Pay / Shop Pay / PayPal / Google Pay quick checkout,
  Continue to Checkout, empty state, error state.
{%- endcomment -%}
<section class="km-section km-cart">
  <div class="km-container km-container--narrow">

    <header class="km-cart__header">
      <h1 class="km-cart__title">Your Cart</h1>
      <a href="{{ routes.all_products_collection_url }}" class="km-cart__continue">← Continue shopping</a>
    </header>

    {%- if cart.item_count > 0 -%}
      <form class="km-cart__form" action="{{ routes.cart_url }}" method="post" novalidate>

        <ul class="km-cart__items">
          {%- for item in cart.items -%}
            <li class="km-cart__item" data-km-cart-line="{{ forloop.index }}">
              <a href="{{ item.url }}" class="km-cart__thumb">
                {%- if item.image != blank -%}
                  {{ item.image | image_url: width: 200 | image_tag:
                     width: 100, height: 100, loading: 'lazy',
                     alt: item.product.title, class: 'km-cart__img' }}
                {%- endif -%}
              </a>
              <div class="km-cart__info">
                <a href="{{ item.url }}" class="km-cart__name">{{ item.product.title }}</a>
                {%- unless item.variant.title contains 'Default' -%}
                  <ul class="km-cart__variant-list">
                    {%- for opt in item.options_with_values -%}
                      <li><span>{{ opt.name }}:</span> <span>{{ opt.value }}</span></li>
                    {%- endfor -%}
                  </ul>
                {%- endunless -%}
                <div class="km-cart__qty-wrap">
                  <label for="updates_{{ item.key }}" class="km-cart__qty-label">Qty</label>
                  <input
                    type="number"
                    id="updates_{{ item.key }}"
                    name="updates[{{ item.key }}]"
                    value="{{ item.quantity }}"
                    min="0"
                    inputmode="numeric"
                    pattern="^[0-9]+$"
                    aria-label="Update quantity for {{ item.product.title }}"
                    class="km-cart__qty-input">
                  <a href="{{ item.url_to_remove }}" class="km-cart__remove" aria-label="Remove {{ item.product.title }} from cart">Remove</a>
                </div>
              </div>
              <div class="km-cart__line-price">{{ item.final_line_price | money }}</div>
            </li>
          {%- endfor -%}
        </ul>

        {%- if settings.cart_note_enabled or true -%}
          <div class="km-cart__note">
            <label for="cart-note" class="km-cart__note-label">Order notes (optional)</label>
            <textarea id="cart-note" name="note" rows="2" class="km-cart__note-input" placeholder="Anything we should know about your order?">{{ cart.note }}</textarea>
          </div>
        {%- endif -%}

        <div class="km-cart__footer">
          <div class="km-cart__subtotal">
            <span>Subtotal</span>
            <strong>{{ cart.total_price | money_with_currency }}</strong>
          </div>
          <p class="km-cart__tax-note">Taxes and shipping calculated at checkout.</p>

          <div class="km-cart__actions">
            <button type="submit" name="update" class="km-btn km-btn-ghost km-cart__update">Update cart</button>
            <button type="submit" name="checkout" class="km-btn km-btn-primary km-cart__checkout">
              Continue to Checkout
              {%- render 'icon', icon: 'arrow-right' -%}
            </button>
          </div>

          {%- if additional_checkout_buttons -%}
            <div class="km-cart__dynamic-checkout">
              {{ content_for_additional_checkout_buttons }}
            </div>
          {%- endif -%}
        </div>

      </form>

      <div class="km-cart__trust">
        <div class="km-cart__trust-item">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" width="18" height="18"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
          <span>Secure checkout</span>
        </div>
        <div class="km-cart__trust-item">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" width="18" height="18"><path d="M14 18V6a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2v11a1 1 0 0 0 1 1h2"/><path d="M15 18H9"/><path d="M19 18h2a1 1 0 0 0 1-1v-3.65a1 1 0 0 0-.22-.624l-3.48-4.35A1 1 0 0 0 17.52 8H14"/><circle cx="17" cy="18" r="2"/><circle cx="7" cy="18" r="2"/></svg>
          <span>Worldwide shipping</span>
        </div>
        <div class="km-cart__trust-item">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" width="18" height="18"><path d="M3 12a9 9 0 1 0 9-9"/><path d="M3 4v5h5"/></svg>
          <span>Lifetime warranty</span>
        </div>
      </div>

    {%- else -%}
      <div class="km-cart__empty">
        <p class="km-cart__empty-msg">No items found. Your cart is empty.</p>
        <a href="{{ routes.all_products_collection_url }}" class="km-btn km-btn-primary">
          Browse the shop
          {%- render 'icon', icon: 'arrow-right' -%}
        </a>
      </div>
    {%- endif -%}
  </div>
</section>

<style>
  .km-cart { background: var(--km-surface); padding: 56px 0 96px; }
  .km-container--narrow { max-width: 860px; }

  .km-cart__header {
    display: flex; justify-content: space-between; align-items: baseline;
    margin: 0 0 28px; gap: 16px; flex-wrap: wrap;
  }
  .km-cart__title {
    font-size: clamp(28px, 3.6vw, 40px); font-weight: 800;
    letter-spacing: -.02em; color: var(--km-heading, #000); margin: 0;
  }
  .km-cart__continue {
    font-size: 13px; font-weight: 700; color: #000;
    text-decoration: none; border-bottom: 2px solid transparent;
    transition: border-color .2s ease;
  }
  .km-cart__continue:hover { border-color: var(--km-accent, #FBB03D); }

  .km-cart__items { list-style: none; padding: 0; margin: 0 0 24px; display: flex; flex-direction: column; }
  .km-cart__item {
    display: grid; grid-template-columns: 100px 1fr auto; gap: 20px; align-items: start;
    padding: 20px 0; border-bottom: 1px solid var(--km-border, #DDD);
  }
  .km-cart__thumb { width: 100px; height: 100px; border-radius: 12px; overflow: hidden; background: #fff; display: block; }
  .km-cart__img { width: 100%; height: 100%; object-fit: cover; }
  .km-cart__info { display: flex; flex-direction: column; gap: 6px; }
  .km-cart__name { font-weight: 700; font-size: 15px; color: var(--km-heading, #000); text-decoration: none; }
  .km-cart__variant-list { list-style: none; padding: 0; margin: 0; font-size: 12px; color: var(--km-text, #4B5563); }
  .km-cart__variant-list li { display: inline-block; margin-right: 12px; }
  .km-cart__variant-list span:first-child { font-weight: 600; }

  .km-cart__qty-wrap { display: flex; align-items: center; gap: 14px; margin-top: 6px; }
  .km-cart__qty-label { font-size: 12px; font-weight: 600; color: var(--km-text, #4B5563); }
  .km-cart__qty-input {
    width: 64px; padding: 6px 8px; border: 1px solid var(--km-border, #DDD);
    border-radius: 6px; font-size: 14px; font-family: inherit;
    background: #fff; color: #000; text-align: center;
  }
  .km-cart__remove {
    font-size: 12px; color: var(--km-text, #4B5563); text-decoration: underline;
    text-underline-offset: 3px; transition: color .2s ease;
  }
  .km-cart__remove:hover { color: #c0392b; }

  .km-cart__line-price { font-weight: 800; color: var(--km-heading, #000); font-size: 15px; }

  .km-cart__note { margin: 0 0 24px; }
  .km-cart__note-label {
    display: block; font-size: 12px; font-weight: 700;
    text-transform: uppercase; letter-spacing: .08em;
    color: var(--km-text, #4B5563); margin-bottom: 8px;
  }
  .km-cart__note-input {
    width: 100%; padding: 12px 14px; border: 1px solid var(--km-border, #DDD);
    border-radius: 8px; font-family: inherit; font-size: 14px;
    background: #fff; color: #000; resize: vertical;
  }
  .km-cart__note-input:focus { outline: none; border-color: #000; }

  .km-cart__footer { border-top: 2px solid var(--km-heading, #000); padding-top: 24px; }
  .km-cart__subtotal {
    display: flex; justify-content: space-between; align-items: baseline;
    font-size: 20px; font-weight: 800; color: var(--km-heading, #000);
    margin-bottom: 6px;
  }
  .km-cart__tax-note {
    font-size: 12px; color: var(--km-text, #4B5563); margin: 0 0 20px;
  }

  .km-cart__actions {
    display: grid; grid-template-columns: auto 1fr; gap: 12px; margin-bottom: 14px;
  }
  .km-btn-ghost {
    background: transparent; color: #000; border: 1px solid #000;
    padding: 14px 24px; font-weight: 700; font-size: 13px;
    border-radius: 8px; cursor: pointer; font-family: inherit;
    letter-spacing: .04em; transition: background .2s ease, color .2s ease;
  }
  .km-btn-ghost:hover { background: #000; color: #fff; }
  .km-cart__checkout { width: 100%; justify-content: center; padding: 14px 32px; }

  .km-cart__dynamic-checkout {
    margin-top: 12px;
  }
  /* Shopify injects its own styled Apple Pay / Shop Pay / PayPal / GPay buttons here */
  .km-cart__dynamic-checkout .additional-checkout-button,
  .km-cart__dynamic-checkout .shopify-payment-button {
    width: 100%;
    margin-top: 8px;
  }

  .km-cart__trust {
    display: flex; justify-content: center; gap: 32px;
    margin-top: 32px; padding-top: 24px;
    border-top: 1px solid var(--km-border, #DDD);
    flex-wrap: wrap;
  }
  .km-cart__trust-item {
    display: inline-flex; align-items: center; gap: 8px;
    font-size: 12px; font-weight: 600; color: var(--km-text, #4B5563);
  }
  .km-cart__trust-item svg { color: #000; }

  .km-cart__empty {
    text-align: center; padding: 80px 0;
    background: #fff; border-radius: 16px;
  }
  .km-cart__empty-msg { color: var(--km-text, #4B5563); margin-bottom: 24px; font-size: 16px; }

  @media (max-width: 640px) {
    .km-cart__item { grid-template-columns: 80px 1fr; gap: 14px; }
    .km-cart__thumb { width: 80px; height: 80px; }
    .km-cart__line-price { grid-column: 2 / 3; }
    .km-cart__actions { grid-template-columns: 1fr; }
  }
</style>
