  .km-about-page__header { margin-bottom: 36px; }
  .km-about-page__h1 {
    font-size: clamp(32px, 4.4vw, 52px);
    font-weight: 700;
    letter-spacing: -.02em;
    color: #000;
    margin: 0;
    line-height: 1.1;
  }

  /* HERO SPLIT */
  .km-about-page__hero-grid {
    display: grid;
    grid-template-columns: 1.3fr 1fr;
    gap: 32px;
    margin-bottom: 24px;
  }
  .km-about-page__hero-img {
    aspect-ratio: 4/5;
    border-radius: 18px;
    overflow: hidden;
    background: #000;
  }
  .km-about-page__img { width: 100%; height: 100%; object-fit: cover; }

  .km-about-page__hero-card {
    background: #fff;
    border-radius: 18px;
    padding: 24px;
    display: flex;
    flex-direction: column;
    gap: 14px;
    border: 1px solid var(--km-border, #DDDDDD);
  }
  .km-about-page__card-media {
    aspect-ratio: 16/10;
    border-radius: 12px;
    overflow: hidden;
    background: #f3f4f6;
    margin-bottom: 4px;
  }
  .km-about-page__card-media img { width: 100%; height: 100%; object-fit: cover; }
  .km-about-page__card-h {
    font-size: 15px;
    font-weight: 700;
    color: #000;
    margin: 0;
    letter-spacing: .02em;
  }
  .km-about-page__hero-card p {
    font-size: 13px;
    line-height: 1.6;
    color: var(--km-text, #4B5563);
    margin: 0;
  }
  .km-about-page__card-tag strong { color: #000; font-weight: 700; }
  .km-about-page__card-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 13px;
    font-weight: 700;
    color: #000;
    text-decoration: none;
    margin-top: auto;
  }
  .km-about-page__card-link:hover { color: var(--km-accent, #FBB03D); }
  .km-about-page__card-link svg { width: 12px; height: 12px; }
  .km-about-page__card-meta {
    padding-top: 12px;
    border-top: 1px solid var(--km-border, #DDDDDD);
    font-size: 12px;
    font-weight: 600;
    color: var(--km-text, #4B5563);
  }

  /* STATS STRIP */
  .km-about-page__stats-strip {
    background: #fff;
    padding: 40px 32px;
    border-radius: 18px;
    display: grid;
    grid-template-columns: 1.2fr 2fr;
    gap: 40px;
    align-items: center;
    border: 1px solid var(--km-border, #DDDDDD);
    margin-bottom: 48px;
  }
  .km-about-page__stats-tagline h3 {
    font-size: 16px;
    font-weight: 700;
    color: #000;
    margin: 0 0 8px;
    letter-spacing: -.005em;
  }
  .km-about-page__stats-tagline p {
    font-size: 12px;
    line-height: 1.6;
    color: var(--km-text, #4B5563);
    margin: 0;
  }
  .km-about-page__stats-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    border-left: 1px solid var(--km-border, #DDDDDD);
    padding-left: 40px;
  }
  .km-about-page__stat { display: flex; flex-direction: column; gap: 4px; }
  .km-about-page__stat-num {
    font-size: clamp(28px, 3.4vw, 40px);
    font-weight: 800;
    color: #000;
    line-height: 1;
    letter-spacing: -.02em;
  }
  .km-about-page__stat-label {
    font-size: 14px;
