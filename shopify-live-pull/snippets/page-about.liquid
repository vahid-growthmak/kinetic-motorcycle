  .km-about-page__cta-right-bg { position: absolute; inset: 0; z-index: -1; }
  .km-about-page__cta-right-bg img { width: 100%; height: 100%; object-fit: cover; opacity: .55; }
  .km-about-page__cta-right-bg::after { content: ''; position: absolute; inset: 0; background: linear-gradient(90deg, rgba(0,0,0,.7) 0%, rgba(0,0,0,.3) 100%); }
  .km-about-page__cta-right-inner { padding: 48px 40px; display: flex; flex-direction: column; justify-content: center; gap: 14px; height: 100%; }
  .km-about-page__cta-eyebrow { font-size: 11px; font-weight: 700; letter-spacing: .14em; text-transform: uppercase; color: rgba(255,255,255,.8); }
  .km-about-page__cta-right-inner h4 { font-size: clamp(18px, 2vw, 22px); font-weight: 700; color: #fff; margin: 0 0 8px; line-height: 1.25; max-width: 400px; }
  .km-about-page__form { display: flex; background: #fff; border-radius: 6px; overflow: hidden; max-width: 400px; }
  .km-about-page__form-input { flex: 1; padding: 14px 16px; border: 0; font-size: 14px; color: #111; outline: none; font-family: inherit; }
  .km-about-page__form-btn { flex: 0 0 auto; padding: 14px 24px; background: var(--km-accent, #FBB03D); color: #000; border: 0; font-weight: 800; font-size: 13px; letter-spacing: .04em; cursor: pointer; font-family: inherit; transition: background .2s ease; }
