    .km-about-page__vmi-media { position: static; aspect-ratio: 16/9; }
    .km-about-page__vmi-card { position: static; transform: none; width: 100%; max-width: none; border-radius: 0; box-shadow: none; }
    .km-about-page__why-grid { grid-template-columns: 1fr; }
    .km-about-page__cta-grid { grid-template-columns: 1fr; }
  }
</style>

<script>
(() => {
  const tabs = document.querySelectorAll('[data-vmi]');
  const h = document.querySelector('[data-vmi-h]');
  const p = document.querySelector('[data-vmi-p]');
  if (!tabs.length || !h || !p) return;

  const content = {
    vision: {
      h: 'Our Vision',
      p: 'We aim to set a higher standard in the motorcycle parts industry — a future where riders can confidently find the right parts for their bikes without confusion, delays, or uncertainty.'
    },
    mission: {
      h: 'Our Mission',
      p: 'Deliver motorcycle solutions that meet real-world riding needs. By focusing on trust, innovation, and consistent quality, we make sure every product and every interaction adds value to your experience as a rider.'
    },
    innovation: {
      h: 'Our Innovation',
      p: 'We are shaping the future of automotive innovation & leading the way towards a more innovative, rider-first approach to motorcycle parts. Every component is engineered from scratch in-house — no templates, no outsourced shortcuts.'
    }
  };

  tabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      const key = tab.getAttribute('data-vmi');
      tabs.forEach((t) => {
        t.classList.toggle('is-active', t === tab);
        t.setAttribute('aria-selected', t === tab ? 'true' : 'false');
      });
      const c = content[key];
      if (!c) return;
      h.textContent = c.h;
      p.textContent = c.p;
    });
  });
})();
</script>
