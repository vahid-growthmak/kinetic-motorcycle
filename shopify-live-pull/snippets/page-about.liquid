  /* VISION / MISSION / INNOVATION */
  .km-about-page__vmi-wrap {
    padding: 40px 0 72px;
    background: var(--km-body-bg, #EDEDED);
  }
  .km-about-page__vmi-tabs {
    display: flex;
    gap: 4px;
    justify-content: center;
    padding: 6px;
    background: #fff;
    border: 1px solid var(--km-border, #DDDDDD);
    border-radius: 9999px;
    max-width: max-content;
    margin: 0 auto 32px;
  }
  .km-about-page__vmi-tab {
    padding: 10px 22px;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: .02em;
