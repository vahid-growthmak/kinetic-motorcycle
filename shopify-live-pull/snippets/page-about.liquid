    background: transparent;
    border: 0;
    border-radius: 9999px;
    cursor: pointer;
    font-family: inherit;
    transition: background .25s ease, color .25s ease;
  }
  .km-about-page__vmi-tab:hover { color: #000; }
  .km-about-page__vmi-tab.is-active {
    background: #000;
    color: #fff;
  }

  .km-about-page__vmi-panel {
    position: relative;
    border-radius: 18px;
    overflow: hidden;
    aspect-ratio: 16/6;
    min-height: 320px;
    background: #000;
  }
  .km-about-page__vmi-media { position: absolute; inset: 0; z-index: 0; }
  .km-about-page__vmi-media img { width: 100%; height: 100%; object-fit: cover; }
  .km-about-page__vmi-card {
    position: absolute;
    right: 32px;
    top: 50%;
    transform: translateY(-50%);
    background: #fff;
    border-radius: 14px;
    padding: 28px;
    width: 340px;
    max-width: 42%;
    z-index: 2;
    box-shadow: 0 10px 30px rgba(0,0,0,.15);
  }
  .km-about-page__vmi-card h3 {
    font-size: 18px;
    font-weight: 700;
    color: #000;
    margin: 0 0 10px;
    letter-spacing: -.005em;
  }
  .km-about-page__vmi-card p {
    font-size: 13px;
    line-height: 1.6;
