{%- comment -%} Hero — full-bleed bg + headline + chips. Inlined to bypass Shopify section registration. {%- endcomment -%}
<section class="km-hero">
  <div class="km-hero__bg">
    <img src="{{ 'hero-bg.webp' | asset_url }}" alt="Precision Performance" class="km-hero__img" loading="eager" fetchpriority="high">
    <div class="km-hero__overlay"></div>
  </div>

  <div class="km-container km-hero__inner">
    <div class="km-hero__content">
      <span class="km-hero__eyebrow">Elevate Your Ride</span>
      <h1 class="km-hero__heading">Precision Performance.<br>Seamless Fit.</h1>
      <p class="km-hero__subtext">Performance-Driven Parts &amp; Gear for Riders Who Live to Ride. Precision-engineered. Made in the USA. Designed for your bike.</p>
      <a href="/collections" class="km-hero__cta">
        Find Parts For Your Motorcycle
        {%- render 'icon', icon: 'arrow-right' -%}
      </a>
    </div>
  </div>

  <div class="km-hero__chips">
    <div class="km-container km-hero__chips-row">
      <span class="km-hero__chips-label">Shop by models :</span>
      {%- assign chips = 'Sportster,harley-davidson-sportster-parts|Softail,harley-davidson-softail-parts|Dyna,harley-davidson-dyna-parts|Triumph,triumph-motorcycle-parts-accessories|Honda,honda-cb-parts|Indian,indian' | split: '|' -%}
      {%- for c in chips -%}
        {%- assign p = c | split: ',' -%}
        <a href="/collections/{{ p[1] }}" class="km-hero__chip">{{ p[0] }}</a>
      {%- endfor -%}
    </div>
  </div>
</section>

<style>
  .km-hero {
    position: relative; min-height: 628px; display: flex; align-items: center;
    overflow: hidden; isolation: isolate;
  }
  .km-hero__bg { position: absolute; inset: 0; z-index: -1; }
  .km-hero__img { width: 100%; height: 100%; object-fit: cover; object-position: center; }
  .km-hero__overlay {
    position: absolute; inset: 0;
    background: linear-gradient(90deg, rgba(0,0,0,.55) 0%, rgba(0,0,0,.2) 55%, rgba(0,0,0,0) 100%);
  }
  .km-hero__inner {
    width: 100%;
    padding-top: 80px;
    padding-bottom: 120px;
    padding-left: 60px;
    padding-right: 32px;
  }
  .km-hero__content { max-width: 820px; color: #fff; }
  .km-hero__eyebrow {
    display: inline-block; font-size: 14px; font-weight: 500; color: #fff;
    letter-spacing: .02em; margin-bottom: 18px; opacity: .95;
  }
  .km-hero__heading {
    color: #fff; font-size: clamp(40px, 4.6vw, 66px); font-weight: 700;
    letter-spacing: -.01em; line-height: 1.1; margin: 0 0 18px;
    white-space: normal;
  }
  .km-hero__subtext {
    color: #e5e7eb; font-size: clamp(14px, 1.1vw, 16px); line-height: 1.6;
    max-width: 460px; margin: 0 0 30px;
  }
  .km-hero__cta {
    display: inline-flex; align-items: center; gap: 10px;
    background: var(--km-accent, #FBB03D); color: #fff; padding: 14px 28px;
    border-radius: 9999px; font-size: 14px; font-weight: 500; text-decoration: none;
    transition: background .2s ease, transform .2s ease;
  }
  .km-hero__cta:hover { background: #e69a2b; transform: translateY(-1px); }
  .km-hero__cta svg { width: 16px; height: 16px; }
  .km-hero__chips {
    position: absolute; left: 0; right: 0; bottom: 24px;
  }
  .km-hero__chips-row { display: flex; align-items: center; gap: 10px; flex-wrap: wrap; }
  .km-hero__chips-label { color: #fff; font-size: 13px; font-weight: 500; letter-spacing: .02em; margin-right: 4px; }
  .km-hero__chip {
    padding: 9px 20px; border-radius: 9999px; background: rgba(255,255,255,.12);
    border: 1px solid rgba(255,255,255,.25); color: #fff; font-size: 12px;
    font-weight: 700; letter-spacing: .08em; text-transform: uppercase;
    backdrop-filter: blur(8px); -webkit-backdrop-filter: blur(8px); text-decoration: none;
    transition: background .2s ease, color .2s ease, border-color .2s ease;
  }
  .km-hero__chip:hover { background: #fff; color: #000; border-color: #fff; }
  @media (max-width: 640px) {
    .km-hero { min-height: 520px; }
    .km-hero__inner { padding-top: 48px; padding-bottom: 120px; }
    .km-hero__chip { padding: 8px 14px; font-size: 11px; }
    .km-hero__chips-row { justify-content: center; }
  }
</style>
