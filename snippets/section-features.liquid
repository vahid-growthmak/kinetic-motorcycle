{%- comment -%} Features (Why Choose Kinetic Motorcycles) — 3 illustrated USPs. Uses ^^ and || delimiters so commas in text don't break the parser. {%- endcomment -%}
<section class="km-section km-features">
  <div class="km-container">
    <header class="km-features__header">
      <h2 class="km-features__heading">Why Choose Kinetic Motorcycles</h2>
    </header>
    <div class="km-features__grid">

      <div class="km-features__card">
        <div class="km-features__media">
          <img src="{{ 'feature-made-in-usa.webp' | asset_url }}" width="240" height="240" loading="lazy" alt="Made in USA badge illustration" class="km-features__img">
        </div>
        <h3 class="km-features__title">Made in USA</h3>
        <p class="km-features__desc">Every product is designed and manufactured in the USA, ensuring top-notch quality and supporting local craftsmanship. When you choose us, you’re choosing reliability and homegrown excellence.</p>
      </div>

      <div class="km-features__card">
        <div class="km-features__media">
          <img src="{{ 'feature-garage.webp' | asset_url }}" width="240" height="240" loading="lazy" alt="Established 2014 garage illustration" class="km-features__img">
        </div>
        <h3 class="km-features__title">Established in 2014</h3>
        <p class="km-features__desc">For over 11 years, we’ve been delivering unmatched quality and expertise. Our track record reflects a deep commitment to customer satisfaction and industry-leading solutions.</p>
      </div>

      <div class="km-features__card">
        <div class="km-features__media">
          <img src="{{ 'feature-shipping.webp' | asset_url }}" width="240" height="240" loading="lazy" alt="Free shipping rider illustration" class="km-features__img">
        </div>
        <h3 class="km-features__title">Free Shipping</h3>
        <p class="km-features__desc">Enjoy the convenience of free delivery anywhere in the US. We prioritize your satisfaction by making your shopping experience seamless and hassle-free.</p>
      </div>

    </div>
  </div>
</section>

<style>
  .km-features { padding: 80px 0; background: var(--km-body-bg, #EDEDED); }
  .km-features__header { text-align: left; margin: 0 0 48px; }
  .km-features__heading {
    font-size: clamp(32px, 4vw, 48px);
    font-weight: 700;
    letter-spacing: -.015em;
    color: var(--km-heading, #000);
    margin: 0;
    line-height: 1.1;
  }
  .km-features__grid { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 32px; }
  .km-features__card { padding: 24px 16px; text-align: center; transition: transform .25s ease; }
  .km-features__card:hover { transform: translateY(-2px); }
  .km-features__media {
    width: 100%; max-width: 240px; aspect-ratio: 1 / 1; margin: 0 auto 20px;
    display: flex; align-items: center; justify-content: center;
  }
  .km-features__img { width: 100%; height: 100%; object-fit: contain; }
  .km-features__title {
    font-size: 18px; font-weight: 700; letter-spacing: .06em; text-transform: uppercase;
    color: #000; margin: 0 0 14px;
  }
  .km-features__desc {
    color: var(--km-text, #4B5563); line-height: 1.65; font-size: 15px;
    max-width: 340px; margin: 0 auto;
  }
  @media (max-width: 900px) { .km-features__grid { grid-template-columns: 1fr; } }
</style>
