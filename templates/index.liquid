{%- comment -%}
  Homepage — 10 content sections matching Webflow exactly.
  Product rows now pull REAL products from Shopify collections.
{%- endcomment -%}

{% render 'section-hero' %}

{% render 'section-ticker' %}

{% render 'section-model-chooser' %}

{%- comment -%} BEST SELLERS — pulls from collection handle 'best-sellers' or 'frontpage' {%- endcomment -%}
{%- assign bs_coll = collections['best-sellers'] | default: collections['frontpage'] -%}
<section class="km-section km-pcarousel">
  <div class="km-container">
    <div class="km-section-row">
      <h2 class="km-section-heading">Best Sellers</h2>
      <div class="km-pcarousel__actions">
        <a href="{{ bs_coll.url | default: '/collections' }}" class="km-pcarousel__viewall">View All {%- render 'icon', icon: 'arrow-right' -%}</a>
      </div>
    </div>
    <div class="km-pcarousel__viewport">
      <div class="km-pcarousel__track">
        {%- for product in bs_coll.products limit: 4 -%}
          <article class="km-pcarousel__card">
            <a href="{{ product.url }}" class="km-pcarousel__imgwrap">
              {%- if product.featured_image != blank -%}
                {{ product.featured_image | image_url: width: 800 | image_tag: width: 400, height: 400, loading: 'lazy', alt: product.title, class: 'km-pcarousel__img' }}
              {%- endif -%}
            </a>
            <div class="km-pcarousel__meta">
              <h3 class="km-pcarousel__title"><a href="{{ product.url }}">{{ product.title }}</a></h3>
              {%- if product.vendor != blank -%}
                <div class="km-pcarousel__model">
                  <img src="{{ 'icon-motor.png' | asset_url }}" width="16" height="16" alt="" class="km-pcarousel__model-icon" loading="lazy">
                  <span>{{ product.vendor }}</span>
                </div>
              {%- endif -%}
              <div class="km-pcarousel__pricerow">
                <span class="km-pcarousel__price">{{ product.price | money }}</span>
                {%- if product.compare_at_price > product.price -%}
                  <span class="km-pcarousel__compare">{{ product.compare_at_price | money }}</span>
                {%- endif -%}
              </div>
              <div class="km-pcarousel__rating" aria-label="4 out of 5 stars">
                {%- for i in (1..5) -%}<span class="km-pcarousel__star{% if i > 4 %} km-pcarousel__star--off{% endif %}">{%- render 'icon', icon: 'star' -%}</span>{%- endfor -%}
              </div>
            </div>
          </article>
        {%- else -%}
          <p style="color: var(--km-text); padding: 40px 0;">No products in this collection yet. Add products to your "Best Sellers" collection in Shopify admin.</p>
        {%- endfor -%}
      </div>
    </div>
  </div>
</section>

