<script>
(() => {
  // Thumbnail swap
  const hero = document.querySelector('.km-pp__hero-img');
  document.querySelectorAll('[data-km-thumb]').forEach((t) => {
    t.addEventListener('click', () => {
      const src = t.getAttribute('data-km-thumb');
      if (hero && src) {
        hero.src = src;
        hero.srcset = src;
      }
      document.querySelectorAll('[data-km-thumb]').forEach((x) => x.classList.toggle('is-active', x === t));
    });
  });

  // Quantity stepper
  const qty = document.querySelector('[data-km-qty-input]');
  const dec = document.querySelector('[data-km-qty-dec]');
  const inc = document.querySelector('[data-km-qty-inc]');
  if (qty && dec && inc) {
    dec.addEventListener('click', () => { qty.value = Math.max(1, parseInt(qty.value || '1', 10) - 1); });
    inc.addEventListener('click', () => { qty.value = Math.max(1, parseInt(qty.value || '1', 10) + 1); });
  }

  // Reviews carousel scroll
  const track = document.querySelector('[data-km-pp-rev-track]');
  const prev = document.querySelector('[data-km-pp-prev]');
  const next = document.querySelector('[data-km-pp-next]');
  if (track && prev && next) {
    const step = () => track.clientWidth * 0.6;
    prev.addEventListener('click', () => track.scrollBy({ left: -step(), behavior: 'smooth' }));
    next.addEventListener('click', () => track.scrollBy({ left: step(), behavior: 'smooth' }));
  }
})();
</script>
