{%- comment -%}
  ------------------------------------------------------------
  FAQ — Accordion using native <details>/<summary> (no JS needed)
  Sidebar heading on the left, accordion on the right
  ------------------------------------------------------------
{%- endcomment -%}

<section class="km-section km-faq" id="Section-{{ section.id }}">
  <div class="km-container">
    <div class="km-faq__grid">
      <aside class="km-faq__side">
        {%- if section.settings.eyebrow != blank -%}
          <span class="km-eyebrow">{{ section.settings.eyebrow }}</span>
        {%- endif -%}
        <h2 class="km-section-heading km-faq__heading">{{ section.settings.heading }}</h2>
        {%- if section.settings.subheading != blank -%}
          <p class="km-muted km-faq__sub">{{ section.settings.subheading }}</p>
        {%- endif -%}
        {%- if section.settings.side_image != blank -%}
          <div class="km-faq__side-image">
            <img src="{{ section.settings.side_image | image_url: width: 800 }}" 
                 alt="{{ section.settings.side_image.alt | escape }}" 
                 loading="lazy" 
                 width="{{ section.settings.side_image.width }}" 
                 height="{{ section.settings.side_image.height }}">
          </div>
        {%- endif -%}
      </aside>

      <div class="km-faq__list">
        {%- if section.blocks.size > 0 -%}
          {%- for block in section.blocks -%}
            {%- if block.type == 'qa' -%}
              <details class="km-faq__item" {% if forloop.first and section.settings.open_first %}open{% endif %} {{ block.shopify_attributes }}>
                <summary class="km-faq__q">
                  <span class="km-faq__q-text">{{ block.settings.question }}</span>
                  <span class="km-faq__toggle" aria-hidden="true">
                    <span class="km-faq__toggle-plus">{%- render 'icon', icon: 'plus' -%}</span>
                    <span class="km-faq__toggle-minus">{%- render 'icon', icon: 'minus' -%}</span>
                  </span>
                </summary>
                <div class="km-faq__a">{{ block.settings.answer }}</div>
              </details>
            {%- endif -%}
          {%- endfor -%}
        {%- else -%}
          {%- assign fallback_faqs = 'How do I place an order?|Browse the catalog, add items to your cart, and head to checkout. Enter your shipping and payment details and your order will be processed right away.||What payment methods do you accept?|We accept major credit and debit cards, PayPal, and other secure online payment options — pick whichever is most convenient at checkout.||How long will it take for my order to arrive?|Delivery times depend on your location and stock. Once your order is processed we will email a confirmation and tracking link.||Do you offer warranties on your products?|Many of our products come with a manufacturer warranty. You will find warranty details on the product page or included in the packaging.||How can I contact customer support?|Get in touch by phone, email, or the contact form on our site. Our team is available during normal business hours and we usually reply within 24 hours.||What if I cant find a specific part on your website?|If a part is not listed, drop us a note. We will help track it down or recommend a suitable alternative from our catalog.' | split: '||' -%}
          {%- for entry in fallback_faqs -%}
            {%- assign p = entry | split: '|' -%}
            <details class="km-faq__item" {% if forloop.first and section.settings.open_first %}open{% endif %}>
              <summary class="km-faq__q">
                <span class="km-faq__q-text">{{ p[0] }}</span>
                <span class="km-faq__toggle" aria-hidden="true">
                  <span class="km-faq__toggle-plus">{%- render 'icon', icon: 'plus' -%}</span>
                  <span class="km-faq__toggle-minus">{%- render 'icon', icon: 'minus' -%}</span>
                </span>
              </summary>
              <div class="km-faq__a"><p>{{ p[1] }}</p></div>
            </details>
          {%- endfor -%}
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

<style>
  .km-faq { background: var(--km-body-bg); }

  .km-faq__grid {
    display: grid;
    grid-template-columns: 1fr 1.4fr;
    gap: 60px;
    align-items: stretch;
  }

  .km-faq__side .km-eyebrow {
    display: inline-block;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: .16em;
    text-transform: uppercase;
    color: var(--km-accent);
    margin-bottom: 14px;
  }
  .km-faq__heading {
    text-align: left;
    margin-bottom: 20px;
  }
  .km-faq__sub { font-size: 16px; margin-bottom: 32px; }
  .km-faq__side { display: flex; flex-direction: column; height: 100%; gap: 24px; }
  .km-faq__side-image { flex: 1; border-radius: var(--km-radius-lg, 16px); overflow: hidden; box-shadow: 0 12px 40px rgba(0,0,0,.1); }
  .km-faq__side-image img { width: 100%; height: 100%; object-fit: cover; display: block; }

  .km-faq__list {
    display: flex;
    flex-direction: column;
    height: 100%;
    gap: 12px;
  }
  .km-faq__item {
    background: var(--km-surface);
    border: 1px solid var(--km-border);
    border-radius: var(--km-radius-lg);
    padding: 0 28px;
    transition: box-shadow var(--km-transition, .25s ease), border-color var(--km-transition, .25s ease);
  }
  .km-faq__item[open] {
    border-color: var(--km-heading);
    box-shadow: 0 6px 22px rgba(0,0,0,.06);
  }

  .km-faq__q {
    list-style: none;
    cursor: pointer;
    padding: 22px 0;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
    font-weight: 700;
    color: var(--km-heading);
    font-size: 16px;
    line-height: 1.4;
  }
  .km-faq__q::-webkit-details-marker { display: none; }
  .km-faq__q-text { flex: 1 1 auto; }

  .km-faq__toggle {
    flex: 0 0 auto;
    width: 32px; height: 32px;
    border-radius: 50%;
    background: var(--km-body-bg);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--km-heading);
    transition: background var(--km-transition, .25s ease), color var(--km-transition, .25s ease);
  }
  .km-faq__item[open] .km-faq__toggle {
    background: var(--km-heading);
    color: #fff;
  }
  .km-faq__toggle-plus { display: inline-flex; }
  .km-faq__toggle-minus { display: none; }
  .km-faq__item[open] .km-faq__toggle-plus { display: none; }
  .km-faq__item[open] .km-faq__toggle-minus { display: inline-flex; }

  .km-faq__a {
    padding: 0 0 24px;
    color: var(--km-text);
    font-size: 15px;
    line-height: 1.7;
    border-top: 1px solid var(--km-border);
    padding-top: 18px;
    margin-top: -4px;
  }
  .km-faq__a p:last-child { margin-bottom: 0; }

  @media (max-width: 900px) {
    .km-faq__grid { grid-template-columns: 1fr; gap: 48px; }
    .km-faq__side { height: auto; gap: 16px; }
    .km-faq__heading { margin-bottom: 24px; }
    .km-faq__sub { margin-bottom: 40px; }
    .km-faq__side-image { min-height: auto; aspect-ratio: 16/9; }
    .km-faq__item { padding: 0 20px; }
    .km-faq__q { padding: 18px 0; font-size: 15px; }
  }
</style>

{% schema %}
{
  "name": "FAQ",
  "settings": [
    { "type": "text",     "id": "eyebrow",     "label": "Eyebrow" },
    { "type": "text",     "id": "heading",     "label": "Heading",     "default": "FAQs" },
    { "type": "textarea", "id": "subheading",  "label": "Subheading" },
    { "type": "image_picker", "id": "side_image", "label": "Sidebar Image" },
    { "type": "checkbox", "id": "open_first",  "label": "Open first item by default", "default": true }
  ],
  "blocks": [
    {
      "type": "qa",
      "name": "Question",
      "settings": [
        { "type": "text",     "id": "question", "label": "Question", "default": "Do parts come with a warranty?" },
        { "type": "richtext", "id": "answer",   "label": "Answer",   "default": "<p>Yes. Every product we ship is covered by a 12-month manufacturer warranty, plus a 30-day no-questions-asked return window if you change your mind.</p>" }
      ]
    }
  ],
  "max_blocks": 12,
  "presets": [
    {
      "name": "FAQ",
      "blocks": [
        { "type": "qa", "settings": { "question": "How do I place an order?",                      "answer": "<p>Browse the catalog, add items to your cart, and head to checkout. Enter your shipping and payment details and your order will be processed right away.</p>" } },
        { "type": "qa", "settings": { "question": "What payment methods do you accept?",           "answer": "<p>We accept major credit and debit cards, PayPal, and other secure online payment options — pick whichever is most convenient at checkout.</p>" } },
        { "type": "qa", "settings": { "question": "How long will it take for my order to arrive?", "answer": "<p>Delivery times depend on your location and stock. Once your order is processed we'll email a confirmation and tracking link so you can follow it the whole way.</p>" } },
        { "type": "qa", "settings": { "question": "Do you offer warranties on your products?",     "answer": "<p>Many of our products come with a manufacturer warranty. You'll find warranty details on the product page or included in the packaging — reach out if anything's unclear.</p>" } },
        { "type": "qa", "settings": { "question": "How can I contact customer support?",           "answer": "<p>Get in touch by phone, email, or the contact form on our site. Our team is available during normal business hours and we usually reply within 24 hours.</p>" } },
        { "type": "qa", "settings": { "question": "What if I can't find a specific part on your website?", "answer": "<p>If a part isn't listed, drop us a note. We'll help track it down or recommend a suitable alternative from our catalog.</p>" } }
      ]
    }
  ]
}
{% endschema %}
