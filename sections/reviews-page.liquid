{%- comment -%}
  Customer Reviews page — hero, stats, FUNCTIONAL filter tabs for Judge.me widget.
{%- endcomment -%}

<section class="km-reviews-page" id="Section-{{ section.id }}">

  {%- comment -%} HERO STRIP {%- endcomment -%}
  <div class="km-reviews-page__hero">
    <div class="km-container km-reviews-page__hero-inner">
      <span class="km-reviews-page__eyebrow">{{ section.settings.eyebrow }}</span>
      <h1 class="km-reviews-page__h1">{{ section.settings.title }}</h1>
      <p class="km-reviews-page__sub">{{ section.settings.subtext }}</p>
      
      {%- if section.settings.show_stats -%}
      <div class="km-reviews-page__stats">
        {%- for block in section.blocks -%}
          {%- if block.type == 'stat' -%}
            <div class="km-reviews-page__stat" {{ block.shopify_attributes }}>
              <div class="km-reviews-page__num-row">
                <span class="km-reviews-page__num">{{ block.settings.number }}</span>
                {%- if block.settings.show_stars -%}
                  <span class="km-reviews-page__num-stars" aria-hidden="true">
                    {%- for i in (1..5) -%}{%- render 'icon', icon: 'star' -%}{%- endfor -%}
                  </span>
                {%- endif -%}
              </div>
              <div class="km-reviews-page__label">{{ block.settings.label }}</div>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
      {%- endif -%}
    </div>
  </div>

  {%- comment -%} MODEL FILTER TABS {%- endcomment -%}
  <div class="km-container km-reviews-page__tabs-wrap">
    <div class="km-reviews-page__tabs" role="tablist" data-km-rev-tabs>
      <button type="button" class="km-reviews-page__tab is-active" role="tab" aria-selected="true" data-filter="">All reviews</button>
      <button type="button" class="km-reviews-page__tab" role="tab" aria-selected="false" data-filter="Sportster">Sportster</button>
      <button type="button" class="km-reviews-page__tab" role="tab" aria-selected="false" data-filter="Dyna">Dyna</button>
      <button type="button" class="km-reviews-page__tab" role="tab" aria-selected="false" data-filter="Softail">Softail</button>
      <button type="button" class="km-reviews-page__tab" role="tab" aria-selected="false" data-filter="Touring">Touring</button>
      <button type="button" class="km-reviews-page__tab" role="tab" aria-selected="false" data-filter="Indian">Indian</button>
      <button type="button" class="km-reviews-page__tab" role="tab" aria-selected="false" data-filter="Triumph">Triumph</button>
      <button type="button" class="km-reviews-page__tab" role="tab" aria-selected="false" data-filter="Honda">Honda</button>
    </div>
  </div>

  {%- comment -%} JUDGE.ME ALL REVIEWS WIDGET {%- endcomment -%}
  <div class="km-container km-reviews-page__widget-wrap">
    <div id="km-judgeme-all-reviews-wrapper">
      <!-- Start of Judge.me code -->
      <div id='judgeme_all_reviews' class='jdgm-widget jdgm-all-reviews-widget' data-hub-id='undefined'>
        {{ shop.metafields.judgeme.all_reviews_widget }}
      </div>
      <!-- End of Judge.me code -->
    </div>
  </div>
</section>

<style>
  .km-reviews-page { padding-bottom: 96px; background: var(--km-body-bg, #EDEDED); }
  .km-reviews-page__hero { background: #000; color: #fff; padding: 80px 0 64px; position: relative; overflow: hidden; isolation: isolate; }
  .km-reviews-page__hero::before { content: ''; position: absolute; inset: 0; z-index: -1; background: radial-gradient(60% 80% at 80% 30%, rgba(251,176,61,.15), transparent 60%); }
  .km-reviews-page__hero-inner { text-align: center; max-width: 760px; margin: 0 auto; }
  .km-reviews-page__eyebrow { display: inline-block; font-size: 12px; font-weight: 800; letter-spacing: .16em; text-transform: uppercase; color: var(--km-accent, #FBB03D); margin-bottom: 14px; }
  .km-reviews-page__h1 { font-size: clamp(40px, 5.4vw, 64px); font-weight: 700; letter-spacing: -.02em; color: #fff; margin: 0 0 16px; line-height: 1.05; }
  .km-reviews-page__sub { font-size: 16px; line-height: 1.65; color: rgba(255,255,255,.8); margin: 0 auto 40px; max-width: 560px; }
  
  .km-reviews-page__stats { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 40px; padding-top: 36px; border-top: 1px solid rgba(255,255,255,.15); max-width: 640px; margin: 0 auto; }
  .km-reviews-page__stat { text-align: center; display: flex; flex-direction: column; align-items: center; justify-content: flex-start; }
  .km-reviews-page__num-row { min-height: 60px; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 6px; }
  .km-reviews-page__num { font-size: 36px; font-weight: 800; color: #fff; line-height: 1; letter-spacing: -.01em; }
  .km-reviews-page__num-stars { display: inline-flex; gap: 2px; color: var(--km-accent, #FBB03D); }
  .km-reviews-page__num-stars svg { width: 12px; height: 12px; }
  .km-reviews-page__label { font-size: 11px; font-weight: 700; letter-spacing: .12em; text-transform: uppercase; color: rgba(255,255,255,.6); margin-top: 10px; }

  .km-reviews-page__tabs-wrap { display: flex; flex-direction: column; align-items: center; gap: 14px; margin: 48px auto 28px; }
  .km-reviews-page__tabs { display: flex; gap: 4px; padding: 8px; background: #fff; border: 1px solid var(--km-border, #DDDDDD); border-radius: 9999px; overflow-x: auto; max-width: 100%; scrollbar-width: none; }
  .km-reviews-page__tabs::-webkit-scrollbar { display: none; }
  .km-reviews-page__tab { padding: 12px 24px; font-size: 12px; font-weight: 800; letter-spacing: .1em; text-transform: uppercase; color: var(--km-text, #4B5563); background: transparent; border: 0; border-radius: 9999px; cursor: pointer; font-family: inherit; transition: background .25s ease, color .25s ease; white-space: nowrap; }
  .km-reviews-page__tab:hover { color: #000; background: var(--km-body-bg, #EDEDED); }
  .km-reviews-page__tab.is-active { background: #000; color: #fff; }

  .km-reviews-page__widget-wrap { margin-bottom: 64px; background: #fff; border: 1px solid var(--km-border, #DDDDDD); border-radius: 24px; padding: 48px; }

  /* Judge.me Custom Styling */
  #km-judgeme-all-reviews-wrapper .jdgm-all-reviews-widget { font-family: inherit !important; border: 0 !important; padding: 0 !important; }
  #km-judgeme-all-reviews-wrapper .jdgm-all-reviews-widget__title { display: none !important; }
  #km-judgeme-all-reviews-wrapper .jdgm-star { color: var(--km-accent, #FBB03D) !important; }
  #km-judgeme-all-reviews-wrapper .jdgm-btn { 
    background: #000 !important; color: #fff !important; border-radius: 9999px !important; 
    text-transform: uppercase !important; font-weight: 800 !important; letter-spacing: .1em !important; 
    padding: 12px 24px !important; font-size: 12px !important; border: 0 !important;
  }
  #km-judgeme-all-reviews-wrapper .jdgm-btn:hover { background: var(--km-accent, #FBB03D) !important; color: #000 !important; }

  @media (max-width: 700px) { 
    .km-reviews-page__tabs { border-radius: 20px; padding: 6px; } 
    .km-reviews-page__tab { padding: 10px 16px; font-size: 11px; } 
    .km-reviews-page__widget-wrap { padding: 24px 16px; border-radius: 0; border-left: 0; border-right: 0; }
  }
</style>

<script>
(() => {
  const tabsRoot = document.querySelector('[data-km-rev-tabs]');
  if (!tabsRoot) return;

  const tabs = [...tabsRoot.querySelectorAll('[data-filter]')];

  const applyJudgeMeFilter = (filterText) => {
    const widget = document.querySelector('#judgeme_all_reviews');
    if (!widget) return;

    // APPROACH: Use Judge.me Product Tags filtering if possible
    // Setting data-product-tag and re-rendering
    if (filterText) {
      widget.setAttribute('data-product-tag', filterText);
    } else {
      widget.removeAttribute('data-product-tag');
    }

    // Try to call Judge.me re-render
    if (window.jdgm && window.jdgm.widget && typeof window.jdgm.widget.reRenderAll === 'function') {
      window.jdgm.widget.reRenderAll();
    } else {
      // Fallback: Search bar approach if re-render isn't available
      const jdgmSearchInput = document.querySelector('.jdgm-search-input');
      if (jdgmSearchInput) {
        jdgmSearchInput.value = filterText;
        jdgmSearchInput.dispatchEvent(new Event('input', { bubbles: true }));
        jdgmSearchInput.dispatchEvent(new KeyboardEvent('keyup', { bubbles: true, key: 'Enter' }));
        const searchBtn = jdgmSearchInput.parentElement.querySelector('.jdgm-search-icon, .jdgm-search-btn');
        if (searchBtn) searchBtn.click();
      }
    }
  };

  tabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      const filter = tab.getAttribute('data-filter') || '';
      tabs.forEach((t) => {
        t.classList.toggle('is-active', t === tab);
        t.setAttribute('aria-selected', t === tab ? 'true' : 'false');
      });
      applyJudgeMeFilter(filter);
    });
  });

  // Style Judge.me widget periodically as it loads
  const styleInterval = setInterval(() => {
    const widget = document.querySelector('.jdgm-all-reviews-widget');
    if (widget) {
      const title = widget.querySelector('.jdgm-all-reviews-widget__title');
      if (title) title.style.display = 'none';
      widget.querySelectorAll('.jdgm-star').forEach(s => s.style.color = '#FBB03D');
    }
  }, 1000);
  setTimeout(() => clearInterval(styleInterval), 15000);
})();
</script>

{% schema %}
{
  "name": "Reviews Page",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Real Rider Feedback" },
    { "type": "text", "id": "title", "label": "Title", "default": "Customer Reviews" },
    { "type": "textarea", "id": "subtext", "label": "Subtext", "default": "The stories behind 12,000+ builds." },
    { "type": "checkbox", "id": "show_stats", "label": "Show Stats", "default": true }
  ],
  "blocks": [
    {
      "type": "stat",
      "name": "Hero Stat",
      "limit": 3,
      "settings": [
        { "type": "text", "id": "number", "label": "Number", "default": "4.9" },
        { "type": "text", "id": "label", "label": "Label", "default": "Average rating" },
        { "type": "checkbox", "id": "show_stars", "label": "Show star icons", "default": true }
      ]
    }
  ],
  "default": {
    "blocks": [
      { "type": "stat", "settings": { "number": "4.9", "label": "Average rating" } },
      { "type": "stat", "settings": { "number": "12k+", "label": "Bikes built", "show_stars": false } },
      { "type": "stat", "settings": { "number": "10 yrs", "label": "Houston-built", "show_stars": false } }
    ]
  }
}
{% endschema %}

