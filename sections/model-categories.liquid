{%- comment -%}
  Model Categories Grid Section — Grid of category cards with descriptions and links.
{%- endcomment -%}

<section class="km-model-cats" id="Section-{{ section.id }}">
  <div class="km-container">
    <header class="km-model-cats__header">
      <h2 class="km-model-cats__title">{{ section.settings.heading | default: 'Softail Categories' }}</h2>
    </header>

    <div class="km-model-cats__grid">
      {%- if section.blocks.size > 0 -%}
        {%- for block in section.blocks -%}
          <div class="km-model-cats__card" {{ block.shopify_attributes }}>
            <div class="km-model-cats__card-image">
              {%- if block.settings.image != blank -%}
                {{ block.settings.image | image_url: width: 800 | image_tag: width: 400, height: 260, loading: 'lazy', alt: block.settings.title, class: 'km-model-cats__img' }}
              {%- else -%}
                <img src="{{ 'category_illustration_vintage.png' | asset_url }}" width="400" height="260" loading="lazy" alt="{{ block.settings.title }}" class="km-model-cats__img">
              {%- endif -%}
            </div>
            <div class="km-model-cats__card-content">
              <h3 class="km-model-cats__card-title">{{ block.settings.title }}</h3>
              {%- if block.settings.description != blank -%}
                <p class="km-model-cats__card-desc">{{ block.settings.description }}</p>
              {%- endif -%}
              {%- if block.settings.url != blank -%}
                <a href="{{ block.settings.url }}" class="km-btn km-btn-outline km-model-cats__card-btn">
                  {{ block.settings.btn_label | default: 'View ' | append: block.settings.title }} {%- render 'icon', icon: 'arrow-right' -%}
                </a>
              {%- endif -%}
            </div>
          </div>
        {%- endfor -%}
      {%- endif -%}
    </div>
  </div>
</section>

<style>
  .km-model-cats {
    background: #fff;
    padding: 0 0 80px;
  }
  .km-model-cats__header {
    margin-bottom: 40px;
  }
  .km-model-cats__title {
    font-size: clamp(24px, 3.5vw, 36px);
    font-weight: 700;
    color: #000;
    margin: 0;
  }

  .km-model-cats__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 32px;
  }

  .km-model-cats__card {
    background: #fff;
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .km-model-cats__card-image {
    position: relative;
    border-radius: 16px;
    overflow: hidden;
    aspect-ratio: 1.5/1;
    background: #f9fafb;
    border: 1px solid #E5E7EB;
  }
  .km-model-cats__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .km-model-cats__card-content {
    display: flex;
    flex-direction: column;
    gap: 12px;
    flex-grow: 1;
  }
  .km-model-cats__card-title {
    font-size: 24px;
    font-weight: 700;
    color: #000;
    margin: 0;
  }
  .km-model-cats__card-desc {
    font-size: 14px;
    line-height: 1.65;
    color: var(--km-text, #4B5563);
    margin: 0 0 8px;
  }
  .km-model-cats__card-btn {
    width: fit-content;
    padding: 10px 24px;
    font-size: 13px;
    font-weight: 700;
    border-radius: 9999px;
    border-color: #D1D5DB;
    background: var(--km-accent, #FBB03D);
    color: #000;
    border: 0;
  }
  .km-model-cats__card-btn:hover {
    background: #e69a2b;
  }

  @media (max-width: 768px) {
    .km-model-cats__grid {
      grid-template-columns: 1fr;
    }
  }
</style>

{% schema %}
{
  "name": "Model Categories Grid",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Softail Categories"
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Illustration/Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Accessories"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Personalize your ride with accessories designed to improve comfort, usability, and finishing details. These components complement stock and custom setups while maintaining the bike's balance and classic lines."
        },
        {
          "type": "text",
          "id": "btn_label",
          "label": "Button Label"
        },
        {
          "type": "url",
          "id": "url",
          "label": "Category Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Model Categories Grid"
    }
  ]
}
{% endschema %}
