{%- comment -%}
  ============================================================
  TICKER SECTION — scrolling USP bar, editable blocks
  ============================================================
{%- endcomment -%}

{%- assign items = section.blocks -%}

<section class="km-ticker" aria-label="Highlights" {{ section.shopify_attributes }}>
  <div class="km-ticker__track" aria-hidden="true">
    {%- for i in (1..4) -%}
      {%- for block in items -%}
        <div class="km-ticker__item" {{ block.shopify_attributes }}>
          <span class="km-ticker__badge" aria-hidden="true">
            {%- case block.settings.icon -%}
              {%- when 'truck' -%}
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="22" height="22"><path d="M14 18V6a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2v11a1 1 0 0 0 1 1h2"/><path d="M15 18H9"/><path d="M19 18h2a1 1 0 0 0 1-1v-3.65a1 1 0 0 0-.22-.624l-3.48-4.35A1 1 0 0 0 17.52 8H14"/><circle cx="17" cy="18" r="2"/><circle cx="7" cy="18" r="2"/></svg>
              {%- when 'box' -%}
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="22" height="22"><path d="M21 12a9 9 0 1 1-3-6.7"/><path d="M21 4v6h-6"/><rect x="8" y="8" width="8" height="8" rx="1"/></svg>
              {%- when 'shield' -%}
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="22" height="22"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polygon points="12 8.5 13.1 10.8 15.5 11.1 13.7 12.8 14.2 15.2 12 14 9.8 15.2 10.3 12.8 8.5 11.1 10.9 10.8 12 8.5" fill="currentColor" stroke="none"/></svg>
              {%- else -%}
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="22" height="22"><circle cx="12" cy="12" r="10"/><path d="M8 12l3 3 5-6"/></svg>
            {%- endcase -%}
          </span>
          <span class="km-ticker__label">{{ block.settings.label }}</span>
        </div>
        <span class="km-ticker__divider" aria-hidden="true"></span>
      {%- endfor -%}
    {%- endfor -%}
  </div>
</section>

<style>
  .km-ticker {
    background: #fff;
    border-top: 1px solid var(--km-border, #DDDDDD);
    border-bottom: 1px solid var(--km-border, #DDDDDD);
    padding: 22px 0;
    overflow: hidden;
    position: relative;
  }
  .km-ticker__track {
    display: flex;
    align-items: center;
    gap: 56px;
    width: max-content;
    animation: km-ticker-scroll 40s linear infinite;
  }
  .km-ticker__item {
    display: inline-flex;
    align-items: center;
    gap: 18px;
    flex-shrink: 0;
  }
  .km-ticker__badge {
    width: 48px; height: 48px; border-radius: 50%;
    background: var(--km-accent, #FBB03D); color: #fff;
    display: inline-flex; align-items: center; justify-content: center; flex: 0 0 auto;
  }
  .km-ticker__badge svg { width: 22px; height: 22px; }
  .km-ticker__label {
    font-size: 16px; font-weight: 700; letter-spacing: .01em;
    color: var(--km-heading, #000); white-space: nowrap;
  }
  .km-ticker__divider { width: 1px; height: 26px; background: var(--km-border, #DDDDDD); flex: 0 0 auto; }
  @keyframes km-ticker-scroll {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }
  @media (max-width: 640px) {
    .km-ticker { padding: 16px 0; }
    .km-ticker__track { gap: 32px; animation-duration: 28s; }
    .km-ticker__badge { width: 40px; height: 40px; }
    .km-ticker__badge svg { width: 18px; height: 18px; }
    .km-ticker__label { font-size: 13px; }
    .km-ticker__item { gap: 12px; }
  }
</style>

{% schema %}
{
  "name": "USP Ticker",
  "tag": "section",
  "class": "shopify-section-ticker",
  "blocks": [
    {
      "type": "item",
      "name": "Ticker item",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "truck", "label": "Truck (shipping)" },
            { "value": "box", "label": "Box / refresh (established)" },
            { "value": "shield", "label": "Shield / star (quality)" },
            { "value": "check", "label": "Check (generic)" }
          ],
          "default": "truck"
        },
        { "type": "text", "id": "label", "label": "Label", "default": "Free Shipping" }
      ]
    }
  ],
  "max_blocks": 10,
  "presets": [
    {
      "name": "USP Ticker",
      "category": "Promotional",
      "blocks": [
        { "type": "item", "settings": { "icon": "truck", "label": "Free Shipping" } },
        { "type": "item", "settings": { "icon": "box", "label": "Established 2014" } },
        { "type": "item", "settings": { "icon": "shield", "label": "Made in USA" } }
      ]
    }
  ]
}
{% endschema %}
