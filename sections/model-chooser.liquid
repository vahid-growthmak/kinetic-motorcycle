          "categories": "Accessories|#\nFootpegs and Shifters|#\nExhausts|#\nCovers-Decals-Armor|#\nHandlebars|#\nLighting|#\nGrips|#\nServices|#\nIntake Systems|#"
        }
      },
      {
        "type": "model",
        "settings": {
          "name": "Harley Davidson Softail",
          "before_asset": "model-softail-before.png",
          "after_asset": "model-softail-after.webp",
          "description": "The Softail blends classic styling with modern ride comfort. Our Softail collections bring together engineered exhausts, handlebars, seats, covers, accessories, and services — chosen for direct fitment and dependable performance. Upgrade the look and feel of your Softail with parts proven to improve power, comfort, and overall appearance.",
          "categories": "Accessories|#\nExhausts|#\nHandlebars|#\nSeats|#\nCovers-Decals-Armor|#\nLighting|#\nFootpegs and Shifters|#\nGrips|#\nServices|#"
        }
      },
      {
        "type": "model",
