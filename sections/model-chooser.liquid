{%- comment -%}
  ------------------------------------------------------------
  Model Chooser — "Choose Your Model"
  Tabbed motorcycle models with before/after image comparison slider
  ------------------------------------------------------------
{%- endcomment -%}

<section class="km-section km-models" id="Section-{{ section.id }}">
  <div class="km-container">
    <header class="km-models__header">
      <h2 class="km-section-heading">{{ section.settings.heading | default: 'Choose Your Model' }}</h2>
      {%- if section.settings.subheading != blank -%}
        <p class="km-muted">{{ section.settings.subheading }}</p>
      {%- endif -%}
    </header>

    {%- if section.blocks.size == 0 -%}
      {%- assign fallback_models = 'sportster:Harley Davidson Sportster:model-sportster-before.png:model-sportster-after.png:The Harley-Davidson Sportster has been a symbol of versatility and style since 1957, beloved by riders for its adaptability and iconic look. Premium exhausts, handlebars, grips, lighting, intake systems, footpegs, shifters, accessories, and services, selected for precise fitment and dependable performance.;;softail:Harley Davidson Softail:model-softail-before.png:model-softail-after.webp:The Softail blends classic styling with modern ride comfort. Engineered exhausts, handlebars, seats, covers, accessories, and services chosen for direct fitment and dependable performance.;;dyna:Harley Davidson Dyna:model-dyna-before.png:model-dyna-after.webp:The Dyna platform is built for riders who push the limits. Full exhaust systems, precision shifters, intake kits, handlebars, lighting, and accessories selected for direct bolt-on fitment.;;triumph:Triumph:model-triumph-before.png:model-triumph-after.webp:From Bonneville to Speed Twin, Triumph is a hallmark of British engineering and classic styling. High-flow intakes, custom exhausts, CNC-machined cockpit parts, lighting, and accessories.;;honda:Honda:model-honda-before.png:model-honda-after.webp:Honda builds some of the most reliable and versatile motorcycles on the road. Intake kits, exhaust systems, handlebars, grips, lighting, and accessories engineered for precise fitment.' | split: ';;' -%}
    {%- endif -%}

    <div class="km-models__tabs" data-km-tabs>
      <div class="km-models__tablist" role="tablist">
        {%- if section.blocks.size > 0 -%}
          {%- for block in section.blocks -%}
            <button type="button" class="km-models__tab{% if forloop.first %} is-active{% endif %}" role="tab" data-km-tab="model-{{ block.id }}" aria-selected="{% if forloop.first %}true{% else %}false{% endif %}" {{ block.shopify_attributes }}>{{ block.settings.name }}</button>
          {%- endfor -%}
        {%- else -%}
          {%- for entry in fallback_models -%}
            {%- assign p = entry | split: ':' -%}
            <button type="button" class="km-models__tab{% if forloop.first %} is-active{% endif %}" role="tab" data-km-tab="model-{{ p[0] }}" aria-selected="{% if forloop.first %}true{% else %}false{% endif %}">{{ p[1] }}</button>
          {%- endfor -%}
        {%- endif -%}
      </div>

      {%- if section.blocks.size > 0 -%}
        {%- for block in section.blocks -%}
          <div class="km-models__panel{% if forloop.first %} is-active{% endif %}" data-km-panel="model-{{ block.id }}" role="tabpanel" {{ block.shopify_attributes }}>
            <div class="km-models__compare" data-km-compare>
              <div class="km-models__compare-before">
                {%- if block.settings.before_image != blank -%}
                  {{ block.settings.before_image | image_url: width: 1800 | image_tag: loading: 'lazy', width: 1440, height: 810, alt: block.settings.name | append: ' before' }}
                {%- else -%}
                  <img src="{{ block.settings.before_asset | default: 'model-sportster-before.png' | asset_url }}" alt="{{ block.settings.name }} before" loading="lazy" width="1440" height="810">
                {%- endif -%}
                <span class="km-models__compare-label is-before">Before</span>
              </div>
              <div class="km-models__compare-after" data-km-compare-after>
                {%- if block.settings.after_image != blank -%}
                  {{ block.settings.after_image | image_url: width: 1800 | image_tag: loading: 'lazy', width: 1440, height: 810, alt: block.settings.name | append: ' after' }}
                {%- else -%}
                  <img src="{{ block.settings.after_asset | default: 'model-sportster-after.png' | asset_url }}" alt="{{ block.settings.name }} after" loading="lazy" width="1440" height="810">
                {%- endif -%}
                <span class="km-models__compare-label is-after">After</span>
              </div>
              <div class="km-models__compare-handle" data-km-compare-handle aria-label="Drag to compare" role="slider" aria-valuemin="0" aria-valuemax="100">
                <span class="km-models__compare-handle-dot">
                  {%- render 'icon', icon: 'chevron-left' -%}{%- render 'icon', icon: 'chevron-right' -%}
                </span>
              </div>
            </div>
            <div class="km-models__info">
              <h3 class="km-models__title">{{ block.settings.name }}</h3>
              {%- if block.settings.description != blank -%}<p class="km-models__desc">{{ block.settings.description }}</p>{%- endif -%}
              {%- if block.settings.categories != blank -%}
                <div class="km-models__cats">
                  <span class="km-models__cats-label">Choose category :</span>
                  <div class="km-models__cats-list">
                    {%- assign cat_lines = block.settings.categories | newline_to_br | split: '<br />' -%}
                    {%- for raw in cat_lines -%}
                      {%- assign line = raw | strip -%}{%- if line == blank -%}{%- continue -%}{%- endif -%}
                      {%- assign parts = line | split: '|' -%}
                      <a href="{{ parts[1] | default: '#' | strip }}" class="km-models__cat-pill">{{ parts[0] | strip }}{%- render 'icon', icon: 'arrow-right' -%}</a>
                    {%- endfor -%}
                  </div>
                </div>
              {%- endif -%}
            </div>
          </div>
        {%- endfor -%}
      {%- else -%}
        {%- assign default_cats = 'Accessories,Footpegs and Shifters,Exhausts,Covers-Decals-Armor,Handlebars,Lighting,Grips,Services,Intake Systems' | split: ',' -%}
        {%- for entry in fallback_models -%}
          {%- assign p = entry | split: ':' -%}
          <div class="km-models__panel{% if forloop.first %} is-active{% endif %}" data-km-panel="model-{{ p[0] }}" role="tabpanel">
            <div class="km-models__compare" data-km-compare>
              <div class="km-models__compare-before">
                <img src="{{ p[2] | asset_url }}" alt="{{ p[1] }} before" loading="lazy" width="1440" height="810">
                <span class="km-models__compare-label is-before">Before</span>
              </div>
              <div class="km-models__compare-after" data-km-compare-after>
                <img src="{{ p[3] | asset_url }}" alt="{{ p[1] }} after" loading="lazy" width="1440" height="810">
                <span class="km-models__compare-label is-after">After</span>
              </div>
              <div class="km-models__compare-handle" data-km-compare-handle role="slider" aria-valuemin="0" aria-valuemax="100">
                <span class="km-models__compare-handle-dot">{%- render 'icon', icon: 'chevron-left' -%}{%- render 'icon', icon: 'chevron-right' -%}</span>
              </div>
            </div>
            <div class="km-models__info">
              <h3 class="km-models__title">{{ p[1] }}</h3>
              <p class="km-models__desc">{{ p[4] }}</p>
              <div class="km-models__cats">
                <span class="km-models__cats-label">Choose category :</span>
                <div class="km-models__cats-list">
                  {%- for cat in default_cats -%}
                    <a href="#" class="km-models__cat-pill">{{ cat }}{%- render 'icon', icon: 'arrow-right' -%}</a>
                  {%- endfor -%}
                </div>
              </div>
            </div>
          </div>
        {%- endfor -%}
      {%- endif -%}
    </div>
  </div>
</section>

<style>
  .km-models { background: var(--km-body-bg); }
  .km-models__header { text-align: center; max-width: 680px; margin: 0 auto 40px; }
  .km-models__header h2 { margin-bottom: 8px; }

  .km-models__tablist {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    justify-content: center;
    margin-bottom: 32px;
  }
  .km-models__tab {
    padding: 10px 22px;
    border-radius: var(--km-radius-pill);
    border: 1px solid var(--km-border);
    background: var(--km-surface);
    color: var(--km-heading);
    font-size: 13px;
    font-weight: 700;
    letter-spacing: .08em;
    text-transform: uppercase;
    cursor: pointer;
    transition: all var(--km-transition);
  }
  .km-models__tab:hover { border-color: var(--km-primary); }
  .km-models__tab.is-active {
    background: var(--km-primary);
    color: var(--km-primary-contrast);
    border-color: var(--km-primary);
  }

  .km-models__panel {
    display: none;
    grid-template-columns: 1.2fr 1fr;
    gap: 40px;
    align-items: center;
  }
  .km-models__panel.is-active { display: grid; animation: km-fade-in .4s ease; }

  .km-models__compare {
    position: relative;
    aspect-ratio: 16/9;
    border-radius: var(--km-radius-lg);
    overflow: hidden;
    cursor: ew-resize;
    user-select: none;
    background: #000;
  }
  .km-models__compare img {
    position: absolute; inset: 0;
    width: 100%; height: 100%;
    object-fit: cover;
  }
  .km-models__compare-after {
    clip-path: inset(0 50% 0 0);
    will-change: clip-path;
  }
  .km-models__compare-label {
    position: absolute;
    top: 16px;
    padding: 6px 14px;
    border-radius: var(--km-radius-pill);
    background: rgba(0,0,0,.7);
    color: #fff;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: .14em;
    text-transform: uppercase;
    backdrop-filter: blur(6px);
  }
  .km-models__compare-label.is-before { left: 16px; }
  .km-models__compare-label.is-after { right: 16px; background: rgba(251,176,61,.95); color: #000; }

  .km-models__compare-handle {
    position: absolute;
    top: 0; bottom: 0;
    left: 50%;
    width: 3px;
    background: #fff;
    transform: translateX(-50%);
    z-index: 2;
    pointer-events: none;
  }
  .km-models__compare-handle-dot {
    position: absolute;
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: #fff;
    color: #000;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 6px 20px rgba(0,0,0,.25);
    pointer-events: auto;
    cursor: ew-resize;
  }
  .km-models__compare-handle-dot svg:first-child { margin-right: -4px; }
  .km-models__compare-handle-dot svg:last-child { margin-left: -4px; }

  .km-models__info { padding: 16px; }
  .km-models__title {
    font-size: clamp(24px, 2.5vw, 32px);
    margin: 0 0 12px;
  }
  .km-models__desc {
    color: var(--km-text);
    line-height: 1.7;
    margin-bottom: 24px;
  }

  .km-models__cats { margin-bottom: 20px; }
  .km-models__cats-label {
    display: block;
    font-size: 13px;
    font-weight: 700;
    color: var(--km-heading);
    margin-bottom: 12px;
  }
  .km-models__cats-list {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
  .km-models__cat-pill {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 8px 16px;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: .08em;
    text-transform: uppercase;
    background: var(--km-primary);
    color: var(--km-primary-contrast);
    border-radius: var(--km-radius-pill);
    text-decoration: none;
    transition: background var(--km-transition, .2s ease);
  }
  .km-models__cat-pill:hover { background: var(--km-accent); color: #000; }
  .km-models__cat-pill svg { width: 12px; height: 12px; }

  @media (max-width: 900px) {
    .km-models__panel.is-active { grid-template-columns: 1fr; }
    .km-models__info { padding: 0; text-align: center; }
  }
</style>

{% schema %}
{
  "name": "Model Chooser",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Choose Your Model"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Slide to see the transformation. Performance-engineered parts for every ride."
    }
  ],
  "blocks": [
    {
      "type": "model",
      "name": "Motorcycle model",
      "settings": [
        { "type": "text", "id": "name", "label": "Model name", "default": "Harley Davidson Sportster" },
        { "type": "image_picker", "id": "before_image", "label": "Before image" },
        { "type": "text", "id": "before_asset", "label": "Before asset filename (fallback)", "default": "model-sportster-before.png" },
        { "type": "image_picker", "id": "after_image", "label": "After image" },
        { "type": "text", "id": "after_asset", "label": "After asset filename (fallback)", "default": "model-sportster-after.png" },
        { "type": "textarea", "id": "description", "label": "Description", "default": "The Harley-Davidson Sportster has been a symbol of versatility and style since 1957, beloved by riders for its adaptability and iconic look. Our Harley-Davidson Sportster collections bring together premium exhausts, handlebars, grips, lighting, intake systems, footpegs, shifters, accessories, and services, selected for precise fitment and dependable performance. You save time, avoid compatibility issues, and upgrade with confidence using proven parts that enhance power, comfort, and overall appearance." },
        { "type": "textarea", "id": "categories", "label": "Category pills (one per line: Label|URL)", "default": "Accessories|#\nFootpegs and Shifters|#\nExhausts|#\nCovers-Decals-Armor|#\nHandlebars|#\nLighting|#\nGrips|#\nServices|#\nIntake Systems|#" },
        { "type": "text", "id": "cta_label", "label": "CTA label" },
        { "type": "url", "id": "cta_url", "label": "CTA URL" }
      ]
    }
  ],
  "default": {
    "blocks": [
      {
        "type": "model",
