{%- comment -%}
  ============================================================
  MODEL CHOOSER — stacked rows, each bike is a block
  ============================================================
  Each block = 1 motorcycle row with before/after slider + description + category pills.
  Categories inside each block are comma-separated (single textarea).
{%- endcomment -%}

<section class="km-section km-models" {{ section.shopify_attributes }}>
  <div class="km-container">
    {%- if section.settings.heading != blank -%}
      <header class="km-models__header">
        <h2 class="km-section-heading">{{ section.settings.heading }}</h2>
      </header>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <div class="km-models__list">
        {%- for block in section.blocks -%}
          <article class="km-models__row" {{ block.shopify_attributes }}>
            <div class="km-models__compare" data-km-compare>
              {%- if block.settings.before_image != blank -%}
                <img src="{{ block.settings.before_image | image_url: width: 1200 }}" alt="{{ block.settings.name }} before" loading="lazy" class="km-models__compare-before-img">
              {%- else -%}
                <img src="{{ 'model-sportster-before.png' | asset_url }}" alt="" loading="lazy" class="km-models__compare-before-img">
              {%- endif -%}
              {%- if block.settings.after_image != blank -%}
                <img src="{{ block.settings.after_image | image_url: width: 1200 }}" alt="{{ block.settings.name }} after" loading="lazy" class="km-models__compare-after-img">
              {%- else -%}
                <img src="{{ 'model-sportster-after.png' | asset_url }}" alt="" loading="lazy" class="km-models__compare-after-img">
              {%- endif -%}
              <span class="km-models__compare-label is-before">{{ section.settings.before_label | default: 'Before' }}</span>
              <span class="km-models__compare-label is-after">{{ section.settings.after_label | default: 'After' }}</span>
              <div class="km-models__compare-handle" aria-hidden="true">
                <span class="km-models__compare-handle-dot">
                  {%- render 'icon', icon: 'chevron-left' -%}
                  {%- render 'icon', icon: 'chevron-right' -%}
                </span>
              </div>
            </div>

            <div class="km-models__info">
              <h3 class="km-models__title">{{ block.settings.name }}</h3>
              {%- if block.settings.description != blank -%}
                <p class="km-models__desc">{{ block.settings.description }}</p>
              {%- endif -%}
              {%- if block.settings.categories != blank -%}
                <div class="km-models__cats">
                  <span class="km-models__cats-label">{{ section.settings.cats_label | default: 'Choose category :' }}</span>
                  <div class="km-models__cats-list">
                    {%- assign cat_pairs = block.settings.categories | strip | split: ',' -%}
                    {%- for pair in cat_pairs -%}
                      {%- assign parts = pair | strip | split: '|' -%}
                      {%- assign label = parts[0] | strip -%}
                      {%- assign url = parts[1] | strip | default: '/collections/' | append: label | downcase | replace: ' ', '-' -%}
                      {%- if label != blank -%}
                        <a href="{{ url }}" class="km-models__cat-pill">
                          {{ label }}
                          {%- render 'icon', icon: 'arrow-right' -%}
                        </a>
                      {%- endif -%}
                    {%- endfor -%}
                  </div>
                </div>
              {%- endif -%}
            </div>
          </article>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</section>

<style>
  .km-models { background: var(--km-body-bg, #EDEDED); padding: 64px 0; }
  .km-models__header { text-align: center; max-width: 680px; margin: 0 auto 40px; }
  .km-models__list { display: flex; flex-direction: column; gap: 80px; }
  .km-models__row {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 48px;
    align-items: center;
  }
  .km-models__row:nth-child(even) { grid-template-columns: 1fr 1.2fr; }
  .km-models__row:nth-child(even) .km-models__compare { order: 2; }
  .km-models__row:nth-child(even) .km-models__info { order: 1; }
  .km-models__compare {
    position: relative; aspect-ratio: 16/10; border-radius: 20px;
    overflow: hidden; cursor: ew-resize; user-select: none; background: #fff;
  }
  .km-models__compare img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; }
  .km-models__compare-after-img { clip-path: inset(0 50% 0 0); will-change: clip-path; }
  .km-models__compare-label {
    position: absolute; top: 16px; padding: 6px 14px; border-radius: 9999px;
    background: rgba(0,0,0,.7); color: #fff; font-size: 11px; font-weight: 700;
    letter-spacing: .14em; text-transform: uppercase; backdrop-filter: blur(6px); z-index: 3;
  }
  .km-models__compare-label.is-before { left: 16px; }
  .km-models__compare-label.is-after { right: 16px; background: rgba(251,176,61,.95); color: #000; }
  .km-models__compare-handle {
    position: absolute; top: 0; bottom: 0; left: 50%; width: 3px; background: #fff;
    transform: translateX(-50%); z-index: 2; pointer-events: none;
  }
  .km-models__compare-handle-dot {
    position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%);
    width: 48px; height: 48px; border-radius: 50%; background: #fff; color: #000;
    display: flex; align-items: center; justify-content: center;
    box-shadow: 0 6px 20px rgba(0,0,0,.25); pointer-events: auto; cursor: ew-resize;
  }
  .km-models__compare-handle-dot svg:first-child { margin-right: -4px; }
  .km-models__compare-handle-dot svg:last-child { margin-left: -4px; }
  .km-models__info { padding: 0 16px; }
  .km-models__title { font-size: clamp(22px, 2.2vw, 30px); font-weight: 700; margin: 0 0 12px; color: var(--km-heading, #000); letter-spacing: -.01em; }
  .km-models__desc { color: var(--km-text, #4B5563); line-height: 1.7; font-size: 14px; margin: 0 0 22px; }
  .km-models__cats-label { display: block; font-size: 13px; font-weight: 700; margin-bottom: 12px; color: var(--km-heading, #000); }
  .km-models__cats-list { display: flex; flex-wrap: wrap; gap: 8px; }
  .km-models__cat-pill {
    display: inline-flex; align-items: center; gap: 6px; padding: 8px 16px;
    font-size: 11px; font-weight: 700; letter-spacing: .08em; text-transform: uppercase;
    background: #000; color: #fff; border-radius: 9999px; text-decoration: none;
    transition: background .2s ease;
  }
  .km-models__cat-pill:hover { background: var(--km-accent, #FBB03D); color: #000; }
  .km-models__cat-pill svg { width: 12px; height: 12px; }
  @media (max-width: 900px) {
    .km-models__row, .km-models__row:nth-child(even) { grid-template-columns: 1fr; gap: 24px; }
    .km-models__row:nth-child(even) .km-models__compare,
    .km-models__row:nth-child(even) .km-models__info { order: initial; }
    .km-models__info { padding: 0; }
  }
</style>

<script>
(() => {
  document.querySelectorAll('.km-models__compare[data-km-compare]').forEach((root) => {
    const after = root.querySelector('.km-models__compare-after-img');
    const handle = root.querySelector('.km-models__compare-handle');
    if (!after || !handle) return;
    let dragging = false;
    const setTo = (clientX) => {
      const rect = root.getBoundingClientRect();
      let pct = ((clientX - rect.left) / rect.width) * 100;
      pct = Math.max(0, Math.min(100, pct));
      after.style.clipPath = `inset(0 ${100 - pct}% 0 0)`;
      handle.style.left = pct + '%';
    };
    root.addEventListener('pointerdown', (e) => { dragging = true; root.setPointerCapture?.(e.pointerId); setTo(e.clientX); });
    root.addEventListener('pointermove', (e) => { if (dragging) setTo(e.clientX); });
    root.addEventListener('pointerup', () => { dragging = false; });
    root.addEventListener('pointercancel', () => { dragging = false; });
    root.addEventListener('pointerleave', () => { dragging = false; });
  });
})();
</script>

{% schema %}
{
  "name": "Model Chooser",
  "tag": "section",
  "class": "shopify-section-models",
  "settings": [
    { "type": "text", "id": "heading", "label": "Section heading", "default": "Choose Your Model" },
    { "type": "text", "id": "before_label", "label": "Before label", "default": "Before" },
    { "type": "text", "id": "after_label", "label": "After label", "default": "After" },
    { "type": "text", "id": "cats_label", "label": "Categories label", "default": "Choose category :" }
  ],
  "blocks": [
    {
      "type": "model",
      "name": "Motorcycle model",
      "settings": [
        { "type": "text", "id": "name", "label": "Model name", "default": "Harley Davidson Sportster" },
        { "type": "image_picker", "id": "before_image", "label": "Before image" },
        { "type": "image_picker", "id": "after_image", "label": "After image" },
        { "type": "textarea", "id": "description", "label": "Description", "default": "Description here." },
        {
          "type": "textarea",
          "id": "categories",
          "label": "Categories (comma-separated, optional |URL suffix)",
          "info": "e.g. 'Accessories, Exhausts|custom-exhausts, Handlebars'. Without |URL, uses /collections/{slug}.",
          "default": "Accessories, Exhausts, Handlebars"
        }
      ]
    }
  ],
  "max_blocks": 10,
  "presets": [
    {
      "name": "Model Chooser",
      "category": "Collections",
      "blocks": [
        { "type": "model", "settings": { "name": "Harley Davidson Sportster" } },
        { "type": "model", "settings": { "name": "Harley Davidson Softail" } },
        { "type": "model", "settings": { "name": "Harley Davidson Dyna" } },
        { "type": "model", "settings": { "name": "Triumph ( Bonneville / Thruxton / Scrambler )" } },
        { "type": "model", "settings": { "name": "Honda CB Series" } },
        { "type": "model", "settings": { "name": "Indian Motorcycle" } }
      ]
    }
  ]
}
{% endschema %}
