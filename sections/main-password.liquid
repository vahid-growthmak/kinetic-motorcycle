{%- comment -%}
  Password page section.
{%- endcomment -%}

<section class="km-section km-password" id="Section-{{ section.id }}">
  <div class="km-container km-container--narrow">
    <div class="km-password__card">
      <h1 class="km-password__title">{{ section.settings.title | default: "We're almost ready." }}</h1>
      <p class="km-password__subtext">
        {{ section.settings.subtext | default: "Opening the garage doors soon. Enter the password if you have one." }}
      </p>

      {%- form 'storefront_password', class: 'km-password__form' -%}
        <label for="Password" class="km-visually-hidden">Password</label>
        <div class="km-password__row">
          <input type="password" name="password" id="Password"
                 placeholder="{{ section.settings.placeholder | default: 'Password' }}" class="km-password__input" autocomplete="off" required>
          <button type="submit" class="km-btn km-btn-primary km-password__submit">
            {{ section.settings.button_label | default: 'Enter' }}
            {%- render 'icon', icon: 'arrow-right' -%}
          </button>
        </div>
        {%- if form.errors -%}
          <p class="km-password__error">{{ form.errors | default_errors }}</p>
        {%- endif -%}
      {%- endform -%}

      <p class="km-password__shop">
        <strong>{{ shop.name }}</strong>
      </p>
    </div>
  </div>
</section>

<style>
  .km-password { background: var(--km-body-bg); min-height: 80vh; display: flex; align-items: center; }
  .km-container--narrow { max-width: 640px; }
  .km-password__card {
    background: var(--km-surface); border: 1px solid var(--km-border);
    border-radius: var(--km-radius-lg); padding: 48px 40px;
    text-align: center; box-shadow: 0 10px 36px rgba(0,0,0,.06);
  }
  .km-password__title {
    font-size: clamp(26px, 3.4vw, 38px); font-weight: 800;
    letter-spacing: -.02em; color: var(--km-heading); margin: 0 0 12px;
  }
  .km-password__subtext { color: var(--km-text); font-size: 15px; margin: 0 0 28px; }
  .km-password__form { margin-bottom: 24px; }
  .km-password__row { display: flex; gap: 10px; }
  .km-password__input {
    flex: 1 1 auto; padding: 14px 18px;
    border: 1px solid var(--km-border); border-radius: var(--km-radius-pill);
    background: var(--km-body-bg); font-size: 15px; outline: none;
  }
  .km-password__input:focus { border-color: var(--km-heading); }
  .km-password__submit { padding: 14px 22px; }
  .km-password__error { color: #b91c1c; font-size: 13px; margin-top: 10px; }
  .km-password__shop { color: var(--km-text); font-size: 13px; margin: 0; opacity: .75; }
</style>

{% schema %}
{
  "name": "Password Page",
  "settings": [
    { "type": "text", "id": "title", "label": "Heading", "default": "We're almost ready." },
    { "type": "textarea", "id": "subtext", "label": "Subtext", "default": "Opening the garage doors soon. Enter the password if you have one." },
    { "type": "text", "id": "placeholder", "label": "Input placeholder", "default": "Password" },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Enter" }
  ],
  "presets": [
    {
      "name": "Password Page"
    }
  ]
}
{% endschema %}
