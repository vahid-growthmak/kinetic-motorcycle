{%- comment -%}
  Judge.me Review Widget
  This section displays the review widget for the current product.
{%- endcomment -%}

<div class="km-container judgeme-section" style="margin-top: 64px; margin-bottom: 64px;">
  <div class="km-pp__review-wrapper" id="km-judgeme-wrapper">
    <h2 class="km-section-title" style="margin-bottom: 40px; text-align: center;">Customer Reviews</h2>
    
    <!-- Start of Judge.me code -->
    {% assign has_legacy = false %}
    {% if product.metafields.judgeme.widget.size > 20 %}
      {% assign has_legacy = true %}
    {% endif %}
    <div style='clear:both'></div>
    <div id='judgeme_product_reviews' class='jdgm-widget jdgm-review-widget' 
      data-product-title='{{ product.title | escape }}' 
      data-id='{{ product.id }}' 
      data-product-id='{{ product.id }}' 
      data-widget='review' 
      data-auto-install='false' 
      data-shop-reviews-count='{{ shop.metafields.judgeme.shop_reviews_count | default: 0 | escape }}' 
      data-entry-point='review_widget.js' 
      data-entry-key='review-widget/main.js'>
      {% if has_legacy %}
        <div class='jdgm-legacy-widget-content' style='display: none;'>{{ product.metafields.judgeme.widget }}</div>
      {% endif %}
    </div>
    {% if product.metafields.judgeme.review_widget_data %}
      <script>jdgm.data ||= {}; jdgm.data.reviewWidget ||= {}; jdgm.data.reviewWidget[{{ product.id }}] = {{ product.metafields.judgeme.review_widget_data }}</script>
    {% endif %}
    <!-- End of Judge.me code -->
  </div>
</div>

<style>
  .km-pp__review-wrapper {
    background: #fff;
    border: 1px solid var(--km-border, #DDDDDD);
    border-radius: 20px;
    padding: 64px 48px;
    position: relative;
  }
  
  .km-section-title {
    font-size: clamp(24px, 3vw, 34px);
    font-weight: 700;
    color: #000;
    margin: 0;
    letter-spacing: -.01em;
    text-transform: none;
  }
  
  /* =========================================
     HYPER-AGGRESSIVE JUDGE.ME OVERRIDES
     Using 'html body' to ensure high specificity 
     against Judge.me's injected stylesheets.
     ========================================= */
  
  html body .jdgm-widget.jdgm-review-widget {
    font-family: inherit !important;
    color: var(--km-text, #4B5563) !important;
    border: 0 !important;
  }
  
  /* 1. Hide the duplicate title */
  html body .jdgm-rev-widg__title,
  html body .jdgm-widget-title,
  html body h2.jdgm-rev-widg__title {
    display: none !important;
    visibility: hidden !important;
    opacity: 0 !important;
    height: 0 !important;
    margin: 0 !important;
    padding: 0 !important;
    overflow: hidden !important;
  }
  
  /* 2. Center the header area */
  html body .jdgm-rev-widg__header {
    border-bottom: 0 !important;
    margin-bottom: 32px !important;
    display: flex !important;
    flex-direction: column !important;
    align-items: center !important;
    text-align: center !important;
  }
  
  html body .jdgm-widget .jdgm-star {
    color: var(--km-accent, #FBB03D) !important;
  }
  
  /* 3. Primary CTA Button Styling (Force Yellow) */
  html body .jdgm-write-rev-btn, 
  html body .jdgm-submit-rev,
  html body .jdgm-rev-widg .jdgm-btn,
  html body .jdgm-btn,
  html body input.jdgm-submit-rev {
    display: inline-flex !important;
    align-items: center !important;
    justify-content: center !important;
    padding: 16px 32px !important;
    background-color: var(--km-accent, #FBB03D) !important;
    background: var(--km-accent, #FBB03D) !important;
    color: #000 !important;
    border: 0 !important;
    border-radius: 9999px !important;
    font-weight: 800 !important;
    font-size: 12px !important;
    letter-spacing: .14em !important;
    text-transform: uppercase !important;
    cursor: pointer !important;
    transition: all .2s ease !important;
    height: auto !important;
    line-height: 1 !important;
    box-shadow: none !important;
  }
  
  html body .jdgm-write-rev-btn:hover,
  html body .jdgm-submit-rev:hover,
  html body .jdgm-btn:hover,
  html body input.jdgm-submit-rev:hover {
    background-color: #000 !important;
    background: #000 !important;
    color: #fff !important;
    transform: translateY(-2px);
  }
  
  html body .jdgm-rev-widg__summary-text {
    font-weight: 700 !important;
    text-transform: uppercase !important;
    font-size: 13px !important;
    letter-spacing: 0.04em !important;
    color: #000 !important;
    margin-top: 12px !important;
    display: block !important;
  }
  
  html body .jdgm-rev {
    border-top: 1px solid var(--km-border, #DDDDDD) !important;
    padding: 32px 0 !important;
  }
  
  html body .jdgm-rev__author {
    font-weight: 700 !important;
    color: #000 !important;
    text-transform: uppercase !important;
    font-size: 13px !important;
  }
  
  html body .jdgm-rev__title {
    font-weight: 700 !important;
    color: #000 !important;
    font-size: 16px !important;
    margin: 8px 0 !important;
  }
  
  html body .jdgm-rev__body p {
    line-height: 1.65 !important;
    font-size: 14px !important;
  }

  /* Centering Fixes for Empty State */
  html body .jdgm-rev-widg__header-right {
    float: none !important;
    display: flex !important;
    justify-content: center !important;
    margin-top: 16px !important;
    width: 100% !important;
  }
  
  @media (max-width: 768px) {
    .km-pp__review-wrapper {
      padding: 32px 20px;
    }
    .km-section-title {
      font-size: 24px;
    }
  }
</style>

<script>
  // ULTRA-AGGRESSIVE JUDGE.ME STYLER
  // This script bypasses class names and searches for elements by their raw text content
  // to guarantee styling is applied no matter how Judge.me loads or obfuscates classes.
  (() => {
    const applyDeepStyles = () => {
      const wrapper = document.getElementById('km-judgeme-wrapper');
      if (!wrapper) return;

      // 1. Find and hide duplicate titles
      const allTextElements = wrapper.querySelectorAll('h2, h3, div, span');
      allTextElements.forEach(el => {
        const text = el.textContent.trim().toLowerCase();
        if (text === 'customer reviews' && !el.classList.contains('km-section-title')) {
          el.setAttribute('style', 'display: none !important; visibility: hidden !important; opacity: 0 !important; height: 0 !important; overflow: hidden !important; position: absolute !important;');
        }
      });

      // 2. Find and style buttons
      const allButtons = wrapper.querySelectorAll('a, button, input[type="submit"], input[type="button"], .jdgm-btn');
      allButtons.forEach(btn => {
        const text = (btn.value || btn.textContent || '').trim().toLowerCase();
        if (text.includes('write a review') || text.includes('submit review') || btn.classList.toString().includes('jdgm-')) {
          // Ignore our own carousel arrows if they somehow end up here
          if (btn.classList.contains('km-pp-reviews__arrow')) return;
          
          btn.setAttribute('style', 'background-color: #FBB03D !important; background: #FBB03D !important; color: #000 !important; border: none !important; border-radius: 9999px !important; padding: 16px 32px !important; font-weight: 800 !important; font-size: 12px !important; text-transform: uppercase !important; letter-spacing: 0.14em !important; box-shadow: none !important; display: inline-flex !important; align-items: center !important; justify-content: center !important; cursor: pointer !important; text-decoration: none !important;');
        }
      });

      // 3. Fix star colors
      const stars = wrapper.querySelectorAll('.jdgm-star');
      stars.forEach(star => {
        star.setAttribute('style', 'color: #FBB03D !important;');
      });

      // 4. Center header right container (usually contains the button in empty state)
      const headerRight = wrapper.querySelectorAll('.jdgm-rev-widg__header-right');
      headerRight.forEach(hr => {
        hr.setAttribute('style', 'float: none !important; display: flex !important; justify-content: center !important; margin-top: 16px !important; width: 100% !important;');
      });
      
      // 5. Center header text
      const headers = wrapper.querySelectorAll('.jdgm-rev-widg__header');
      headers.forEach(h => {
        h.setAttribute('style', 'display: flex !important; flex-direction: column !important; align-items: center !important; text-align: center !important; border: none !important;');
      });
    };

    // Run immediately
    applyDeepStyles();

    // Use MutationObserver to watch for ANY DOM changes within the wrapper
    const wrapper = document.getElementById('km-judgeme-wrapper');
    if (wrapper) {
      const observer = new MutationObserver(() => {
        applyDeepStyles();
      });
      observer.observe(wrapper, { childList: true, subtree: true, attributes: true });
    }

    // Polling fallback
    const interval = setInterval(applyDeepStyles, 100); // Very fast polling
    setTimeout(() => clearInterval(interval), 15000); // Stop after 15s

    // Listen for custom events
    document.addEventListener('jdgm.doneSetup', applyDeepStyles);
  })();
</script>

{% schema %}
{
  "name": "Judge.me Review Widget",
  "settings": [],
  "presets": [
    {
      "name": "Judge.me Review Widget"
    }
  ]
}
{% endschema %}
