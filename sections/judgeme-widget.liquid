{%- comment -%}
  Judge.me Review Widget
  This section displays the review widget for the current product.
{%- endcomment -%}

<div class="km-container judgeme-section" style="margin-top: 64px; margin-bottom: 64px;">
  <div class="km-pp__review-wrapper" id="km-judgeme-wrapper">
    <h2 class="km-section-title" style="margin-bottom: 40px; text-align: center;">Customer Reviews</h2>
    
    <!-- Start of Judge.me code -->
    {% assign has_legacy = false %}
    {% if product.metafields.judgeme.widget.size > 20 %}
      {% assign has_legacy = true %}
    {% endif %}
    <div style='clear:both'></div>
    <div id='judgeme_product_reviews' class='jdgm-widget jdgm-review-widget' 
      data-product-title='{{ product.title | escape }}' 
      data-id='{{ product.id }}' 
      data-product-id='{{ product.id }}' 
      data-widget='review' 
      data-auto-install='false' 
      data-shop-reviews-count='{{ shop.metafields.judgeme.shop_reviews_count | default: 0 | escape }}' 
      data-entry-point='review_widget.js' 
      data-entry-key='review-widget/main.js'>
      {% if has_legacy %}
        <div class='jdgm-legacy-widget-content' style='display: none;'>{{ product.metafields.judgeme.widget }}</div>
      {% endif %}
    </div>
    {% if product.metafields.judgeme.review_widget_data %}
      <script>jdgm.data ||= {}; jdgm.data.reviewWidget ||= {}; jdgm.data.reviewWidget[{{ product.id }}] = {{ product.metafields.judgeme.review_widget_data }}</script>
    {% endif %}
    <!-- End of Judge.me code -->
  </div>
</div>

<style>
  .km-pp__review-wrapper {
    background: #fff;
    border: 1px solid var(--km-border, #DDDDDD);
    border-radius: 20px;
    padding: 64px 48px;
    position: relative;
  }
  
  .km-section-title {
    font-size: clamp(24px, 3vw, 34px);
    font-weight: 700;
    color: #000;
    margin: 0;
    letter-spacing: -.01em;
    text-transform: none;
  }
  
  /* Safe Judge.me Overrides */
  #km-judgeme-wrapper .jdgm-widget.jdgm-review-widget {
    font-family: inherit !important;
    color: var(--km-text, #4B5563) !important;
    border: 0 !important;
  }
  
  #km-judgeme-wrapper .jdgm-rev-widg__title,
  #km-judgeme-wrapper .jdgm-widget-title,
  #km-judgeme-wrapper h2.jdgm-rev-widg__title {
    display: none !important;
  }
  
  #km-judgeme-wrapper .jdgm-rev-widg__header {
    border-bottom: 0 !important;
    margin-bottom: 32px !important;
    display: flex !important;
    flex-direction: column !important;
    align-items: center !important;
    text-align: center !important;
  }
  
  #km-judgeme-wrapper .jdgm-widget .jdgm-star {
    color: var(--km-accent, #FBB03D) !important;
  }
  
  #km-judgeme-wrapper .jdgm-write-rev-btn, 
  #km-judgeme-wrapper .jdgm-submit-rev,
  #km-judgeme-wrapper .jdgm-rev-widg .jdgm-btn,
  #km-judgeme-wrapper .jdgm-btn {
    display: inline-flex !important;
    align-items: center !important;
    justify-content: center !important;
    padding: 16px 32px !important;
    background-color: var(--km-accent, #FBB03D) !important;
    background: var(--km-accent, #FBB03D) !important;
    color: #000 !important;
    border: 0 !important;
    border-radius: 9999px !important;
    font-weight: 800 !important;
    font-size: 12px !important;
    letter-spacing: .14em !important;
    text-transform: uppercase !important;
    cursor: pointer !important;
    transition: all .2s ease !important;
    height: auto !important;
    line-height: 1 !important;
    box-shadow: none !important;
  }
  
  #km-judgeme-wrapper .jdgm-write-rev-btn:hover,
  #km-judgeme-wrapper .jdgm-submit-rev:hover,
  #km-judgeme-wrapper .jdgm-btn:hover {
    background-color: #000 !important;
    background: #000 !important;
    color: #fff !important;
    transform: translateY(-2px);
  }
  
  #km-judgeme-wrapper .jdgm-rev-widg__summary-text {
    font-weight: 700 !important;
    text-transform: uppercase !important;
    font-size: 13px !important;
    letter-spacing: 0.04em !important;
    color: #000 !important;
    margin-top: 12px !important;
    display: block !important;
  }
  
  #km-judgeme-wrapper .jdgm-rev {
    border-top: 1px solid var(--km-border, #DDDDDD) !important;
    padding: 32px 0 !important;
  }
  
  #km-judgeme-wrapper .jdgm-rev__author {
    font-weight: 700 !important;
    color: #000 !important;
    text-transform: uppercase !important;
    font-size: 13px !important;
  }
  
  #km-judgeme-wrapper .jdgm-rev__title {
    font-weight: 700 !important;
    color: #000 !important;
    font-size: 16px !important;
    margin: 8px 0 !important;
  }
  
  #km-judgeme-wrapper .jdgm-rev__body p {
    line-height: 1.65 !important;
    font-size: 14px !important;
  }

  #km-judgeme-wrapper .jdgm-rev-widg__header-right {
    float: none !important;
    display: flex !important;
    justify-content: center !important;
    margin-top: 16px !important;
    width: 100% !important;
  }
  
  @media (max-width: 768px) {
    .km-pp__review-wrapper {
      padding: 32px 20px;
    }
    .km-section-title {
      font-size: 24px;
    }
  }
</style>

<script>
  (() => {
    // Safe DOM styling without infinite loops
    const safeStyleJudgeMe = () => {
      const wrapper = document.getElementById('km-judgeme-wrapper');
      if (!wrapper) return;

      // Hide Duplicate Title
      const titles = wrapper.querySelectorAll('.jdgm-rev-widg__title, h2.jdgm-rev-widg__title');
      titles.forEach(el => {
        if (el.style.display !== 'none') {
          el.style.setProperty('display', 'none', 'important');
        }
      });

      // Force Button Colors
      const buttons = wrapper.querySelectorAll('.jdgm-write-rev-btn, .jdgm-submit-rev, .jdgm-btn');
      buttons.forEach(btn => {
        if (btn.style.backgroundColor !== 'rgb(251, 176, 61)' && btn.style.backgroundColor !== '#FBB03D') {
          btn.style.setProperty('background-color', '#FBB03D', 'important');
          btn.style.setProperty('background', '#FBB03D', 'important');
          btn.style.setProperty('color', '#000', 'important');
          btn.style.setProperty('border-radius', '9999px', 'important');
          btn.style.setProperty('border', 'none', 'important');
        }
      });
      
      // Fix Stars
      const stars = wrapper.querySelectorAll('.jdgm-star');
      stars.forEach(star => {
        if (star.style.color !== 'rgb(251, 176, 61)' && star.style.color !== '#FBB03D') {
          star.style.setProperty('color', '#FBB03D', 'important');
        }
      });
    };

    // Run polling safely
    const interval = setInterval(safeStyleJudgeMe, 500);
    setTimeout(() => clearInterval(interval), 15000); // Stop after 15s

    // Run on Judge.me's native event
    document.addEventListener('jdgm.doneSetup', safeStyleJudgeMe);
  })();
</script>

