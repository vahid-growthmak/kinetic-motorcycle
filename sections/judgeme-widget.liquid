{%- comment -%}
  Judge.me Review Widget
  This section displays the review widget for the current product.
{%- endcomment -%}

<div class="km-container judgeme-section" style="margin-top: 64px; margin-bottom: 64px;">
  <div class="km-pp__review-wrapper">
    <h2 class="km-section-title" style="margin-bottom: 40px; text-align: center;">Customer Reviews</h2>
    
    <div style='clear:both'></div>
    <div class='jdgm-widget jdgm-review-widget' data-id='{{ product.id }}'></div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const initJdgm = () => {
      try {
        if (window.jdgm && typeof window.jdgm.initializeWidgets === 'function') {
          window.jdgm.initializeWidgets();
        }
      } catch (e) {
        console.warn('Judge.me init failed:', e);
      }
    };
    setTimeout(initJdgm, 2000);
  });
</script>

<style>
  .km-pp__review-wrapper {
    background: var(--km-surface, #FFFFFF);
    border: 1px solid var(--km-border, #DDDDDD);
    border-radius: var(--km-radius-lg, 20px);
    padding: 80px 48px;
    position: relative;
    box-shadow: var(--km-shadow-sm);
  }
  
  .km-section-title {
    font-family: var(--km-font-heading);
    font-size: clamp(28px, 3.2vw, 44px);
    font-weight: 700;
    color: var(--km-heading, #000);
    margin: 0 0 48px;
    letter-spacing: -.02em;
    text-transform: none;
    text-align: center;
  }
  
</style>

{% schema %}
{
  "name": "Judge.me Review Widget",
  "settings": [],
  "presets": [
    {
      "name": "Judge.me Review Widget"
    }
  ]
}
{% endschema %}
