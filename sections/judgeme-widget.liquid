{%- comment -%}
  Judge.me Review Widget
  This section displays the review widget for the current product.
{%- endcomment -%}

<div class="km-container judgeme-section" style="margin-top: 64px; margin-bottom: 64px;">
  <div class="km-pp__review-wrapper" id="km-judgeme-wrapper">
    <h2 class="km-section-title" style="margin-bottom: 40px; text-align: center;">Customer Reviews</h2>
    
    <!-- Start of Judge.me code -->
    {% assign has_legacy = false %}
    {% if product.metafields.judgeme.widget.size > 20 %}
      {% assign has_legacy = true %}
    {% endif %}
    <div style='clear:both'></div>
    <div id='judgeme_product_reviews' class='jdgm-widget jdgm-review-widget' 
      data-product-title='{{ product.title | escape }}' 
      data-id='{{ product.id }}' 
      data-product-id='{{ product.id }}' 
      data-widget='review' 
      data-auto-install='false' 
      data-shop-reviews-count='{{ shop.metafields.judgeme.shop_reviews_count | default: 0 | escape }}' 
      data-entry-point='review_widget.js' 
      data-entry-key='review-widget/main.js'>
      {% if has_legacy %}
        <div class='jdgm-legacy-widget-content' style='display: none;'>{{ product.metafields.judgeme.widget }}</div>
      {% endif %}
    </div>
    {% if product.metafields.judgeme.review_widget_data %}
      <script>jdgm.data ||= {}; jdgm.data.reviewWidget ||= {}; jdgm.data.reviewWidget[{{ product.id }}] = {{ product.metafields.judgeme.review_widget_data }}</script>
    {% endif %}
    <!-- End of Judge.me code -->
  </div>
</div>

<style>
  .km-pp__review-wrapper {
    background: #fff;
    border: 1px solid var(--km-border, #DDDDDD);
    border-radius: 20px;
    padding: 64px 48px;
    position: relative;
  }
  
  .km-section-title {
    font-size: clamp(24px, 3vw, 34px);
    font-weight: 700;
    color: #000;
    margin: 0;
    letter-spacing: -.01em;
    text-transform: none;
  }
  
  /* =========================================
     HYPER-AGGRESSIVE JUDGE.ME OVERRIDES
     Using 'html body' to ensure high specificity 
     against Judge.me's injected stylesheets.
     ========================================= */
  
  html body .jdgm-widget.jdgm-review-widget {
    font-family: inherit !important;
    color: var(--km-text, #4B5563) !important;
    border: 0 !important;
  }
  
  /* 1. Hide the duplicate title */
  html body .jdgm-rev-widg__title,
  html body .jdgm-widget-title,
  html body h2.jdgm-rev-widg__title {
    display: none !important;
    visibility: hidden !important;
    opacity: 0 !important;
    height: 0 !important;
    margin: 0 !important;
    padding: 0 !important;
    overflow: hidden !important;
  }
  
  /* 2. Center the header area */
  html body .jdgm-rev-widg__header {
    border-bottom: 0 !important;
    margin-bottom: 32px !important;
    display: flex !important;
    flex-direction: column !important;
    align-items: center !important;
    text-align: center !important;
  }
  
  html body .jdgm-widget .jdgm-star {
    color: var(--km-accent, #FBB03D) !important;
  }
  
  /* 3. Primary CTA Button Styling (Force Yellow) */
  html body .jdgm-write-rev-btn, 
  html body .jdgm-submit-rev,
  html body .jdgm-rev-widg .jdgm-btn,
  html body .jdgm-btn,
  html body input.jdgm-submit-rev {
    display: inline-flex !important;
    align-items: center !important;
    justify-content: center !important;
    padding: 16px 32px !important;
    background-color: var(--km-accent, #FBB03D) !important;
    background: var(--km-accent, #FBB03D) !important;
    color: #000 !important;
    border: 0 !important;
    border-radius: 9999px !important;
    font-weight: 800 !important;
    font-size: 12px !important;
    letter-spacing: .14em !important;
    text-transform: uppercase !important;
    cursor: pointer !important;
    transition: all .2s ease !important;
    height: auto !important;
    line-height: 1 !important;
    box-shadow: none !important;
  }
  
  html body .jdgm-write-rev-btn:hover,
  html body .jdgm-submit-rev:hover,
  html body .jdgm-btn:hover,
  html body input.jdgm-submit-rev:hover {
    background-color: #000 !important;
    background: #000 !important;
    color: #fff !important;
    transform: translateY(-2px);
  }
  
  html body .jdgm-rev-widg__summary-text {
    font-weight: 700 !important;
    text-transform: uppercase !important;
    font-size: 13px !important;
    letter-spacing: 0.04em !important;
    color: #000 !important;
    margin-top: 12px !important;
    display: block !important;
  }
  
  html body .jdgm-rev {
    border-top: 1px solid var(--km-border, #DDDDDD) !important;
    padding: 32px 0 !important;
  }
  
  html body .jdgm-rev__author {
    font-weight: 700 !important;
    color: #000 !important;
    text-transform: uppercase !important;
    font-size: 13px !important;
  }
  
  html body .jdgm-rev__title {
    font-weight: 700 !important;
    color: #000 !important;
    font-size: 16px !important;
    margin: 8px 0 !important;
  }
  
  html body .jdgm-rev__body p {
    line-height: 1.65 !important;
    font-size: 14px !important;
  }

  /* Centering Fixes for Empty State */
  html body .jdgm-rev-widg__header-right {
    float: none !important;
    display: flex !important;
    justify-content: center !important;
    margin-top: 16px !important;
    width: 100% !important;
  }
  
  @media (max-width: 768px) {
    .km-pp__review-wrapper {
      padding: 32px 20px;
    }
    .km-section-title {
      font-size: 24px;
    }
  }
</style>

<script>
  // Robust MutationObserver to force inline styles as soon as Judge.me renders
  (() => {
    const forceJudgeMeStyles = () => {
      // 1. Hide titles
      const titles = document.querySelectorAll('.jdgm-rev-widg__title, .jdgm-widget-title');
      titles.forEach(t => {
        t.style.setProperty('display', 'none', 'important');
        t.style.setProperty('visibility', 'hidden', 'important');
      });
      
      // 2. Force Button Colors
      const btns = document.querySelectorAll('.jdgm-btn, .jdgm-write-rev-btn, .jdgm-submit-rev');
      btns.forEach(btn => {
        btn.style.setProperty('background-color', '#FBB03D', 'important');
        btn.style.setProperty('background', '#FBB03D', 'important');
        btn.style.setProperty('color', '#000', 'important');
        btn.style.setProperty('border', 'none', 'important');
        btn.style.setProperty('border-radius', '9999px', 'important');
      });
    };

    // Run immediately just in case
    forceJudgeMeStyles();

    // Set up observer to watch for Judge.me injecting its HTML
    const observer = new MutationObserver((mutations) => {
      let shouldForce = false;
      for (const mutation of mutations) {
        if (mutation.addedNodes.length > 0) {
          // If any nodes were added, run the styling check
          shouldForce = true;
          break;
        }
      }
      if (shouldForce) {
        forceJudgeMeStyles();
      }
    });

    // Start observing the body for changes
    observer.observe(document.body, { childList: true, subtree: true });

    // Fallback polling for the first 10 seconds
    const interval = setInterval(forceJudgeMeStyles, 500);
    setTimeout(() => {
      clearInterval(interval);
      // We can keep the observer running to catch "Write Review" modal opens
    }, 10000);
    
    document.addEventListener('jdgm.doneSetup', forceJudgeMeStyles);
  })();
</script>

{% schema %}
{
  "name": "Judge.me Review Widget",
  "settings": [],
  "presets": [
    {
      "name": "Judge.me Review Widget"
    }
  ]
}
{% endschema %}
