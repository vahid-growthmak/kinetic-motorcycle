{%- comment -%}
  ------------------------------------------------------------
  Hero — Full-bleed background image with left-aligned copy
  Eyebrow • Big headline • Body • CTA
  ------------------------------------------------------------
{%- endcomment -%}

<section class="km-hero" data-km-reveal
  style="--km-hero-height: {{ section.settings.min_height }}px;">
  <div class="km-hero__bg">
    {%- if section.settings.image != blank -%}
      {{ section.settings.image | image_url: width: 2400 | image_tag:
        loading: 'eager',
        fetchpriority: 'high',
        width: section.settings.image.width,
        height: section.settings.image.height,
        alt: section.settings.image.alt | default: section.settings.heading,
        class: 'km-hero__img'
      }}
    {%- else -%}
      <img src="{{ 'hero-bg.webp' | asset_url }}" alt="{{ section.settings.heading }}"
           class="km-hero__img" loading="eager" fetchpriority="high">
    {%- endif -%}
    <div class="km-hero__overlay"
      style="background: rgba(0,0,0,{{ section.settings.overlay_opacity | divided_by: 100.0 | default: 0.4 }});"></div>
  </div>

  <div class="km-container km-hero__inner">
    <div class="km-hero__content">
      {%- if section.settings.eyebrow != blank -%}
        <span class="km-hero__eyebrow">{{ section.settings.eyebrow }}</span>
      {%- endif -%}
      <h1 class="km-hero__heading">{{ section.settings.heading }}</h1>
      {%- if section.settings.subtext != blank -%}
        <p class="km-hero__subtext">{{ section.settings.subtext }}</p>
      {%- endif -%}
      {%- if section.settings.cta_label != blank -%}
        <a href="{{ section.settings.cta_url | default: '#' }}" class="km-btn km-btn-primary km-hero__cta">
          {{ section.settings.cta_label }}
          {%- render 'icon', icon: 'arrow-right' -%}
        </a>
      {%- endif -%}
    </div>
  </div>

  <div class="km-hero__chips">
    <div class="km-container km-hero__chips-row">
      {%- if section.settings.chips_label != blank -%}
        <span class="km-hero__chips-label">{{ section.settings.chips_label }}</span>
      {%- endif -%}
      {%- if section.blocks.size > 0 -%}
        {%- for block in section.blocks -%}
          {%- if block.type == 'chip' -%}
            <a href="{{ block.settings.url | default: '#' }}" class="km-hero__chip" {{ block.shopify_attributes }}>{{ block.settings.label }}</a>
          {%- endif -%}
        {%- endfor -%}
      {%- else -%}
        {%- assign fallback_chips = 'Sportster,sportster|Softail,softail|Dyna,dyna|Triumph,triumph|Honda,honda|Indian,indian' | split: '|' -%}
        {%- for chip in fallback_chips -%}
          {%- assign p = chip | split: ',' -%}
          <a href="/collections/{{ p[1] }}" class="km-hero__chip">{{ p[0] }}</a>
        {%- endfor -%}
      {%- endif -%}
    </div>
  </div>
</section>

<style>
  .km-hero {
    position: relative;
    min-height: var(--km-hero-height, 540px);
    display: flex;
    align-items: center;
    overflow: hidden;
    isolation: isolate;
  }
  .km-hero__bg {
    position: absolute; inset: 0; z-index: -1;
  }
  .km-hero__img {
    width: 100%; height: 100%; object-fit: cover; object-position: center;
    transform: scale(1.02);
  }
  .km-hero__overlay {
    position: absolute; inset: 0;
  }

  .km-hero__inner {
    width: 100%;
    padding-top: 80px;
    padding-bottom: 140px;
  }
  .km-hero__content {
    max-width: 640px;
    color: #fff;
  }
  .km-hero__eyebrow {
    display: inline-block;
    font-size: 14px;
    font-weight: 600;
    color: #fff;
    letter-spacing: .06em;
    margin-bottom: 20px;
    opacity: .95;
  }
  .km-hero__heading {
    color: #fff;
    font-size: clamp(40px, 5.5vw, 72px);
    font-weight: 700;
    letter-spacing: -.02em;
    line-height: 1.05;
    margin: 0 0 20px;
  }
  .km-hero__subtext {
    color: #e5e7eb;
    font-size: clamp(15px, 1.2vw, 17px);
    line-height: 1.6;
    max-width: 520px;
    margin: 0 0 32px;
  }
  .km-hero__cta {
    background: var(--km-accent);
    color: #fff;
    padding: 12px 26px;
    border-radius: 30px;
    font-size: 14px;
    font-weight: 500;
    letter-spacing: normal;
    text-transform: none;
  }
  .km-hero__cta:hover { background: #e69a2b; transform: translateY(-1px); }

  .km-hero__chips {
    position: absolute;
    left: 0; right: 0; bottom: 0;
    padding: 16px 0;
    background: linear-gradient(to top, rgba(0,0,0,.6), transparent);
  }
  .km-hero__chips-row {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    flex-wrap: wrap;
  }
  .km-hero__chips-label {
    color: #fff;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: .04em;
    margin-right: 8px;
  }
  .km-hero__chip {
    padding: 10px 22px;
    border-radius: var(--km-radius-pill);
    background: rgba(255,255,255,.1);
    border: 1px solid rgba(255,255,255,.2);
    color: #fff;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: .1em;
    text-transform: uppercase;
    backdrop-filter: blur(6px);
    transition: background var(--km-transition), color var(--km-transition);
  }
  .km-hero__chip:hover {
    background: #fff;
    color: #000;
  }

  @media (max-width: 1000px) {
    .km-hero {
      display: flex !important;
      flex-direction: column !important;
      justify-content: flex-end !important;
      align-items: flex-start !important;
      min-height: clamp(540px, 85vh, 750px) !important;
    }
    .km-hero__inner {
      margin-top: auto !important; /* Force content to bottom of flex container */
      padding: 40px 20px 150px !important; /* Bottom padding to clear chips */
      width: 100% !important;
      text-align: left !important;
    }
    .km-hero__content {
      max-width: 100% !important;
      margin: 0 !important;
      text-align: left !important;
    }
    .km-hero__heading {
      font-size: clamp(32px, 8vw, 48px) !important;
      text-align: left !important;
    }
    .km-hero__subtext {
      margin-left: 0 !important;
      margin-right: 0 !important;
      text-align: left !important;
    }
    .km-hero__chip { 
      padding: 8px 14px; 
      font-size: 11px; 
    }
  }
</style>

{% schema %}
{
  "name": "Hero",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background image"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay darkness",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 50,
      "unit": "%"
    },
    {
      "type": "range",
      "id": "min_height",
      "label": "Minimum height",
      "min": 400,
      "max": 900,
      "step": 20,
      "default": 540,
      "unit": "px"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Elevate Your Ride"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Precision Performance. Seamless Fit."
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Subtext",
      "default": "Performance-Driven Parts & Gear for Riders Who Live to Ride. Precision-engineered. Made in the USA. Designed for your bike."
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA label",
      "default": "Find Parts For Your Motorcycle"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "CTA URL"
    },
    {
      "type": "text",
      "id": "chips_label",
      "label": "Chips label",
      "default": "Shop by models :"
    }
  ],
  "blocks": [
    {
      "type": "chip",
      "name": "Model chip",
      "settings": [
        { "type": "text", "id": "label", "label": "Label", "default": "Sportster" },
        { "type": "url", "id": "url", "label": "Link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Hero",
      "settings": {
        "cta_url": "/collections"
      },
      "blocks": [
        { "type": "chip", "settings": { "label": "Sportster", "url": "/collections/sportster" } },
        { "type": "chip", "settings": { "label": "Softail", "url": "/collections/softail" } },
        { "type": "chip", "settings": { "label": "Dyna", "url": "/collections/dyna" } },
        { "type": "chip", "settings": { "label": "Triumph", "url": "/collections/triumph" } },
        { "type": "chip", "settings": { "label": "Honda", "url": "/collections/honda" } },
        { "type": "chip", "settings": { "label": "Indian", "url": "/collections/indian" } }
      ]
    }
  ]
}
{% endschema %}
