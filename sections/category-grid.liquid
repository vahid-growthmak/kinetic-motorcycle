{%- comment -%}
  ------------------------------------------------------------
  Category grid — "Browse by Categories"
  4-column card grid with image + label + Shop Now arrow
  ------------------------------------------------------------
{%- endcomment -%}

<section class="km-section km-categories" id="Section-{{ section.id }}">
  <div class="km-container">
    <div class="km-section-row">
      <h2 class="km-section-heading">{{ section.settings.heading | default: 'Browse by Categories' }}</h2>
      {%- if section.settings.view_all_url != blank -%}
        <a href="{{ section.settings.view_all_url }}" class="km-btn-view-all">{{ section.settings.view_all_label | default: 'View All' }}</a>
      {%- endif -%}
    </div>

    <div class="km-categories__grid">
      {%- if section.blocks.size > 0 -%}
        {%- for block in section.blocks -%}
          <a href="{{ block.settings.url | default: '#' }}" class="km-categories__card" {{ block.shopify_attributes }}>
            <div class="km-categories__image-wrap">
              {%- if block.settings.image != blank -%}
                {{ block.settings.image | image_url: width: 600 | image_tag: width: 300, height: 300, loading: 'lazy', alt: block.settings.label, class: 'km-categories__image' }}
              {%- elsif block.settings.asset_name != blank -%}
                <img src="{{ block.settings.asset_name | asset_url }}" width="300" height="300" loading="lazy" alt="{{ block.settings.label }}" class="km-categories__image">
              {%- else -%}
                <div class="km-categories__placeholder"></div>
              {%- endif -%}
            </div>
            <div class="km-categories__meta">
              <h3 class="km-categories__label">{{ block.settings.label }}</h3>
              <span class="km-categories__cta">Shop Now {%- render 'icon', icon: 'arrow-right' -%}</span>
            </div>
          </a>
        {%- endfor -%}
      {%- else -%}
        {%- assign fallback_cats = 'Indian|model-sportster-after.png||Dyna|model-dyna-after.webp||Honda|model-honda-after.webp||Triumph|model-triumph-after.webp' | split: '||' -%}
        {%- for entry in fallback_cats -%}
          {%- assign p = entry | split: '|' -%}
          <a href="#" class="km-categories__card">
            <div class="km-categories__image-wrap">
              <img src="{{ p[1] | asset_url }}" width="300" height="300" loading="lazy" alt="{{ p[0] }}" class="km-categories__image">
            </div>
            <div class="km-categories__meta">
              <h3 class="km-categories__label">{{ p[0] }}</h3>
              <span class="km-categories__cta">Shop Now {%- render 'icon', icon: 'arrow-right' -%}</span>
            </div>
          </a>
        {%- endfor -%}
      {%- endif -%}
    </div>
  </div>
</section>

<style>
  .km-categories__grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 24px;
  }
  .km-categories__card {
    display: block;
    background: var(--km-surface);
    border-radius: var(--km-radius-lg);
    overflow: hidden;
    border: 1px solid var(--km-border);
    transition: transform var(--km-transition), box-shadow var(--km-transition);
  }
  .km-categories__card:hover {
    transform: translateY(-4px);
    box-shadow: var(--km-shadow);
  }
  .km-categories__image-wrap {
    aspect-ratio: 1/1;
    overflow: hidden;
    background: #f3f4f6;
  }
  .km-categories__image {
    width: 100%; height: 100%;
    object-fit: cover;
    transition: transform 400ms ease;
  }
  .km-categories__card:hover .km-categories__image {
    transform: scale(1.05);
  }
  .km-categories__placeholder {
    width: 100%; height: 100%;
    background: linear-gradient(135deg, #f3f4f6, #e5e7eb);
  }
  .km-categories__meta {
    padding: 20px 22px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    min-width: 0; /* Allow flex children to shrink below their content size */
  }
  .km-categories__label {
    margin: 0;
    font-size: 18px;
    font-weight: 700;
    color: var(--km-heading);
    white-space: normal;
    overflow: hidden;
    text-overflow: ellipsis;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    line-height: 1.2;
    flex: 1;
  }
  .km-categories__cta {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: .05em;
    text-transform: uppercase;
    color: var(--km-primary);
    white-space: nowrap;
    flex-shrink: 0;
  }

  @media (max-width: 900px) {
    .km-categories__grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  }
  @media (max-width: 480px) {
    .km-categories__meta { padding: 14px 16px; }
    .km-categories__label { font-size: 16px; }
  }
  @media (max-width: 400px) {
    .km-categories__meta {
      flex-direction: column;
      align-items: flex-start;
      gap: 8px;
    }
  }
</style>

{% schema %}
{
  "name": "Category Grid",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Browse by Categories" },
    { "type": "text", "id": "view_all_label", "label": "View all label", "default": "View All" },
    { "type": "url", "id": "view_all_url", "label": "View all URL" }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "asset_name", "label": "Asset filename (fallback)" },
        { "type": "text", "id": "label", "label": "Label", "default": "Sportster" },
        { "type": "url", "id": "url", "label": "Link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Category Grid",
      "blocks": [
        { "type": "category", "settings": { "label": "Indian",  "asset_name": "model-sportster-after.png" } },
        { "type": "category", "settings": { "label": "Dyna",    "asset_name": "model-dyna-after.webp"    } },
        { "type": "category", "settings": { "label": "Honda",   "asset_name": "model-honda-after.webp"   } },
        { "type": "category", "settings": { "label": "Triumph", "asset_name": "model-triumph-after.webp" } }
      ]
    }
  ]
}
{% endschema %}
