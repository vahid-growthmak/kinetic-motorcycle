{%- comment -%}
  Contact Hero Section — Breadcrumbs, Title, and Intro text.
{%- endcomment -%}

<section class="km-contact-hero" id="Section-{{ section.id }}">
  <div class="km-container">
    <nav class="km-contact-hero__crumbs" aria-label="Breadcrumb">
      <a href="{{ routes.root_url }}">Home</a>
      <span aria-hidden="true">/</span>
      <a href="{{ routes.collections_url }}">Collections</a>
      <span aria-hidden="true">/</span>
      <span class="km-contact-hero__crumb-current">{{ section.settings.breadcrumb_current | default: page.title }}</span>
    </nav>

    <div class="km-contact-hero__content">
      <h1 class="km-contact-hero__title">{{ section.settings.heading | default: page.title }}</h1>
      {%- if section.settings.subheading != blank -%}
        <p class="km-contact-hero__sub">{{ section.settings.subheading }}</p>
      {%- endif -%}
    </div>
  </div>
</section>

<style>
  .km-contact-hero {
    background: var(--km-body-bg, #EDEDED);
    padding: 48px 0 32px;
  }
  .km-contact-hero__crumbs {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: .04em;
    color: var(--km-text, #4B5563);
    margin-bottom: 32px;
  }
  .km-contact-hero__crumbs a {
    color: var(--km-text, #4B5563);
    text-decoration: none;
    transition: color .2s ease;
  }
  .km-contact-hero__crumbs a:hover {
    color: var(--km-accent, #FBB03D);
  }
  .km-contact-hero__crumb-current {
    color: #000;
    font-weight: 700;
  }

  .km-contact-hero__content {
    max-width: 880px;
  }
  .km-contact-hero__title {
    font-size: clamp(36px, 5vw, 56px);
    font-weight: 700;
    letter-spacing: -.02em;
    color: #000;
    margin: 0 0 20px;
    line-height: 1.1;
  }
  .km-contact-hero__sub {
    font-size: 16px;
    line-height: 1.6;
    color: var(--km-text, #4B5563);
    max-width: 780px;
  }
</style>

{% schema %}
{
  "name": "Contact Hero",
  "settings": [
    {
      "type": "text",
      "id": "breadcrumb_current",
      "label": "Current page breadcrumb",
      "default": "Contact Kinetic Motorcycles"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Contact Kinetic Motorcycles"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Have a question about fitment, an order, or a product? Our team is here to help. Reach out using the option that works best for you, and we'll make sure you get the right support."
    }
  ],
  "presets": [
    {
      "name": "Contact Hero"
    }
  ]
}
{% endschema %}
