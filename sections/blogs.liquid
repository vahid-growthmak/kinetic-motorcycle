{%- comment -%}
  ============================================================
  BLOGS — 3-column blog preview grid, editable posts
  ============================================================
{%- endcomment -%}

<section class="km-section km-blogs" {{ section.shopify_attributes }}>
  <div class="km-container">
    <header class="km-blogs__header">
      {%- if section.settings.heading != blank -%}
        <h2 class="km-section-heading km-blogs__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.view_all_label != blank -%}
        <a href="{{ section.settings.view_all_url | default: '/blogs' }}" class="km-btn-view-all">{{ section.settings.view_all_label }}</a>
      {%- endif -%}
    </header>
    {%- if section.blocks.size > 0 -%}
      <div class="km-blogs__grid">
        {%- for block in section.blocks -%}
          {%- assign post_url = block.settings.url | default: '/blogs' -%}
          <article class="km-blogs__card" {{ block.shopify_attributes }}>
            <a href="{{ post_url }}" class="km-blogs__media">
              {%- if block.settings.image != blank -%}
                <img src="{{ block.settings.image | image_url: width: 800 }}" width="400" height="260" loading="lazy" alt="{{ block.settings.title | escape }}" class="km-blogs__img">
              {%- else -%}
                <img src="{{ 'blog-1.png' | asset_url }}" width="400" height="260" loading="lazy" alt="{{ block.settings.title | escape }}" class="km-blogs__img">
              {%- endif -%}
            </a>
            <div class="km-blogs__body">
              <h3 class="km-blogs__title"><a href="{{ post_url }}">{{ block.settings.title }}</a></h3>
              {%- if block.settings.read_more_label != blank -%}
                <a href="{{ post_url }}" class="km-blogs__readmore">{{ block.settings.read_more_label }} {%- render 'icon', icon: 'arrow-right' -%}</a>
              {%- endif -%}
            </div>
          </article>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</section>

<style>
  .km-blogs { padding: 64px 0; background: #fff; }
  .km-blogs__header { display: flex; align-items: flex-end; justify-content: space-between; gap: 24px; margin-bottom: 40px; flex-wrap: wrap; }
  .km-btn-view-all { font-size: 12px; font-weight: 700; letter-spacing: .12em; text-transform: uppercase; color: #000; text-decoration: none; }
  .km-blogs__grid { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 28px; }
  .km-blogs__card { display: flex; flex-direction: column; gap: 18px; transition: transform .25s ease; }
  .km-blogs__card:hover { transform: translateY(-3px); }
  .km-blogs__media { position: relative; display: block; aspect-ratio: 4 / 3; overflow: hidden; border-radius: 20px; background: var(--km-body-bg, #EDEDED); }
  .km-blogs__img { width: 100%; height: 100%; object-fit: cover; transition: transform .4s ease; }
  .km-blogs__card:hover .km-blogs__img { transform: scale(1.04); }
  .km-blogs__body { padding: 0 4px; display: flex; flex-direction: column; gap: 14px; }
  .km-blogs__title { font-size: 20px; font-weight: 700; line-height: 1.25; letter-spacing: -.01em; color: #000; margin: 0; }
  .km-blogs__title a { color: inherit; text-decoration: none; }
  .km-blogs__title a:hover { color: var(--km-accent, #FBB03D); }
  .km-blogs__readmore { display: inline-flex; align-items: center; gap: 6px; font-size: 13px; font-weight: 500; color: var(--km-text, #4B5563); text-decoration: none; }
  @media (max-width: 900px) {
    .km-blogs__grid { grid-template-columns: 1fr; }
    .km-blogs__header { flex-direction: column; align-items: flex-start; }
  }
</style>

{% schema %}
{
  "name": "Blog posts",
  "tag": "section",
  "class": "shopify-section-blogs",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Our Blogs" },
    { "type": "text", "id": "view_all_label", "label": "View All label", "default": "View All" },
    { "type": "url", "id": "view_all_url", "label": "View All link" }
  ],
  "blocks": [
    {
      "type": "post",
      "name": "Blog post card",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Cover image" },
        { "type": "text", "id": "title", "label": "Title", "default": "Blog title" },
        { "type": "url", "id": "url", "label": "Link" },
        { "type": "text", "id": "read_more_label", "label": "Read more label", "default": "Read Articles" }
      ]
    }
  ],
  "max_blocks": 12,
  "presets": [
    {
      "name": "Blogs",
      "category": "Content",
      "blocks": [
        { "type": "post", "settings": { "title": "The \"Forever Bike\" Philosophy: Customizing for Longevity" } },
        { "type": "post", "settings": { "title": "Unleashing Your Inner Biker: Your One-Stop Shop for Customizing Motorcycles" } },
        { "type": "post", "settings": { "title": "Tips on Motorcycle Customization: A Complete Guide" } }
      ]
    }
  ]
}
{% endschema %}
