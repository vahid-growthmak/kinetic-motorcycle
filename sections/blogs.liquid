{%- comment -%}
  ------------------------------------------------------------
  Blogs — 3-column blog preview grid
  Each card: cover image + category pill + title + excerpt + date + author
  ------------------------------------------------------------
{%- endcomment -%}

<section class="km-section km-blogs" id="Section-{{ section.id }}">
  <div class="km-container">
    <header class="km-blogs__header">
      <div class="km-blogs__titles">
        {%- if section.settings.eyebrow != blank -%}
          <span class="km-eyebrow">{{ section.settings.eyebrow }}</span>
        {%- endif -%}
        <h2 class="km-section-heading">{{ section.settings.heading }}</h2>
      </div>
      {%- if section.settings.view_all_label != blank -%}
        <a href="{{ section.settings.view_all_url | default: '#' }}" class="km-btn km-btn-ghost km-blogs__view-all">
          {{ section.settings.view_all_label }}
          {%- render 'icon', icon: 'arrow-right' -%}
        </a>
      {%- endif -%}
    </header>

    <div class="km-blogs__grid">
      {%- if section.settings.blog != blank and blogs[section.settings.blog].articles.size > 0 -%}
        {%- assign blog = blogs[section.settings.blog] -%}
        {%- for article in blog.articles limit: 3 -%}
          <article class="km-blogs__card">
            <a href="{{ article.url }}" class="km-blogs__media">
              {%- if article.image != blank -%}
                {{ article.image | image_url: width: 1200 | image_tag: 
                   loading: 'lazy', 
                   sizes: '(min-width: 1200px) 450px, (min-width: 768px) 50vw, 100vw',
                   widths: '400, 600, 800, 1200',
                   alt: article.title, class: 'km-blogs__img' }}
              {%- else -%}
                <img src="{{ 'blog-1.png' | asset_url }}" width="800" height="520" loading="lazy" alt="{{ article.title }}" class="km-blogs__img">
              {%- endif -%}
              {%- if article.tags.size > 0 -%}<span class="km-blogs__category">{{ article.tags.first }}</span>{%- endif -%}
            </a>
            <div class="km-blogs__body">
              <h3 class="km-blogs__title"><a href="{{ article.url }}">{{ article.title }}</a></h3>
              <p class="km-blogs__excerpt">{{ article.excerpt_or_content | strip_html | truncatewords: 20 }}</p>
              <div class="km-blogs__meta">
                <span class="km-blogs__read-time">Read Article {%- render 'icon', icon: 'arrow-right' -%}</span>
              </div>
            </div>
          </article>
        {%- endfor -%}
      {%- elsif section.blocks.size > 0 -%}
        {%- for block in section.blocks -%}
          {%- if block.type == 'post' -%}
            <article class="km-blogs__card" {{ block.shopify_attributes }}>
              <a href="{{ block.settings.url | default: '/blogs/news' }}" class="km-blogs__media">
                {%- if block.settings.image != blank -%}
                  {{ block.settings.image | image_url: width: 1200 | image_tag: 
                     loading: 'lazy', 
                     sizes: '(min-width: 1200px) 450px, (min-width: 768px) 50vw, 100vw',
                     widths: '400, 600, 800, 1200',
                     alt: block.settings.title, class: 'km-blogs__img' }}
                {%- elsif block.settings.asset_name != blank -%}
                  <img src="{{ block.settings.asset_name | asset_url }}" width="800" height="520" loading="lazy" alt="{{ block.settings.title }}" class="km-blogs__img">
                {%- endif -%}
                {%- if block.settings.category != blank -%}<span class="km-blogs__category">{{ block.settings.category }}</span>{%- endif -%}
              </a>
              <div class="km-blogs__body">
                <h3 class="km-blogs__title"><a href="{{ block.settings.url | default: '/blogs/news' }}">{{ block.settings.title }}</a></h3>
                {%- if block.settings.excerpt != blank -%}<p class="km-blogs__excerpt">{{ block.settings.excerpt }}</p>{%- endif -%}
                <div class="km-blogs__meta">
                  {%- if block.settings.read_time != blank -%}<span class="km-blogs__read-time">{{ block.settings.read_time }}</span>{%- endif -%}
                </div>
              </div>
            </article>
          {%- endif -%}
        {%- endfor -%}
      {%- else -%}
        {%- assign fallback_posts = 'The Forever Bike Philosophy: Customizing for Longevity|blog-1.png||Unleashing Your Inner Biker: Your One-Stop Shop for Customizing Motorcycles|blog-2.jpeg||Tips on Motorcycle Customization: A Complete Guide|blog-3.jpeg' | split: '||' -%}
        {%- for entry in fallback_posts -%}
          {%- assign p = entry | split: '|' -%}
          <article class="km-blogs__card">
            <a href="#" class="km-blogs__media">
              <img src="{{ p[1] | asset_url }}" width="400" height="260" loading="lazy" alt="{{ p[0] }}" class="km-blogs__img">
            </a>
            <div class="km-blogs__body">
              <h3 class="km-blogs__title"><a href="#">{{ p[0] }}</a></h3>
              <div class="km-blogs__meta"><span class="km-blogs__read-time">Read Articles {%- render 'icon', icon: 'arrow-right' -%}</span></div>
            </div>
          </article>
        {%- endfor -%}
      {%- endif -%}
    </div>
  </div>
</section>

<style>
  .km-blogs { background: var(--km-surface); }
  .km-blogs__header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 24px;
    margin-bottom: 40px;
    flex-wrap: wrap;
  }
  .km-blogs__header .km-eyebrow {
    display: inline-block;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: .16em;
    text-transform: uppercase;
    color: var(--km-accent);
    margin-bottom: 10px;
  }
  .km-blogs__titles { max-width: 720px; }
  .km-blogs__view-all { align-self: flex-end; }

  .km-blogs__grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 28px;
  }

  .km-blogs__card {
    display: flex;
    flex-direction: column;
    gap: 18px;
    border-radius: var(--km-radius-lg);
    overflow: hidden;
    background: transparent;
    transition: transform var(--km-transition, .25s ease);
  }
  .km-blogs__card:hover { transform: translateY(-3px); }

  .km-blogs__media {
    position: relative;
    display: block;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    border-radius: var(--km-radius-lg);
    background: var(--km-body-bg);
  }
  .km-blogs__img {
    width: 100%; height: 100%;
    object-fit: cover;
    object-position: center;
    transition: transform .4s ease;
  }
  .km-blogs__card:hover .km-blogs__img { transform: scale(1.04); }

  .km-blogs__category {
    position: absolute;
    top: 16px; left: 16px;
    padding: 6px 12px;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: .12em;
    text-transform: uppercase;
    background: #fff;
    color: #000;
    border-radius: var(--km-radius-pill);
    box-shadow: 0 2px 8px rgba(0,0,0,.1);
  }

  .km-blogs__body {
    padding: 0 4px;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .km-blogs__title {
    font-size: 20px;
    font-weight: 700;
    line-height: 1.25;
    letter-spacing: -.01em;
    color: var(--km-heading);
    margin: 0;
  }
  .km-blogs__title a { color: inherit; text-decoration: none; }
  .km-blogs__title a:hover { color: var(--km-accent); }

  .km-blogs__excerpt {
    font-size: 14px;
    line-height: 1.6;
    color: var(--km-text);
    margin: 0;
  }

  .km-blogs__meta {
    display: flex;
    align-items: center;
    gap: 6px;
    flex-wrap: wrap;
    font-size: 12px;
    color: var(--km-text);
  }
  .km-blogs__author { font-weight: 700; color: var(--km-heading); }
  .km-blogs__dot { opacity: .5; }

  @media (max-width: 900px) {
    .km-blogs__grid { grid-template-columns: 1fr; }
    .km-blogs__header { flex-direction: column; align-items: flex-start; }
    .km-blogs__view-all { align-self: flex-start; }
  }
</style>

{% schema %}
{
  "name": "Blog posts",
  "settings": [
    { "type": "text", "id": "eyebrow",        "label": "Eyebrow" },
    { "type": "text", "id": "heading",        "label": "Heading",        "default": "Our Blogs" },
    { "type": "blog", "id": "blog",           "label": "Select a blog",  "info": "If selected, automatically shows the 3 most recent articles." },
    { "type": "text", "id": "view_all_label", "label": "View all label", "default": "View All" },
    { "type": "url",  "id": "view_all_url",   "label": "View all URL" }
  ],
  "blocks": [
    {
      "type": "post",
      "name": "Post",
      "settings": [
        { "type": "image_picker", "id": "image",      "label": "Cover image" },
        { "type": "text",         "id": "asset_name", "label": "Asset filename (fallback)", "default": "blog-1.png" },
        { "type": "text",         "id": "category",   "label": "Category pill", "default": "Guides" },
        { "type": "text",         "id": "title",      "label": "Title",      "default": "How to Choose the Right Exhaust for Your Bike" },
        { "type": "textarea",     "id": "excerpt",    "label": "Excerpt",    "default": "From slip-ons to full systems, here's how to pick what actually matches how you ride." },
        { "type": "text",         "id": "author",     "label": "Author",     "default": "Kinetic Team" },
        { "type": "text",         "id": "date",       "label": "Date",       "default": "Mar 12, 2026" },
        { "type": "text",         "id": "read_time",  "label": "Read time",  "default": "6 min read" },
        { "type": "url",          "id": "url",        "label": "Link" }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "Blog posts",
      "blocks": [
        { "type": "post", "settings": { "title": "The \"Forever Bike\" Philosophy: Customizing for Longevity", "category": "",   "asset_name": "blog-1.png",  "excerpt": "", "author": "", "date": "", "read_time": "Read Articles" } },
        { "type": "post", "settings": { "title": "Unleashing Your Inner Biker: Your One-Stop Shop for Customizing Motorcycles", "category": "", "asset_name": "blog-2.jpeg", "excerpt": "", "author": "", "date": "", "read_time": "Read Articles" } },
        { "type": "post", "settings": { "title": "Tips on Motorcycle Customization: A Complete Guide", "category": "",  "asset_name": "blog-3.jpeg", "excerpt": "", "author": "", "date": "", "read_time": "Read Articles" } }
      ]
    }
  ]
}
{% endschema %}
