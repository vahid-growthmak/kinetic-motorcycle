{%- comment -%}
  ============================================================
  ABOUT PAGE SECTION — fully editable (H1, hero split, stats, V/M/I tabs, Why Choose, CTA)
  ============================================================
{%- endcomment -%}

<section class="km-about-page" {{ section.shopify_attributes }}>
  <div class="km-container">

    <header class="km-about-page__header">
      <h1 class="km-about-page__h1">{{ section.settings.heading | default: 'About Kinetic Motorcycles' }}</h1>
    </header>

    {%- comment -%} HERO SPLIT: big image + info card {%- endcomment -%}
    <div class="km-about-page__hero-grid">
      <div class="km-about-page__hero-img">
        {%- if section.settings.hero_image != blank -%}
          <img src="{{ section.settings.hero_image | image_url: width: 1600 }}" alt="{{ section.settings.hero_image.alt | default: 'Kinetic rider on the road' }}" loading="eager" class="km-about-page__img">
        {%- else -%}
          <img src="{{ 'hero-bg.webp' | asset_url }}" alt="Kinetic rider on the road" loading="eager" class="km-about-page__img">
        {%- endif -%}
      </div>

      <aside class="km-about-page__hero-card">
        <div class="km-about-page__card-media">
          {%- if section.settings.card_image != blank -%}
            <img src="{{ section.settings.card_image | image_url: width: 800 }}" alt="{{ section.settings.card_image.alt | default: 'Kinetic custom bike' }}" loading="lazy">
          {%- else -%}
            <img src="{{ 'cta-bike.avif' | asset_url }}" alt="Kinetic custom bike" loading="lazy">
          {%- endif -%}
        </div>
        <h2 class="km-about-page__card-h">{{ section.settings.card_heading | default: 'About Kinetic Motorcycles' }}</h2>
        {%- if section.settings.card_paragraph_1 != blank -%}
          <p>{{ section.settings.card_paragraph_1 }}</p>
        {%- endif -%}
        {%- if section.settings.card_paragraph_2 != blank -%}
          <p>{{ section.settings.card_paragraph_2 }}</p>
        {%- endif -%}
        {%- if section.settings.card_tagline != blank -%}
          <div class="km-about-page__card-tag">{{ section.settings.card_tagline }}</div>
        {%- endif -%}
        {%- if section.settings.card_link_label != blank -%}
          <a href="{{ section.settings.card_link_url | default: '/collections' }}" class="km-about-page__card-link">{{ section.settings.card_link_label }} {%- render 'icon', icon: 'arrow-right' -%}</a>
        {%- endif -%}
        {%- if section.settings.card_meta != blank -%}
          <div class="km-about-page__card-meta">{{ section.settings.card_meta }}</div>
        {%- endif -%}
      </aside>
    </div>

    {%- comment -%} WHITE STATS STRIP {%- endcomment -%}
    <div class="km-about-page__stats-strip">
      <div class="km-about-page__stats-tagline">
        <h3>{{ section.settings.stats_heading | default: 'Stop mix-and-matching. Start building.' }}</h3>
        {%- if section.settings.stats_text != blank -%}
          <p>{{ section.settings.stats_text }}</p>
        {%- endif -%}
      </div>
      <div class="km-about-page__stats-grid">
        {%- for block in section.blocks -%}
          {%- if block.type == 'stat' -%}
            <div class="km-about-page__stat" {{ block.shopify_attributes }}>
              <div class="km-about-page__stat-num">{{ block.settings.number }}</div>
              <div class="km-about-page__stat-label">{{ block.settings.label_main }}{%- if block.settings.label_sub != blank -%}<br><span>{{ block.settings.label_sub }}</span>{%- endif -%}</div>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  </div>

  {%- comment -%} VISION / MISSION / INNOVATION TABS {%- endcomment -%}
  <div class="km-about-page__vmi-wrap">
    <div class="km-container">
      <div class="km-about-page__vmi-tabs" role="tablist" data-km-vmi-tabs>
        {%- assign vmi_index = 0 -%}
        {%- assign default_vmi_index = section.settings.vmi_default_index | default: 2 | plus: 0 -%}
        {%- for block in section.blocks -%}
          {%- if block.type == 'vmi_tab' -%}
            {%- assign is_active = false -%}
            {%- if vmi_index == default_vmi_index -%}{%- assign is_active = true -%}{%- endif -%}
            <button type="button" class="km-about-page__vmi-tab{% if is_active %} is-active{% endif %}" role="tab" aria-selected="{% if is_active %}true{% else %}false{% endif %}" data-vmi="{{ block.id }}" data-vmi-h-src="{{ block.settings.heading | escape }}" data-vmi-p-src="{{ block.settings.body | escape }}" data-vmi-img-src="{% if block.settings.image != blank %}{{ block.settings.image | image_url: width: 1600 }}{% else %}{{ 'cta-bike.avif' | asset_url }}{% endif %}" {{ block.shopify_attributes }}>{{ block.settings.tab_label }}</button>
            {%- assign vmi_index = vmi_index | plus: 1 -%}
          {%- endif -%}
        {%- endfor -%}
      </div>

      {%- comment -%} Render the default (active) tab panel so no-JS users see content {%- endcomment -%}
      {%- assign vmi_index = 0 -%}
      {%- assign active_heading = '' -%}
      {%- assign active_body = '' -%}
      {%- assign active_image_url = '' -%}
      {%- for block in section.blocks -%}
        {%- if block.type == 'vmi_tab' -%}
          {%- if vmi_index == default_vmi_index -%}
            {%- assign active_heading = block.settings.heading -%}
            {%- assign active_body = block.settings.body -%}
            {%- if block.settings.image != blank -%}
              {%- assign active_image_url = block.settings.image | image_url: width: 1600 -%}
            {%- endif -%}
          {%- endif -%}
          {%- assign vmi_index = vmi_index | plus: 1 -%}
        {%- endif -%}
      {%- endfor -%}

      <div class="km-about-page__vmi-panel" data-vmi-panel>
        <div class="km-about-page__vmi-media">
          {%- if active_image_url != '' -%}
            <img src="{{ active_image_url }}" alt="{{ active_heading }}" loading="lazy" data-vmi-img>
          {%- else -%}
            <img src="{{ 'cta-bike.avif' | asset_url }}" alt="Kinetic custom bike on the road" loading="lazy" data-vmi-img>
          {%- endif -%}
        </div>
        <article class="km-about-page__vmi-card">
          <h3 data-vmi-h>{{ active_heading | default: 'Our Innovation' }}</h3>
          <p data-vmi-p>{{ active_body | default: 'We are shaping the future of automotive innovation & leading the way towards a more innovative, rider-first approach to motorcycle parts.' }}</p>
          {%- if section.settings.vmi_link_label != blank -%}
            <a href="{{ section.settings.vmi_link_url | default: '/collections' }}" class="km-about-page__vmi-btn">{{ section.settings.vmi_link_label }} {%- render 'icon', icon: 'arrow-right' -%}</a>
          {%- endif -%}
        </article>
      </div>
    </div>
  </div>

  {%- comment -%} WHY CHOOSE {%- endcomment -%}
  <div class="km-about-page__why">
    <div class="km-container">
      <h2 class="km-about-page__why-h">{{ section.settings.why_heading | default: 'Why Choose Kinetic Motorcycles' }}</h2>
      <div class="km-about-page__why-grid">
        {%- for block in section.blocks -%}
          {%- if block.type == 'why_choose_card' -%}
            <article class="km-about-page__why-card" {{ block.shopify_attributes }}>
              <div class="km-about-page__why-media">
                {%- if block.settings.image != blank -%}
                  <img src="{{ block.settings.image | image_url: width: 600 }}" alt="{{ block.settings.image.alt | default: block.settings.title }}" loading="lazy">
                {%- else -%}
                  <img src="{{ block.settings.fallback_asset | default: 'feature-made-in-usa.webp' | asset_url }}" alt="{{ block.settings.title }}" loading="lazy">
                {%- endif -%}
              </div>
              <h3>{{ block.settings.title }}</h3>
              <p>{{ block.settings.description }}</p>
            </article>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  </div>

  {%- comment -%} CTA SPLIT {%- endcomment -%}
  {%- if section.settings.show_cta -%}
    <div class="km-about-page__cta-wrap">
      <div class="km-container">
        <div class="km-about-page__cta-grid">
          <div class="km-about-page__cta-left">
            <h3>{{ section.settings.cta_left_heading | default: 'Advancing Motorcycle Design' }}</h3>
            {%- if section.settings.cta_left_text != blank -%}
              <p>{{ section.settings.cta_left_text }}</p>
            {%- endif -%}
            {%- if section.settings.cta_left_link_label != blank -%}
              <a href="{{ section.settings.cta_left_link_url | default: '/collections' }}" class="km-about-page__cta-link">{{ section.settings.cta_left_link_label }} {%- render 'icon', icon: 'arrow-right' -%}</a>
            {%- endif -%}
          </div>
          <div class="km-about-page__cta-right">
            <div class="km-about-page__cta-right-bg" aria-hidden="true">
              {%- if section.settings.cta_right_image != blank -%}
                <img src="{{ section.settings.cta_right_image | image_url: width: 1400 }}" alt="" loading="lazy">
              {%- else -%}
                <img src="{{ 'cta-bike.avif' | asset_url }}" alt="" loading="lazy">
              {%- endif -%}
            </div>
            <div class="km-about-page__cta-right-inner">
              {%- if section.settings.cta_right_eyebrow != blank -%}
                <span class="km-about-page__cta-eyebrow">{{ section.settings.cta_right_eyebrow }}</span>
              {%- endif -%}
              <h4>{{ section.settings.cta_right_heading | default: 'Get exclusive offers, new product alerts & expert riding tips' }}</h4>
              <form action="/contact#contact_form" method="post" class="km-about-page__form">
                <input type="hidden" name="form_type" value="customer">
                <input type="hidden" name="utf8" value="✓">
                <input type="hidden" name="contact[tags]" value="newsletter">
                <input type="email" name="contact[email]" placeholder="{{ section.settings.cta_right_placeholder | default: 'Email address' }}" required class="km-about-page__form-input">
                <button type="submit" class="km-about-page__form-btn">{{ section.settings.cta_right_submit | default: 'Submit' }}</button>
              </form>
            </div>
          </div>
        </div>
      </div>
    </div>
  {%- endif -%}

</section>

<style>
  .km-about-page { padding: 56px 0 0; background: var(--km-body-bg, #EDEDED); }

  .km-about-page__header { margin-bottom: 36px; }
  .km-about-page__h1 {
    font-size: clamp(32px, 4.4vw, 52px);
    font-weight: 700;
    letter-spacing: -.02em;
    color: #000;
    margin: 0;
    line-height: 1.1;
  }

  /* HERO SPLIT */
  .km-about-page__hero-grid {
    display: grid;
    grid-template-columns: 1.3fr 1fr;
    gap: 32px;
    margin-bottom: 24px;
  }
  .km-about-page__hero-img {
    aspect-ratio: 4/5;
    border-radius: 18px;
    overflow: hidden;
    background: #000;
  }
  .km-about-page__img { width: 100%; height: 100%; object-fit: cover; }

  .km-about-page__hero-card {
    background: #fff;
    border-radius: 18px;
    padding: 24px;
    display: flex;
    flex-direction: column;
    gap: 14px;
    border: 1px solid var(--km-border, #DDDDDD);
  }
  .km-about-page__card-media {
    aspect-ratio: 16/10;
    border-radius: 12px;
    overflow: hidden;
    background: #f3f4f6;
    margin-bottom: 4px;
  }
  .km-about-page__card-media img { width: 100%; height: 100%; object-fit: cover; }
  .km-about-page__card-h {
    font-size: 15px;
    font-weight: 700;
    color: #000;
    margin: 0;
    letter-spacing: .02em;
  }
  .km-about-page__hero-card p {
    font-size: 13px;
    line-height: 1.6;
    color: var(--km-text, #4B5563);
    margin: 0;
  }
  .km-about-page__card-tag strong { color: #000; font-weight: 700; }
  .km-about-page__card-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 13px;
    font-weight: 700;
    color: #000;
    text-decoration: none;
    margin-top: auto;
  }
  .km-about-page__card-link:hover { color: var(--km-accent, #FBB03D); }
  .km-about-page__card-link svg { width: 12px; height: 12px; }
  .km-about-page__card-meta {
    padding-top: 12px;
    border-top: 1px solid var(--km-border, #DDDDDD);
    font-size: 12px;
    font-weight: 600;
    color: var(--km-text, #4B5563);
  }

  /* STATS STRIP */
  .km-about-page__stats-strip {
    background: #fff;
    padding: 40px 32px;
    border-radius: 18px;
    display: grid;
    grid-template-columns: 1.2fr 2fr;
    gap: 40px;
    align-items: center;
    border: 1px solid var(--km-border, #DDDDDD);
    margin-bottom: 48px;
  }
  .km-about-page__stats-tagline h3 {
    font-size: 16px;
    font-weight: 700;
    color: #000;
    margin: 0 0 8px;
    letter-spacing: -.005em;
  }
  .km-about-page__stats-tagline p {
    font-size: 12px;
    line-height: 1.6;
    color: var(--km-text, #4B5563);
    margin: 0;
  }
  .km-about-page__stats-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    border-left: 1px solid var(--km-border, #DDDDDD);
    padding-left: 40px;
  }
  .km-about-page__stat { display: flex; flex-direction: column; gap: 4px; }
  .km-about-page__stat-num {
    font-size: clamp(28px, 3.4vw, 40px);
    font-weight: 800;
    color: #000;
    line-height: 1;
    letter-spacing: -.02em;
  }
  .km-about-page__stat-label {
    font-size: 14px;
    font-weight: 700;
    color: #000;
    line-height: 1.2;
  }
  .km-about-page__stat-label span {
    display: block;
    font-size: 11px;
    font-weight: 500;
    color: var(--km-text, #4B5563);
    letter-spacing: .02em;
    margin-top: 2px;
  }

  /* VISION / MISSION / INNOVATION */
  .km-about-page__vmi-wrap {
    padding: 40px 0 72px;
    background: var(--km-body-bg, #EDEDED);
  }
  .km-about-page__vmi-tabs {
    display: flex;
    gap: 4px;
    justify-content: center;
    padding: 6px;
    background: #fff;
    border: 1px solid var(--km-border, #DDDDDD);
    border-radius: 9999px;
    max-width: max-content;
    margin: 0 auto 32px;
  }
  .km-about-page__vmi-tab {
    padding: 10px 22px;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: .02em;
    color: var(--km-text, #4B5563);
    background: transparent;
    border: 0;
    border-radius: 9999px;
    cursor: pointer;
    font-family: inherit;
    transition: background .25s ease, color .25s ease;
  }
  .km-about-page__vmi-tab:hover { color: #000; }
  .km-about-page__vmi-tab.is-active {
    background: #000;
    color: #fff;
  }

  .km-about-page__vmi-panel {
    position: relative;
    border-radius: 18px;
    overflow: hidden;
    aspect-ratio: 16/6;
    min-height: 320px;
    background: #000;
  }
  .km-about-page__vmi-media { position: absolute; inset: 0; z-index: 0; }
  .km-about-page__vmi-media img { width: 100%; height: 100%; object-fit: cover; }
  .km-about-page__vmi-card {
    position: absolute;
    right: 32px;
    top: 50%;
    transform: translateY(-50%);
    background: #fff;
    border-radius: 14px;
    padding: 28px;
    width: 340px;
    max-width: 42%;
    z-index: 2;
    box-shadow: 0 10px 30px rgba(0,0,0,.15);
  }
  .km-about-page__vmi-card h3 {
    font-size: 18px;
    font-weight: 700;
    color: #000;
    margin: 0 0 10px;
    letter-spacing: -.005em;
  }
  .km-about-page__vmi-card p {
    font-size: 13px;
    line-height: 1.6;
    color: var(--km-text, #4B5563);
    margin: 0 0 18px;
  }
  .km-about-page__vmi-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 10px 20px;
    background: var(--km-accent, #FBB03D);
    color: #000;
    border-radius: 9999px;
    text-decoration: none;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: .04em;
    transition: background .2s ease;
  }
  .km-about-page__vmi-btn:hover { background: #e69a2b; }
  .km-about-page__vmi-btn svg { width: 12px; height: 12px; }

  /* WHY CHOOSE */
  .km-about-page__why {
    padding: 72px 0;
    background: var(--km-body-bg, #EDEDED);
  }
  .km-about-page__why-h {
    font-size: clamp(28px, 3.4vw, 42px);
    font-weight: 700;
    color: #000;
    margin: 0 0 48px;
    letter-spacing: -.015em;
    line-height: 1.1;
  }
  .km-about-page__why-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
  }
  .km-about-page__why-card { text-align: center; }
  .km-about-page__why-media {
    aspect-ratio: 1/1;
    max-width: 240px;
    margin: 0 auto 20px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .km-about-page__why-media img { width: 100%; height: 100%; object-fit: contain; }
  .km-about-page__why-card h3 {
    font-size: 18px;
    font-weight: 800;
    color: #000;
    margin: 0 0 14px;
    letter-spacing: .06em;
    text-transform: uppercase;
  }
  .km-about-page__why-card p {
    font-size: 14px;
    line-height: 1.7;
    color: var(--km-text, #4B5563);
    margin: 0 auto;
    max-width: 340px;
  }

  /* CTA */
  .km-about-page__cta-wrap { padding: 0 0 96px; background: var(--km-body-bg, #EDEDED); }
  .km-about-page__cta-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    border-radius: 18px;
    overflow: hidden;
  }
  .km-about-page__cta-left {
    background: #fff;
    padding: 48px 40px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 12px;
  }
  .km-about-page__cta-left h3 {
    font-size: clamp(22px, 2.4vw, 28px);
    font-weight: 700;
    color: #000;
    margin: 0;
    letter-spacing: -.015em;
    line-height: 1.2;
  }
  .km-about-page__cta-left p { font-size: 14px; line-height: 1.65; color: var(--km-text, #4B5563); margin: 0; max-width: 440px; }
  .km-about-page__cta-link { display: inline-flex; align-items: center; gap: 8px; font-size: 13px; font-weight: 700; color: #000; text-decoration: none; }
  .km-about-page__cta-link:hover { color: var(--km-accent, #FBB03D); }
  .km-about-page__cta-link svg { width: 12px; height: 12px; }

  .km-about-page__cta-right { position: relative; background: #111; color: #fff; overflow: hidden; isolation: isolate; min-height: 240px; }
  .km-about-page__cta-right-bg { position: absolute; inset: 0; z-index: -1; }
  .km-about-page__cta-right-bg img { width: 100%; height: 100%; object-fit: cover; opacity: .55; }
  .km-about-page__cta-right-bg::after { content: ''; position: absolute; inset: 0; background: linear-gradient(90deg, rgba(0,0,0,.7) 0%, rgba(0,0,0,.3) 100%); }
  .km-about-page__cta-right-inner { padding: 48px 40px; display: flex; flex-direction: column; justify-content: center; gap: 14px; height: 100%; }
  .km-about-page__cta-eyebrow { font-size: 11px; font-weight: 700; letter-spacing: .14em; text-transform: uppercase; color: rgba(255,255,255,.8); }
  .km-about-page__cta-right-inner h4 { font-size: clamp(18px, 2vw, 22px); font-weight: 700; color: #fff; margin: 0 0 8px; line-height: 1.25; max-width: 400px; }
  .km-about-page__form { display: flex; background: #fff; border-radius: 6px; overflow: hidden; max-width: 400px; }
  .km-about-page__form-input { flex: 1; padding: 14px 16px; border: 0; font-size: 14px; color: #111; outline: none; font-family: inherit; }
  .km-about-page__form-btn { flex: 0 0 auto; padding: 14px 24px; background: var(--km-accent, #FBB03D); color: #000; border: 0; font-weight: 800; font-size: 13px; letter-spacing: .04em; cursor: pointer; font-family: inherit; transition: background .2s ease; }
  .km-about-page__form-btn:hover { background: #e69a2b; }

  @media (max-width: 1000px) {
    .km-about-page__hero-grid { grid-template-columns: 1fr; }
    .km-about-page__stats-strip { grid-template-columns: 1fr; }
    .km-about-page__stats-grid { border-left: 0; padding-left: 0; border-top: 1px solid var(--km-border, #DDDDDD); padding-top: 20px; }
    .km-about-page__vmi-panel { aspect-ratio: auto; min-height: 0; display: flex; flex-direction: column; }
    .km-about-page__vmi-media { position: static; aspect-ratio: 16/9; }
    .km-about-page__vmi-card { position: static; transform: none; width: 100%; max-width: none; border-radius: 0; box-shadow: none; }
    .km-about-page__why-grid { grid-template-columns: 1fr; }
    .km-about-page__cta-grid { grid-template-columns: 1fr; }
  }
</style>

<script>
(() => {
  const tabs = document.querySelectorAll('[data-vmi]');
  const h = document.querySelector('[data-vmi-h]');
  const p = document.querySelector('[data-vmi-p]');
  const img = document.querySelector('[data-vmi-img]');
  if (!tabs.length || !h || !p) return;

  tabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      tabs.forEach((t) => {
        t.classList.toggle('is-active', t === tab);
        t.setAttribute('aria-selected', t === tab ? 'true' : 'false');
      });
      const newH = tab.getAttribute('data-vmi-h-src');
      const newP = tab.getAttribute('data-vmi-p-src');
      const newImg = tab.getAttribute('data-vmi-img-src');
      if (newH) h.textContent = newH;
      if (newP) p.textContent = newP;
      if (img && newImg) img.setAttribute('src', newImg);
    });
  });
})();
</script>

{% schema %}
{
  "name": "About page",
  "tag": "section",
  "class": "shopify-section-about-page",
  "settings": [
    { "type": "header", "content": "Page heading" },
    { "type": "text", "id": "heading", "label": "H1 heading", "default": "About Kinetic Motorcycles" },

    { "type": "header", "content": "Hero split" },
