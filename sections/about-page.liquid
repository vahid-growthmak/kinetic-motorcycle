      { "type": "tab", "settings": { "title": "Our Mission", "heading": "Our Mission", "content": "<p>Deliver motorcycle solutions that meet real-world riding needs. By focusing on trust, innovation, and consistent quality, we make sure every product and every interaction adds value to your experience as a rider.</p>" } },
      { "type": "tab", "settings": { "title": "Our Innovation", "heading": "Our Innovation", "content": "<p>We are shaping the future of automotive innovation & leading the way towards a more innovative, rider-first approach to motorcycle parts. Every component is engineered from scratch in-house — no templates, no outsourced shortcuts.</p>" } },
