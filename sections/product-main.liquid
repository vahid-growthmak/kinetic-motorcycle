{%- comment -%}
  ------------------------------------------------------------
  Product Main — Gallery + Info + Form + Badges
  This is a proper section so it appears in the theme editor.
  ------------------------------------------------------------
{%- endcomment -%}

<section class="km-product-page" id="Section-{{ section.id }}">
  <div class="km-container">

    {%- comment -%} BREADCRUMB {%- endcomment -%}
    <nav class="km-pp__crumbs" aria-label="Breadcrumb">
      <a href="{{ routes.root_url }}">Home</a>
      
      {%- assign mf_model = product.metafields.custom.model.value | default: product.metafields.custom.model -%}
      {%- assign mf_category = product.metafields.custom.category.value | default: product.metafields.custom.category -%}

      {%- if mf_model != blank -%}
        <span aria-hidden="true">›</span>
        {%- if mf_model.url -%}
          <a href="{{ mf_model.url }}">{{ mf_model.title }}</a>
        {%- else -%}
          <a href="/collections/{{ mf_model | handleize }}">{{ mf_model }}</a>
        {%- endif -%}

        {%- if mf_category != blank -%}
          <span aria-hidden="true">›</span>
          {%- if mf_category.url -%}
            <a href="{{ mf_category.url }}">{{ mf_category.title }}</a>
          {%- else -%}
            <a href="/collections/{{ mf_model | handleize }}-{{ mf_category | handleize }}">{{ mf_category }}</a>
          {%- endif -%}
        {%- endif -%}
      {%- else -%}
        {%- comment -%} FALLBACK TO COLLECTION LOGIC {%- endcomment -%}
        {%- assign current_collection = collection | default: product.collections.first -%}
        {%- if current_collection -%}
          {%- assign handle_parts = current_collection.handle | split: '-' -%}
          {%- assign model_handle = '' -%}
          {%- if current_collection.handle contains 'harley-davidson' -%}
            {%- assign model_handle = handle_parts[2] -%}
          {%- elsif current_collection.handle contains 'indian' or current_collection.handle contains 'triumph' or current_collection.handle contains 'honda' -%}
            {%- assign model_handle = handle_parts[1] -%}
          {%- else -%}
            {%- assign model_handle = handle_parts | first -%}
          {%- endif -%}
          {%- assign parent_collection = collections[model_handle] -%}
          {%- if parent_collection -%}
            <span aria-hidden="true">›</span>
            <a href="{{ parent_collection.url }}">{{ parent_collection.title | remove: ' Parts' | remove: ' parts' | remove: 'Harley-Davidson ' }}</a>
          {%- elsif model_handle != blank -%}
            <span aria-hidden="true">›</span>
            <a href="/collections/{{ model_handle }}">{{ model_handle | capitalize }}</a>
          {%- endif -%}
          <span aria-hidden="true">›</span>
          <a href="{{ current_collection.url }}">{{ current_collection.title | remove: 'Harley-Davidson ' | remove: 'Harley-Davidson' | remove: 'Sportster ' | remove: 'Sportster' | remove: 'Softail ' | remove: 'Softail' | remove: 'Dyna ' | remove: 'Dyna' | remove: 'Indian ' | remove: 'Indian' | remove: 'Triumph ' | remove: 'Triumph' | remove: 'Honda ' | remove: 'Honda' | strip }}</a>
        {%- else -%}
          <span aria-hidden="true">›</span>
          <a href="{{ routes.all_products_collection_url }}">Products</a>
        {%- endif -%}
      {%- endif -%}
      
      <span aria-hidden="true">›</span>
      <span class="km-pp__crumb-current">{{ product.title | upcase }}</span>
    </nav>

    {%- comment -%} TOP GRID — gallery | info {%- endcomment -%}
    <div class="km-pp__top">

      {%- comment -%} LEFT: gallery {%- endcomment -%}
      <div class="km-pp__gallery">
        <div class="km-pp__hero">
          {%- if product.featured_image != blank -%}
            <img
              src="{{ product.featured_image | image_url: width: 1200 }}"
              alt="{{ product.featured_image.alt | default: product.title | escape }}"
              width="800"
              height="800"
              loading="eager"
              fetchpriority="high"
              class="km-pp__hero-img"
              id="km-product-hero-img"
            >
          {%- else -%}
            <div class="km-pp__hero-placeholder" aria-hidden="true"></div>
          {%- endif -%}
        </div>
        {%- if product.images.size > 1 -%}
          <div class="km-pp__thumbs">
            {%- for img in product.images -%}
              <button type="button" class="km-pp__thumb{% if forloop.first %} is-active{% endif %}" data-km-thumb="{{ img | image_url: width: 1200 }}" aria-label="View image {{ forloop.index }}">
                <img src="{{ img | image_url: width: 240 }}" width="120" height="120" loading="lazy" alt="{{ product.title | escape }}">
              </button>
            {%- endfor -%}
          </div>
        {%- else -%}
          <div class="km-pp__thumbs-empty">No items found</div>
        {%- endif -%}
      </div>

      {%- comment -%} RIGHT: info {%- endcomment -%}
      <div class="km-pp__info">
        <div class="km-pp__rating-row">
          <div class="km-pp__stars" aria-label="5 out of 5 stars">
            {%- for i in (1..5) -%}<span>{%- render 'icon', icon: 'star' -%}</span>{%- endfor -%}
          </div>
          <span class="km-pp__review-count">5.0 · {{ product.metafields.reviews.count | default: 24 }} reviews</span>
        </div>

        <h1 class="km-pp__title">{{ product.title | default: 'Product Title' }}</h1>

        {%- if product.tags.size > 0 -%}
          <div class="km-pp__sub">{{ product.tags | first | upcase }}</div>
        {%- endif -%}

        <div class="km-pp__pricerow">
          <span class="km-pp__price">{{ product.price | money }}</span>
          {%- if product.compare_at_price > product.price -%}
            <span class="km-pp__compare">{{ product.compare_at_price | money }}</span>
          {%- endif -%}
        </div>

        {%- if product.description != blank -%}
          <div class="km-pp__short-desc">{{ product.description | strip_html | truncate: 1000 }}</div>
        {%- else -%}
          <div class="km-pp__short-desc">A precision-machined upgrade engineered for exact factory fitment, durable sealing, and long-term reliability. Designed in-house and manufactured in the United States.</div>
        {%- endif -%}

        <div class="km-pp__meta">
          {%- if product.vendor != blank -%}
            <span class="km-pp__meta-tag">
              <img src="{{ 'icon-motor.png' | asset_url }}" width="14" height="14" alt="" loading="lazy">
              {{ product.vendor }}
            </span>
          {%- endif -%}
          {%- if product.type != blank -%}
            <span class="km-pp__meta-tag">
              {%- render 'icon', icon: 'arrow-up-right' -%}
              {{ product.type }}
            </span>
          {%- endif -%}
        </div>

        <form method="post" action="/cart/add" class="km-pp__form" data-km-product-form enctype="multipart/form-data">
          <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
          <script type="application/json" data-km-variants>{{ product.variants | json }}</script>

          {%- if product.has_only_default_variant == false and product.variants.size > 1 -%}
            {%- for option in product.options_with_values -%}
              <div class="km-pp__option">
                <label class="km-pp__option-label">{{ option.name }}</label>
                <div class="km-pp__option-values">
                  {%- for value in option.values -%}
                    <button type="button" class="km-pp__option-value{% if option.selected_value == value %} is-active{% endif %}" 
                      data-option-index="{{ forloop.parentloop.index0 }}" 
                      data-option-value="{{ value | escape }}">
                      {{ value }}
                    </button>
                  {%- endfor -%}
                </div>
              </div>
            {%- endfor -%}
          {%- endif -%}

          <div class="km-pp__qty-row">
            <div class="km-pp__qty">
              <button type="button" class="km-pp__qty-btn" data-km-qty-dec aria-label="Decrease quantity">−</button>
              <input type="number" name="quantity" value="1" min="1" class="km-pp__qty-input" data-km-qty-input>
              <button type="button" class="km-pp__qty-btn" data-km-qty-inc aria-label="Increase quantity">+</button>
            </div>
            <button type="submit" name="add" class="km-pp__add">
              Add to Cart
              {%- render 'icon', icon: 'arrow-right' -%}
            </button>
          </div>

          {%- if product.selected_or_first_available_variant.available -%}
            <button type="submit" name="checkout" formaction="/checkout" class="km-pp__buy-now">Buy Now</button>
          {%- endif -%}
        </form>

        <div class="km-pp__badges">
          {%- for block in section.blocks -%}
            {%- if block.type == 'badge' -%}
              <div class="km-pp__badge" {{ block.shopify_attributes }}>
                <span class="km-pp__badge-icon" aria-hidden="true">
                  {%- if block.settings.image != blank -%}
                    {{ block.settings.image | image_url: width: 80 | image_tag: width: 36, height: 36, loading: 'lazy' }}
                  {%- else -%}
                    {%- render 'icon', icon: block.settings.icon | default: 'globe' -%}
                  {%- endif -%}
                </span>
                {{ block.settings.label }}
              </div>
            {%- endif -%}
          {%- endfor -%}
          {%- if section.blocks.size == 0 -%}
            <div class="km-pp__badge">
              <span class="km-pp__badge-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" width="18" height="18"><circle cx="12" cy="12" r="10"/><path d="M2 12h20"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
              </span>
              USA Designed &amp; Made
            </div>
            <div class="km-pp__badge">
              <span class="km-pp__badge-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" width="18" height="18"><path d="M14 18V6a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2v11a1 1 0 0 0 1 1h2"/><path d="M15 18H9"/><path d="M19 18h2a1 1 0 0 0 1-1v-3.65a1 1 0 0 0-.22-.624l-3.48-4.35A1 1 0 0 0 17.52 8H14"/><circle cx="17" cy="18" r="2"/><circle cx="7" cy="18" r="2"/></svg>
              </span>
              Worldwide Shipping
            </div>
            <div class="km-pp__badge">
              <span class="km-pp__badge-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" width="18" height="18"><circle cx="12" cy="12" r="3"/><path d="M12 1v6m0 10v6M4.22 4.22l4.24 4.24m7.08 7.08l4.24 4.24M1 12h6m10 0h6M4.22 19.78l4.24-4.24m7.08-7.08l4.24-4.24"/></svg>
              </span>
              High Precision Motorcycle Parts
            </div>
          {%- endif -%}
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .km-pp__badge-icon img { width: 100%; height: 100%; object-fit: contain; }
  .km-product-page { padding: 36px 0 72px; background: var(--km-body-bg, #EDEDED); }
  .km-pp__crumbs { display: flex; flex-flow: wrap; align-items: center; gap: 8px; font-size: 11px; font-weight: 600; letter-spacing: .06em; text-transform: uppercase; color: var(--km-text, #4B5563); margin-bottom: 32px; overflow-wrap: break-word; }
  .km-pp__crumbs a { color: inherit; text-decoration: none; flex-shrink: 0; }
  .km-pp__crumbs a:hover { color: var(--km-accent, #FBB03D); }
  .km-pp__crumb-current { color: #000; font-weight: 700; overflow-wrap: break-word; }

  .km-pp__top { display: grid; grid-template-columns: minmax(0, 1.1fr) minmax(0, 1fr); gap: 48px; align-items: flex-start; }

  .km-pp__gallery { display: flex; flex-direction: column; gap: 14px; position: sticky; top: 24px; }
  .km-pp__hero { aspect-ratio: 1/1; background: #fff; border: 1px solid var(--km-border, #DDDDDD); border-radius: 20px; overflow: hidden; }
  .km-pp__hero-img { width: 100%; height: 100%; object-fit: cover; transition: opacity .2s ease; }
  .km-pp__hero-placeholder { width: 100%; height: 100%; background: linear-gradient(135deg, #f3f4f6, #e5e7eb); }
  .km-pp__thumbs { 
    display: flex; 
    gap: 12px; 
    overflow-x: auto; 
    max-width: 100%;
    padding-bottom: 8px;
    /* Hide scrollbar for Chrome, Safari and Opera */
    -ms-overflow-style: none;  /* IE and Edge */
    scrollbar-width: none;  /* Firefox */
  }
  .km-pp__thumbs::-webkit-scrollbar { display: none; }
  
  .km-pp__thumb { 
    flex: 0 0 80px;
    aspect-ratio: 1/1; 
    background: #fff; 
    border: 1px solid var(--km-border, #DDDDDD); 
    border-radius: 10px; 
    overflow: hidden; 
    cursor: pointer; 
    padding: 0; 
    transition: all .2s ease; 
  }
  .km-pp__thumb img { width: 100%; height: 100%; object-fit: cover; }
  .km-pp__thumb:hover { border-color: #000; transform: translateY(-2px); }
  .km-pp__thumb.is-active { border-color: var(--km-accent, #FBB03D); border-width: 2px; }
  .km-pp__thumbs-empty { font-size: 12px; color: #9ca3af; font-style: italic; text-align: center; padding: 16px 0 0; }

  .km-pp__info { display: flex; flex-direction: column; gap: 16px; padding-top: 8px; }
  .km-pp__rating-row { display: flex; align-items: center; gap: 10px; }
  .km-pp__stars { display: inline-flex; gap: 2px; color: var(--km-accent, #FBB03D); }
  .km-pp__stars svg { width: 14px; height: 14px; }
  .km-pp__review-count { font-size: 12px; font-weight: 700; color: var(--km-text, #4B5563); letter-spacing: .04em; text-transform: uppercase; }

  .km-pp__title { font-size: clamp(28px, 3.4vw, 40px); font-weight: 700; letter-spacing: -.015em; line-height: 1.15; color: #000; margin: 0; text-transform: uppercase; }
  .km-pp__sub { font-size: 12px; font-weight: 700; letter-spacing: .14em; text-transform: uppercase; color: var(--km-text, #4B5563); margin-top: -4px; }

  .km-pp__pricerow { display: flex; align-items: baseline; gap: 12px; padding: 14px 0; border-top: 1px solid var(--km-border, #DDDDDD); border-bottom: 1px solid var(--km-border, #DDDDDD); margin: 6px 0; }
  .km-pp__price { font-size: 26px; font-weight: 800; color: #000; letter-spacing: -.01em; }
  .km-pp__compare { font-size: 16px; color: #9ca3af; text-decoration: line-through; }

  .km-pp__short-desc { font-size: 14px; line-height: 1.65; color: var(--km-text, #4B5563); }

  .km-pp__meta { display: flex; gap: 10px; flex-wrap: wrap; }
  .km-pp__meta-tag { display: inline-flex; align-items: center; gap: 6px; padding: 6px 14px; background: #fff; border: 1px solid var(--km-border, #DDDDDD); border-radius: 9999px; font-size: 12px; font-weight: 600; color: var(--km-text, #4B5563); }
  .km-pp__meta-tag svg { width: 12px; height: 12px; }

  .km-pp__form { display: flex; flex-direction: column; gap: 12px; margin-top: 8px; }
  .km-pp__option-label { display: block; font-size: 12px; font-weight: 700; letter-spacing: .08em; text-transform: uppercase; color: #000; margin-bottom: 8px; }
  .km-pp__option-values { display: flex; gap: 8px; flex-wrap: wrap; }
  .km-pp__option-value { padding: 8px 14px; background: #fff; border: 1px solid var(--km-border, #DDDDDD); border-radius: 9999px; font-size: 12px; font-weight: 600; cursor: pointer; font-family: inherit; }
  .km-pp__option-value.is-active { background: #000; color: #fff; border-color: #000; }

  .km-pp__qty-row { display: grid; grid-template-columns: auto 1fr; gap: 10px; }
  .km-pp__qty { display: inline-flex; align-items: center; border: 1px solid var(--km-border, #DDDDDD); border-radius: 9999px; background: #fff; padding: 4px; }
  .km-pp__qty-btn { width: 36px; height: 36px; border-radius: 50%; border: 0; background: transparent; font-size: 18px; font-weight: 700; color: #000; cursor: pointer; font-family: inherit; transition: background .2s ease; }
  .km-pp__qty-btn:hover { background: var(--km-body-bg, #EDEDED); }
  .km-pp__qty-input { width: 48px; text-align: center; border: 0; background: transparent; font-size: 15px; font-weight: 700; color: #000; font-family: inherit; -moz-appearance: textfield; }
  .km-pp__qty-input::-webkit-outer-spin-button, .km-pp__qty-input::-webkit-inner-spin-button { -webkit-appearance: none; margin: 0; }

  .km-pp__add { display: inline-flex; align-items: center; justify-content: center; gap: 8px; padding: 14px 24px; background: #000; color: #fff; border: 0; border-radius: 9999px; font-weight: 800; font-size: 12px; letter-spacing: .14em; text-transform: uppercase; cursor: pointer; font-family: inherit; transition: background .2s ease; }
  .km-pp__add:hover { background: var(--km-accent, #FBB03D); color: #000; }

  .km-pp__buy-now { width: 100%; padding: 16px 24px; background: var(--km-accent, #FBB03D); color: #000; border: 0; border-radius: 9999px; font-weight: 800; font-size: 13px; letter-spacing: .14em; text-transform: uppercase; cursor: pointer; font-family: inherit; transition: background .2s ease; }
  .km-pp__buy-now:hover { background: #e69a2b; }

  .km-pp__badges { display: grid; grid-template-columns: repeat(3, 1fr); gap: 8px; margin-top: 14px; padding-top: 18px; border-top: 1px solid var(--km-border, #DDDDDD); }
  .km-pp__badge { display: flex; flex-direction: column; align-items: center; text-align: center; gap: 6px; font-size: 10px; font-weight: 700; letter-spacing: .1em; text-transform: uppercase; color: var(--km-text, #4B5563); line-height: 1.3; }
  .km-pp__badge-icon { width: 36px; height: 36px; border-radius: 50%; background: var(--km-body-bg, #EDEDED); display: inline-flex; align-items: center; justify-content: center; color: #000; }

  @media (max-width: 1000px) {
    .km-pp__top { grid-template-columns: minmax(0, 1fr); }
    .km-pp__gallery { position: static; min-width: 0; }
  }
  @media (max-width: 600px) {
    .km-pp__badges { grid-template-columns: 1fr 1fr; }
  }
</style>

<script>
(() => {
  // Thumbnail swap
  const hero = document.getElementById('km-product-hero-img');
  if (hero) {
    document.querySelectorAll('[data-km-thumb]').forEach((t) => {
      t.addEventListener('click', () => {
        const src = t.getAttribute('data-km-thumb');
        if (src) {
          hero.style.opacity = '0.5';
          hero.src = src;
          hero.onload = () => { hero.style.opacity = '1'; };
        }
        document.querySelectorAll('[data-km-thumb]').forEach((x) => x.classList.toggle('is-active', x === t));
      });
    });
  }

  // Quantity stepper
  const qty = document.querySelector('[data-km-qty-input]');
  const dec = document.querySelector('[data-km-qty-dec]');
  const inc = document.querySelector('[data-km-qty-inc]');
  if (qty && dec && inc) {
    dec.addEventListener('click', () => { qty.value = Math.max(1, parseInt(qty.value || '1', 10) - 1); });
    inc.addEventListener('click', () => { qty.value = Math.max(1, parseInt(qty.value || '1', 10) + 1); });
  }
})();
</script>

{% schema %}
{
  "name": "Product Main",
  "blocks": [
    {
      "type": "badge",
      "name": "Trust badge",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Custom icon (image)" },
        { "type": "text", "id": "label", "label": "Label", "default": "USA Designed & Made" },
        { "type": "text", "id": "icon", "label": "Icon name", "default": "globe", "info": "Icon from icon.liquid snippet (e.g. globe, truck, star) - used if no image is uploaded" }
      ]
    }
  ]
}
{% endschema %}
