{%- comment -%}
  Collection — sidebar filter + breadcrumb + 3-col grid (matches Kinetic collection layout).
  Fully editable section with schema settings.
{%- endcomment -%}
<section class="km-coll-page" id="Section-{{ section.id }}">
  <div class="km-container">

    {%- comment -%} Breadcrumb {%- endcomment -%}
    <nav class="km-coll__crumbs" aria-label="Breadcrumb">
      <a href="{{ routes.root_url }}">Home</a>
      <span aria-hidden="true">/</span>
      <a href="{{ routes.collections_url }}">Collections</a>
      <span aria-hidden="true">/</span>
      <span class="km-coll__crumb-current">{{ collection.title }}</span>
    </nav>

    <header class="km-coll__header">
      <h1 class="km-coll__title">{{ collection.title }}</h1>
      {%- if collection.description != blank -%}
        <div class="km-coll__desc">{{ collection.description }}</div>
      {%- endif -%}
      <div class="km-coll__count">
        {%- if collection.products_count > 0 -%}
          {{ collection.products_count }} product{% if collection.products_count != 1 %}s{% endif %}
        {%- else -%}
          Browse the collection
        {%- endif -%}
      </div>
    </header>

    <div class="km-coll__layout">
      {%- comment -%} Sidebar — filters + related collections {%- endcomment -%}


      <div class="km-coll__main">
        <div class="km-coll__toolbar">
          <div class="km-coll__sort-label">Sort by</div>
          <form method="get" class="km-coll__sort">
            <select name="sort_by" onchange="this.form.submit()">
              <option value="manual">Featured</option>
              <option value="best-selling">Best selling</option>
              <option value="title-ascending">Alphabetical, A–Z</option>
              <option value="price-ascending">Price, low to high</option>
              <option value="price-descending">Price, high to low</option>
              <option value="created-descending">Newest first</option>
            </select>
          </form>
        </div>

        {%- paginate collection.products by section.settings.products_per_page -%}
          {%- if collection.products.size > 0 -%}
            <div class="km-coll__grid">
              {%- for product in collection.products -%}
                <a href="{{ product.url }}" class="km-coll__card">
                  <div class="km-coll__media">
                    {%- if product.featured_image != blank -%}
                      {{ product.featured_image | image_url: width: 600 | image_tag:
                         width: 300, height: 300, loading: 'lazy',
                         alt: product.title, class: 'km-coll__img' }}
                    {%- endif -%}
                    {%- if product.compare_at_price > product.price -%}
                      <span class="km-coll__sale">Sale</span>
                    {%- endif -%}
                  </div>
                  <div class="km-coll__info">
                    <h3 class="km-coll__name">{{ product.title }}</h3>
                    {%- if product.vendor != blank -%}
                      <div class="km-coll__vendor">
                        <img src="{{ 'icon-motor.png' | asset_url }}" width="14" height="14" alt="" loading="lazy">
                        <span>{{ product.vendor }}</span>
                      </div>
                    {%- endif -%}
                    <div class="km-coll__pricerow">
                      <span class="km-coll__price">{{ product.price | money }}</span>
                      {%- if product.compare_at_price > product.price -%}
                        <span class="km-coll__compare">{{ product.compare_at_price | money }}</span>
                      {%- endif -%}
                    </div>
                    <div class="km-coll__rating" aria-hidden="true">
                      {%- for i in (1..5) -%}<span class="{% if i > 4 %}is-off{% endif %}">{%- render 'icon', icon: 'star' -%}</span>{%- endfor -%}
                    </div>
                  </div>
                </a>
              {%- endfor -%}
            </div>

            {%- if paginate.pages > 1 -%}
              <nav class="km-pagination">{{ paginate | default_pagination }}</nav>
            {%- endif -%}
          {%- else -%}
            <div class="km-coll__empty">
              <p>{{ section.settings.empty_message | default: 'No products in this collection yet.' }}</p>
              <a href="{{ routes.all_products_collection_url }}" class="km-btn km-btn-primary">Browse all products {%- render 'icon', icon: 'arrow-right' -%}</a>
            </div>
          {%- endif -%}
        {%- endpaginate -%}
      </div>
    </div>
  </div>
</section>

<style>
  .km-coll-page { padding: 48px 0 80px; background: var(--km-body-bg, #EDEDED); }
  .km-coll__crumbs { display: flex; align-items: center; gap: 8px; font-size: 12px; font-weight: 600; letter-spacing: .04em; color: var(--km-text, #4B5563); margin-bottom: 28px; }
  .km-coll__crumbs a { color: var(--km-text, #4B5563); text-decoration: none; transition: color .2s ease; }
  .km-coll__crumbs a:hover { color: var(--km-accent, #FBB03D); }
  .km-coll__crumb-current { color: #000; font-weight: 700; }

  .km-coll__header { max-width: 880px; margin-bottom: 40px; }
  .km-coll__title { font-size: clamp(32px, 4.4vw, 52px); font-weight: 700; letter-spacing: -.02em; color: #000; margin: 0 0 14px; }
  .km-coll__desc { font-size: 15px; line-height: 1.7; color: var(--km-text, #4B5563); margin-bottom: 12px; }
  .km-coll__count { font-size: 13px; font-weight: 700; letter-spacing: .06em; text-transform: uppercase; color: var(--km-accent, #FBB03D); }

  .km-coll__layout { display: block; }

  .km-coll__toolbar { display: flex; align-items: center; justify-content: flex-end; gap: 12px; margin-bottom: 20px; padding: 12px 16px; background: #fff; border: 1px solid var(--km-border, #DDDDDD); border-radius: 12px; }
  @media (max-width: 1000px) {
    .km-coll__toolbar { justify-content: space-between; }
  }
  .km-coll__sort-label { font-size: 12px; font-weight: 700; letter-spacing: .08em; text-transform: uppercase; color: var(--km-text, #4B5563); }
  .km-coll__sort select { padding: 6px 10px; border: 1px solid var(--km-border, #DDDDDD); border-radius: 6px; background: #fff; font-size: 13px; font-weight: 500; font-family: inherit; cursor: pointer; }

  .km-coll__grid { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 20px; }
  .km-coll__card { background: #fff; border: 1px solid var(--km-border, #DDDDDD); border-radius: 16px; overflow: hidden; text-decoration: none; color: inherit; display: flex; flex-direction: column; transition: transform .25s ease, box-shadow .25s ease; }
  .km-coll__card:hover { transform: translateY(-3px); box-shadow: 0 8px 22px rgba(0,0,0,.06); }
  .km-coll__media { aspect-ratio: 1 / 1; overflow: hidden; background: #f9fafb; position: relative; }
  .km-coll__img { width: 100%; height: 100%; object-fit: cover; transition: transform .4s ease; }
  .km-coll__card:hover .km-coll__img { transform: scale(1.04); }
  .km-coll__sale { position: absolute; top: 12px; left: 12px; padding: 4px 10px; font-size: 10px; font-weight: 700; letter-spacing: .12em; text-transform: uppercase; background: #FFDEDE; color: #b91c1c; border-radius: 9999px; }
  .km-coll__info { padding: 16px 18px 20px; display: flex; flex-direction: column; gap: 6px; flex: 1; }
  .km-coll__name { font-size: 14px; font-weight: 600; line-height: 1.4; color: #000; margin: 0; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
  .km-coll__vendor { display: inline-flex; align-items: center; gap: 6px; font-size: 12px; font-weight: 600; color: var(--km-text, #4B5563); }
  .km-coll__pricerow { display: flex; align-items: baseline; gap: 8px; margin-top: auto; }
  .km-coll__price { font-size: 15px; font-weight: 700; color: #000; }
  .km-coll__compare { font-size: 12px; color: #9ca3af; text-decoration: line-through; }
  .km-coll__rating { display: inline-flex; gap: 1px; color: var(--km-accent, #FBB03D); }
  .km-coll__rating svg { width: 12px; height: 12px; }
  .km-coll__rating .is-off { color: #d1d5db; }

  .km-coll__empty { padding: 80px 20px; text-align: center; background: #fff; border-radius: 16px; }

  @media (max-width: 1000px) { .km-coll__grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 640px)  { .km-coll__grid { grid-template-columns: 1fr; } }
</style>

{% schema %}
{
  "name": "Collection Page",
  "settings": [

    { "type": "header", "content": "Grid" },
    { "type": "range", "id": "products_per_page", "label": "Products per page", "min": 6, "max": 24, "step": 3, "default": 12 },
    { "type": "text", "id": "empty_message", "label": "Empty collection message", "default": "No products in this collection yet." }
  ]
}
{% endschema %}
