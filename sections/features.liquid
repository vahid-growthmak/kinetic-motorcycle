{%- comment -%}
  ============================================================
  FEATURES ("Why Choose") — illustration + title + description cards
  ============================================================
{%- endcomment -%}

<section class="km-section km-features" {{ section.shopify_attributes }}>
  <div class="km-container">
    {%- if section.settings.heading != blank -%}
      <header class="km-features__header">
        <h2 class="km-features__heading">{{ section.settings.heading }}</h2>
      </header>
    {%- endif -%}
    {%- if section.blocks.size > 0 -%}
      <div class="km-features__grid">
        {%- for block in section.blocks -%}
          <div class="km-features__card" {{ block.shopify_attributes }}>
            <div class="km-features__media">
              {%- if block.settings.image != blank -%}
                <img src="{{ block.settings.image | image_url: width: 480 }}" width="240" height="240" loading="lazy" alt="{{ block.settings.image.alt | default: block.settings.title | escape }}" class="km-features__img">
              {%- else -%}
                <img src="{{ 'feature-made-in-usa.webp' | asset_url }}" width="240" height="240" loading="lazy" alt="{{ block.settings.title | escape }}" class="km-features__img">
              {%- endif -%}
            </div>
            <h3 class="km-features__title">{{ block.settings.title }}</h3>
            {%- if block.settings.description != blank -%}
              <p class="km-features__desc">{{ block.settings.description }}</p>
            {%- endif -%}
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</section>

<style>
  .km-features { padding: 80px 0; background: var(--km-body-bg, #EDEDED); }
  .km-features__header { text-align: left; margin: 0 0 48px; }
  .km-features__heading {
    font-size: clamp(32px, 4vw, 48px); font-weight: 700; letter-spacing: -.015em;
    color: var(--km-heading, #000); margin: 0; line-height: 1.1;
  }
  .km-features__grid { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 32px; }
  .km-features__card { padding: 24px 16px; text-align: center; transition: transform .25s ease; }
  .km-features__card:hover { transform: translateY(-2px); }
  .km-features__media {
    width: 100%; max-width: 240px; aspect-ratio: 1 / 1; margin: 0 auto 20px;
    display: flex; align-items: center; justify-content: center;
  }
  .km-features__img { width: 100%; height: 100%; object-fit: contain; }
  .km-features__title {
    font-size: 18px; font-weight: 700; letter-spacing: .06em; text-transform: uppercase;
    color: #000; margin: 0 0 14px;
  }
  .km-features__desc {
    color: var(--km-text, #4B5563); line-height: 1.65; font-size: 15px;
    max-width: 340px; margin: 0 auto;
  }
  @media (max-width: 900px) { .km-features__grid { grid-template-columns: 1fr; } }
</style>

{% schema %}
{
  "name": "Features (Why Choose)",
  "tag": "section",
  "class": "shopify-section-features",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Why Choose Kinetic Motorcycles" }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Illustration" },
        { "type": "text", "id": "title", "label": "Title", "default": "Made in USA" },
        { "type": "textarea", "id": "description", "label": "Description", "default": "Describe this feature." }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "Features",
      "category": "Promotional",
      "blocks": [
        { "type": "feature", "settings": { "title": "Made in USA", "description": "Every product is designed and manufactured in the USA, ensuring top-notch quality and supporting local craftsmanship. When you choose us, you’re choosing reliability and homegrown excellence." } },
        { "type": "feature", "settings": { "title": "Established in 2014", "description": "For over 11 years, we’ve been delivering unmatched quality and expertise. Our track record reflects a deep commitment to customer satisfaction and industry-leading solutions." } },
        { "type": "feature", "settings": { "title": "Free Shipping", "description": "Enjoy the convenience of free delivery anywhere in the US. We prioritize your satisfaction by making your shopping experience seamless and hassle-free." } }
      ]
    }
  ]
}
{% endschema %}
