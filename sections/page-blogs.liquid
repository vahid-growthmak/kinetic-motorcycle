{%- comment -%}
  ============================================================
  BLOG INDEX PAGE SECTION — hero + featured post, categories, grid, newsletter.
  ============================================================
{%- endcomment -%}

<section class="km-blog-page" {{ section.shopify_attributes }}>
  {%- comment -%} HERO + featured post {%- endcomment -%}
  <div class="km-container km-blog-page__hero">
    <div class="km-blog-page__hero-copy">
      {%- if section.settings.eyebrow != blank -%}
        <span class="km-blog-page__eyebrow">{{ section.settings.eyebrow }}</span>
      {%- endif -%}
      <h1 class="km-blog-page__h1">{{ section.settings.heading | default: 'Motorcycle Blogs' }}</h1>
      {%- if section.settings.lede != blank -%}
        <p class="km-blog-page__lede">{{ section.settings.lede }}</p>
      {%- endif -%}
    </div>
    <article class="km-blog-page__featured">
      <a href="{{ section.settings.featured_url | default: '/blogs' }}" class="km-blog-page__featured-media">
        {%- if section.settings.featured_image != blank -%}
          <img src="{{ section.settings.featured_image | image_url: width: 1200 }}" loading="eager" width="800" height="500" alt="{{ section.settings.featured_image.alt | default: section.settings.featured_title }}" class="km-blog-page__featured-img">
        {%- else -%}
          <img src="{{ 'blog-1.png' | asset_url }}" loading="eager" width="800" height="500" alt="{{ section.settings.featured_title | default: 'Featured article' }}" class="km-blog-page__featured-img">
        {%- endif -%}
        {%- if section.settings.featured_badge != blank -%}
          <span class="km-blog-page__featured-badge">{{ section.settings.featured_badge }}</span>
        {%- endif -%}
      </a>
      <div class="km-blog-page__featured-body">
        {%- if section.settings.featured_meta != blank -%}
          <div class="km-blog-page__meta">{{ section.settings.featured_meta }}</div>
        {%- endif -%}
        <h2 class="km-blog-page__featured-title"><a href="{{ section.settings.featured_url | default: '/blogs' }}">{{ section.settings.featured_title | default: 'Featured article title' }}</a></h2>
        {%- if section.settings.featured_excerpt != blank -%}
          <p class="km-blog-page__featured-excerpt">{{ section.settings.featured_excerpt }}</p>
        {%- endif -%}
        <a href="{{ section.settings.featured_url | default: '/blogs' }}" class="km-blog-page__featured-more">{{ section.settings.featured_more_label | default: 'Read the full article' }} {%- render 'icon', icon: 'arrow-right' -%}</a>
      </div>
    </article>
  </div>

  {%- comment -%} CATEGORIES (CSV of "Label|URL" pairs; falls back to label-only with /blogs) {%- endcomment -%}
  {%- assign categories_raw = section.settings.categories_csv | default: 'All,Guides,Build Stories,Tech,Maintenance,Industry' -%}
  {%- assign categories_list = categories_raw | split: ',' -%}
  {%- assign active_cat_index = section.settings.categories_active_index | default: 0 | plus: 0 -%}
  <div class="km-container km-blog-page__cats">
    {%- for cat in categories_list -%}
      {%- assign parts = cat | split: '|' -%}
      {%- assign label = parts[0] | strip -%}
      {%- assign url = parts[1] | default: '/blogs' | strip -%}
      <a href="{{ url }}"{% if forloop.index0 == active_cat_index %} class="is-active"{% endif %}>{{ label }}</a>
    {%- endfor -%}
  </div>

  {%- comment -%} GRID {%- endcomment -%}
  <div class="km-container km-blog-page__grid">
    {%- for block in section.blocks -%}
      {%- if block.type == 'post' -%}
        <article class="km-blog-page__card" {{ block.shopify_attributes }}>
          <a href="{{ block.settings.url | default: '/blogs' }}" class="km-blog-page__card-media">
            {%- if block.settings.image != blank -%}
              <img src="{{ block.settings.image | image_url: width: 800 }}" width="400" height="260" loading="lazy" alt="{{ block.settings.image.alt | default: block.settings.title }}" class="km-blog-page__card-img">
            {%- else -%}
              <img src="{{ 'blog-1.png' | asset_url }}" width="400" height="260" loading="lazy" alt="{{ block.settings.title }}" class="km-blog-page__card-img">
            {%- endif -%}
            {%- if block.settings.category != blank -%}
              <span class="km-blog-page__card-cat">{{ block.settings.category }}</span>
            {%- endif -%}
          </a>
          <div class="km-blog-page__card-body">
            <div class="km-blog-page__meta">{{ block.settings.date }}{%- if block.settings.read_time != blank -%} &middot; {{ block.settings.read_time }}{%- endif -%}</div>
            <h3 class="km-blog-page__card-title"><a href="{{ block.settings.url | default: '/blogs' }}">{{ block.settings.title }}</a></h3>
            {%- if block.settings.excerpt != blank -%}
              <p class="km-blog-page__card-excerpt" hidden>{{ block.settings.excerpt }}</p>
            {%- endif -%}
            <a href="{{ block.settings.url | default: '/blogs' }}" class="km-blog-page__card-more">{{ block.settings.more_label | default: 'Read more' }} {%- render 'icon', icon: 'arrow-right' -%}</a>
          </div>
        </article>
      {%- endif -%}
    {%- endfor -%}
  </div>

  {%- comment -%} NEWSLETTER STRIP {%- endcomment -%}
  {%- if section.settings.show_newsletter -%}
    <div class="km-container">
      <div class="km-blog-page__newsletter">
        <div>
          <h2>{{ section.settings.newsletter_heading | default: 'Get new posts in your inbox' }}</h2>
          {%- if section.settings.newsletter_text != blank -%}
            <p>{{ section.settings.newsletter_text }}</p>
          {%- endif -%}
        </div>
        <form action="/contact#contact_form" method="post" class="km-blog-page__form">
          <input type="hidden" name="form_type" value="customer">
          <input type="hidden" name="utf8" value="✓">
          <input type="hidden" name="contact[tags]" value="blog-newsletter">
          <input type="email" name="contact[email]" required placeholder="{{ section.settings.newsletter_placeholder | default: 'Your email address' }}" class="km-blog-page__form-input">
          <button type="submit" class="km-blog-page__form-btn">{{ section.settings.newsletter_submit | default: 'Subscribe' }}</button>
        </form>
      </div>
    </div>
  {%- endif -%}
</section>

<style>
  .km-blog-page { padding: 56px 0 96px; background: var(--km-body-bg, #EDEDED); }
  .km-blog-page__hero { display: grid; grid-template-columns: 1fr 1.2fr; gap: 56px; align-items: center; margin-bottom: 48px; }
  .km-blog-page__eyebrow { display: inline-block; font-size: 12px; font-weight: 800; letter-spacing: .16em; text-transform: uppercase; color: var(--km-accent, #FBB03D); margin-bottom: 14px; }
  .km-blog-page__h1 { font-size: clamp(40px, 5.4vw, 64px); font-weight: 700; letter-spacing: -.02em; color: #000; margin: 0 0 18px; line-height: 1.05; }
  .km-blog-page__lede { font-size: 16px; line-height: 1.7; color: var(--km-text, #4B5563); margin: 0; }

  .km-blog-page__featured { background: #fff; border: 1px solid var(--km-border, #DDDDDD); border-radius: 24px; overflow: hidden; display: flex; flex-direction: column; }
  .km-blog-page__featured-media { position: relative; display: block; aspect-ratio: 16/10; overflow: hidden; }
  .km-blog-page__featured-img { width: 100%; height: 100%; object-fit: cover; transition: transform .5s ease; }
  .km-blog-page__featured-media:hover .km-blog-page__featured-img { transform: scale(1.04); }
  .km-blog-page__featured-badge { position: absolute; top: 16px; left: 16px; padding: 6px 14px; font-size: 11px; font-weight: 800; letter-spacing: .12em; text-transform: uppercase; background: var(--km-accent, #FBB03D); color: #000; border-radius: 9999px; }
  .km-blog-page__featured-body { padding: 32px; }
  .km-blog-page__meta { font-size: 12px; font-weight: 700; letter-spacing: .1em; text-transform: uppercase; color: var(--km-text, #4B5563); margin-bottom: 12px; }
  .km-blog-page__featured-title { font-size: 28px; font-weight: 700; line-height: 1.2; letter-spacing: -.01em; color: #000; margin: 0 0 12px; }
  .km-blog-page__featured-title a { color: inherit; text-decoration: none; }
  .km-blog-page__featured-title a:hover { color: var(--km-accent, #FBB03D); }
  .km-blog-page__featured-excerpt { font-size: 15px; line-height: 1.6; color: var(--km-text, #4B5563); margin: 0 0 20px; }
  .km-blog-page__featured-more { display: inline-flex; align-items: center; gap: 8px; font-size: 13px; font-weight: 700; letter-spacing: .06em; text-transform: uppercase; color: #000; text-decoration: none; }

  .km-blog-page__cats { display: flex; gap: 8px; flex-wrap: wrap; justify-content: center; margin-bottom: 40px; }
  .km-blog-page__cats a { padding: 10px 22px; font-size: 12px; font-weight: 700; letter-spacing: .08em; text-transform: uppercase; color: var(--km-text, #4B5563); background: #fff; border: 1px solid var(--km-border, #DDDDDD); border-radius: 9999px; text-decoration: none; transition: background .2s ease, color .2s ease; }
  .km-blog-page__cats a:hover { border-color: #000; color: #000; }
  .km-blog-page__cats a.is-active { background: #000; color: #fff; border-color: #000; }

  .km-blog-page__grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 28px; margin-bottom: 64px; }
  .km-blog-page__card { display: flex; flex-direction: column; gap: 16px; }
  .km-blog-page__card-media { position: relative; display: block; aspect-ratio: 4/3; overflow: hidden; border-radius: 20px; background: #fff; }
  .km-blog-page__card-img { width: 100%; height: 100%; object-fit: cover; transition: transform .4s ease; }
  .km-blog-page__card:hover .km-blog-page__card-img { transform: scale(1.04); }
  .km-blog-page__card-cat { position: absolute; top: 14px; left: 14px; padding: 5px 12px; font-size: 10px; font-weight: 800; letter-spacing: .14em; text-transform: uppercase; background: #fff; color: #000; border-radius: 9999px; }
  .km-blog-page__card-body { padding: 0 4px; }
  .km-blog-page__card-body .km-blog-page__meta { margin-bottom: 8px; }
  .km-blog-page__card-title { font-size: 19px; font-weight: 700; line-height: 1.3; color: #000; margin: 0 0 14px; letter-spacing: -.005em; }
  .km-blog-page__card-title a { color: inherit; text-decoration: none; }
  .km-blog-page__card-title a:hover { color: var(--km-accent, #FBB03D); }
  .km-blog-page__card-more { display: inline-flex; align-items: center; gap: 6px; font-size: 12px; font-weight: 700; letter-spacing: .08em; text-transform: uppercase; color: #000; text-decoration: none; }

  .km-blog-page__newsletter { background: #000; color: #fff; border-radius: 24px; padding: 48px; display: grid; grid-template-columns: 1.1fr 1fr; gap: 40px; align-items: center; position: relative; overflow: hidden; isolation: isolate; }
  .km-blog-page__newsletter::before { content: ''; position: absolute; inset: 0; z-index: -1; background: radial-gradient(60% 80% at 85% 50%, rgba(251,176,61,.15), transparent 60%); }
  .km-blog-page__newsletter h2 { font-size: 26px; font-weight: 700; color: #fff; margin: 0 0 10px; letter-spacing: -.01em; }
  .km-blog-page__newsletter p { font-size: 14px; color: rgba(255,255,255,.8); line-height: 1.6; margin: 0; }
  .km-blog-page__form { display: flex; background: #fff; border-radius: 8px; overflow: hidden; }
  .km-blog-page__form-input { flex: 1; padding: 14px 18px; border: 0; background: transparent; font-size: 14px; outline: none; color: #111; font-family: inherit; }
  .km-blog-page__form-btn { flex: 0 0 auto; padding: 14px 28px; background: var(--km-accent, #FBB03D); color: #000; border: 0; font-weight: 800; font-size: 13px; letter-spacing: .08em; text-transform: uppercase; cursor: pointer; font-family: inherit; transition: background .2s ease; }
  .km-blog-page__form-btn:hover { background: #e69a2b; }

  @media (max-width: 900px) {
    .km-blog-page__hero { grid-template-columns: 1fr; gap: 32px; }
    .km-blog-page__grid { grid-template-columns: 1fr; }
    .km-blog-page__newsletter { grid-template-columns: 1fr; padding: 32px; }
  }
</style>

{% schema %}
{
  "name": "Blog index page",
  "tag": "section",
  "class": "shopify-section-blog-page",
  "settings": [
    { "type": "header", "content": "Hero" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "From the garage" },
    { "type": "text", "id": "heading", "label": "H1 heading", "default": "Motorcycle Blogs" },
    { "type": "textarea", "id": "lede", "label": "Lede / intro text", "default": "Technical insights, build perspectives, practical guides, and industry news — written to help you ride better, build smarter, and get more from your machine." },

    { "type": "header", "content": "Featured post" },
    { "type": "image_picker", "id": "featured_image", "label": "Featured image" },
    { "type": "text", "id": "featured_badge", "label": "Featured badge text", "default": "Featured" },
    { "type": "text", "id": "featured_meta", "label": "Meta line (date · read time)", "default": "Feb 27, 2026 · 8 min read" },
    { "type": "text", "id": "featured_title", "label": "Featured title", "default": "The \"Forever Bike\" Philosophy: Customizing for Longevity" },
    { "type": "textarea", "id": "featured_excerpt", "label": "Featured excerpt", "default": "The growing movement of riders who plan every upgrade around durability, serviceability, and the bike they want to still be riding 15 years from now." },
    { "type": "url", "id": "featured_url", "label": "Featured URL" },
    { "type": "text", "id": "featured_more_label", "label": "Featured CTA label", "default": "Read the full article" },

    { "type": "header", "content": "Categories" },
    { "type": "paragraph", "content": "Comma-separated list of category pills. Use 'Label|URL' for each item to set a link, or just 'Label' to default to /blogs." },
    { "type": "textarea", "id": "categories_csv", "label": "Category pills (CSV)", "default": "All|/blogs,Guides|/blogs/tagged/guides,Build Stories|/blogs/tagged/build-stories,Tech|/blogs/tagged/tech,Maintenance|/blogs/tagged/maintenance,Industry|/blogs/tagged/industry" },
    { "type": "range", "id": "categories_active_index", "label": "Active category index (0-based)", "min": 0, "max": 10, "step": 1, "default": 0 },

    { "type": "header", "content": "Newsletter strip" },
    { "type": "checkbox", "id": "show_newsletter", "label": "Show newsletter strip", "default": true },
    { "type": "text", "id": "newsletter_heading", "label": "Heading", "default": "Get new posts in your inbox" },
    { "type": "textarea", "id": "newsletter_text", "label": "Text", "default": "One email per month. Tech breakdowns, build journals, and occasional shop discounts. Unsubscribe any time." },
    { "type": "text", "id": "newsletter_placeholder", "label": "Email placeholder", "default": "Your email address" },
    { "type": "text", "id": "newsletter_submit", "label": "Submit button label", "default": "Subscribe" }
  ],
  "blocks": [
    {
      "type": "post",
      "name": "Post card",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Post image" },
        { "type": "text", "id": "category", "label": "Category pill", "default": "Guides" },
        { "type": "text", "id": "date", "label": "Date", "default": "Dec 1 2024" },
        { "type": "text", "id": "read_time", "label": "Read time", "default": "6 min read" },
        { "type": "text", "id": "title", "label": "Title", "default": "Post title" },
        { "type": "textarea", "id": "excerpt", "label": "Excerpt (optional, hidden in DOM)", "default": "" },
        { "type": "url", "id": "url", "label": "URL" },
        { "type": "text", "id": "more_label", "label": "'Read more' label", "default": "Read more" }
      ]
    }
  ],
  "max_blocks": 24,
  "presets": [
    {
      "name": "Blog index page",
      "category": "Pages",
      "blocks": [
        { "type": "post", "settings": { "title": "Unleashing Your Inner Biker: Your One-Stop Shop for Customizing Motorcycles", "category": "Guides", "date": "Dec 1 2024", "read_time": "6 min read" } },
        { "type": "post", "settings": { "title": "Tips on Motorcycle Customization: A Complete Guide", "category": "Guides", "date": "Dec 8 2024", "read_time": "6 min read" } },
        { "type": "post", "settings": { "title": "Revving Up Your Ride: A Comprehensive Guide to Motorcycle Exhausts", "category": "Tech", "date": "Nov 18 2024", "read_time": "6 min read" } },
        { "type": "post", "settings": { "title": "Essential Skills to Build a Custom Motorcycle: From Rusty Frame to Dream Ride", "category": "Build Stories", "date": "Oct 5 2024", "read_time": "6 min read" } },
        { "type": "post", "settings": { "title": "Is Building a Custom Motorcycle Worth It? A Complete Breakdown", "category": "Build Stories", "date": "Sep 22 2024", "read_time": "6 min read" } },
        { "type": "post", "settings": { "title": "Handlebar Geometry 101: How Rise, Pullback & Width Change Your Ride", "category": "Tech", "date": "Aug 17 2024", "read_time": "6 min read" } }
      ]
    }
  ]
}
{% endschema %}
