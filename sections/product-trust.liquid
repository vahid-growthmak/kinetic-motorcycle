{%- comment -%}
  Trust Strip — 3 cards: Designed & Built in USA, Decade of Experience, Designed by Riders
{%- endcomment -%}

<section class="km-pp-trust" id="Section-{{ section.id }}">
  <div class="km-container km-pp-trust__grid">
    {%- if section.blocks.size > 0 -%}
      {%- for block in section.blocks -%}
        <div class="km-pp-trust__card" {{ block.shopify_attributes }}>
          <span class="km-pp-trust__icon" aria-hidden="true">
            {%- if block.settings.image != blank -%}
              {{ block.settings.image | image_url: width: 120 | image_tag: width: 56, height: 56, loading: 'lazy' }}
            {%- else -%}
              {%- render 'icon', icon: block.settings.icon | default: 'star' -%}
            {%- endif -%}
          </span>
          <h3>{{ block.settings.heading }}</h3>
          <p>{{ block.settings.text }}</p>
        </div>
      {%- endfor -%}
    {%- else -%}
      <div class="km-pp-trust__card">
        <span class="km-pp-trust__icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" width="22" height="22"><path d="M2 3h6l2 5H4z"/><path d="M14 3h8l-2 5h-6z"/><path d="M8 8h8l-2 13h-4z"/></svg>
        </span>
        <h3>Designed &amp; Built in the USA</h3>
        <p>Every Kinetic product is designed and manufactured in the United States. Keeping our work in-house allows us to control quality, refine fitment, and stand behind every part we make.</p>
      </div>
      <div class="km-pp-trust__card">
        <span class="km-pp-trust__icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" width="22" height="22"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
        </span>
        <h3>A Decade of Hands-On Experience</h3>
        <p>Founded in 2013. A decade of machining, installing, riding and refining components on real bikes — not just in a lab.</p>
      </div>
      <div class="km-pp-trust__card">
        <span class="km-pp-trust__icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" width="22" height="22"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
        </span>
        <h3>Designed by Riders &amp; Builders</h3>
        <p>Every product is shaped by hands-on building and riding experience, with practical decisions made where it matters most.</p>
      </div>
    {%- endif -%}
  </div>
</section>

<style>
  .km-pp-trust { padding: 72px 0; background: #fff; }
  .km-pp-trust__grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 32px; }
  .km-pp-trust__card { text-align: center; padding: 16px; }
  .km-pp-trust__icon { width: 56px; height: 56px; border-radius: 50%; background: var(--km-body-bg, #EDEDED); display: inline-flex; align-items: center; justify-content: center; color: #000; margin-bottom: 16px; overflow: hidden; }
  .km-pp-trust__icon img { width: 100%; height: 100%; object-fit: contain; }
  .km-pp-trust__card h3 { font-size: 14px; font-weight: 800; letter-spacing: .1em; text-transform: uppercase; color: #000; margin: 0 0 10px; }
  .km-pp-trust__card p { font-size: 14px; line-height: 1.65; color: var(--km-text, #4B5563); margin: 0; max-width: 320px; margin: 0 auto; }
  @media (max-width: 1000px) { .km-pp-trust__grid { grid-template-columns: 1fr; gap: 24px; } }
</style>

{% schema %}
{
  "name": "Product Trust Strip",
  "settings": [],
  "blocks": [
    {
      "type": "card",
      "name": "Trust card",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Custom icon (image)" },
        { "type": "text", "id": "heading", "label": "Heading", "default": "Designed & Built in the USA" },
        { "type": "textarea", "id": "text", "label": "Text", "default": "Every Kinetic product is designed and manufactured in the United States." },
        { "type": "text", "id": "icon", "label": "Icon name", "default": "star", "info": "Icon from icon.liquid snippet - used if no image is uploaded" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Product Trust Strip",
      "blocks": [
        { "type": "card", "settings": { "heading": "Designed & Built in the USA", "text": "Every Kinetic product is designed and manufactured in the United States. Keeping our work in-house allows us to control quality, refine fitment, and stand behind every part we make." } },
        { "type": "card", "settings": { "heading": "A Decade of Hands-On Experience", "text": "Founded in 2013. A decade of machining, installing, riding and refining components on real bikes — not just in a lab." } },
        { "type": "card", "settings": { "heading": "Designed by Riders & Builders", "text": "Every product is shaped by hands-on building and riding experience, with practical decisions made where it matters most." } }
      ]
    }
  ]
}
{% endschema %}
