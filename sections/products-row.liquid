{%- comment -%}
  ============================================================
  PRODUCTS ROW — horizontal scroll carousel of products from a Shopify collection
  ============================================================
  Reusable section — can be dropped on homepage multiple times.
  Each instance picks its own collection, heading, and limit.
{%- endcomment -%}

{%- assign source_collection = collections[section.settings.collection] -%}
{%- assign product_limit = section.settings.product_limit | default: 4 -%}
{%- assign empty_msg = section.settings.empty_message | default: 'No products in this collection yet.' -%}

<section class="km-section km-pcarousel" {{ section.shopify_attributes }}>
  <div class="km-container">
    <div class="km-section-row">
      {%- if section.settings.heading != blank -%}
        <h2 class="km-section-heading">{{ section.settings.heading }}</h2>
      {%- endif -%}
      <div class="km-pcarousel__actions">
        {%- if section.settings.view_all_label != blank -%}
          <a href="{{ source_collection.url | default: '/collections' }}" class="km-pcarousel__viewall">
            {{ section.settings.view_all_label }}
            {%- render 'icon', icon: 'arrow-right' -%}
          </a>
        {%- endif -%}
      </div>
    </div>

    <div class="km-pcarousel__viewport">
      <div class="km-pcarousel__track">
        {%- for product in source_collection.products limit: product_limit -%}
          <article class="km-pcarousel__card">
            <a href="{{ product.url }}" class="km-pcarousel__imgwrap">
              {%- if product.featured_image != blank -%}
                {{ product.featured_image | image_url: width: 800 | image_tag:
                  width: 400, height: 400, loading: 'lazy',
                  alt: product.title, class: 'km-pcarousel__img' }}
              {%- endif -%}
            </a>
            <div class="km-pcarousel__meta">
              <h3 class="km-pcarousel__title"><a href="{{ product.url }}">{{ product.title }}</a></h3>
              {%- if product.vendor != blank -%}
                <div class="km-pcarousel__model">
                  <img src="{{ 'icon-motor.png' | asset_url }}" width="16" height="16" alt="" class="km-pcarousel__model-icon" loading="lazy">
                  <span>{{ product.vendor }}</span>
                </div>
              {%- endif -%}
              <div class="km-pcarousel__pricerow">
                <span class="km-pcarousel__price">{{ product.price | money }}</span>
                {%- if product.compare_at_price > product.price -%}
                  <span class="km-pcarousel__compare">{{ product.compare_at_price | money }}</span>
                {%- endif -%}
              </div>
              <div class="km-pcarousel__rating" aria-label="5 out of 5 stars">
                {%- for i in (1..5) -%}<span class="km-pcarousel__star">{%- render 'icon', icon: 'star' -%}</span>{%- endfor -%}
              </div>
            </div>
          </article>
        {%- else -%}
          <p style="color: var(--km-text); padding: 40px 0; grid-column: 1 / -1;">
            {{ empty_msg }}
          </p>
        {%- endfor -%}
      </div>
    </div>
  </div>
</section>

<style>
  .km-pcarousel__viewall {
    display: inline-flex; align-items: center; gap: 6px;
    font-size: 12px; font-weight: 800; letter-spacing: .14em; text-transform: uppercase;
    color: var(--km-text, #4B5563); text-decoration: none; transition: color .2s ease;
  }
  .km-pcarousel__viewall:hover { color: #000; }
  .km-pcarousel__viewall svg { width: 14px; height: 14px; }
</style>

{% schema %}
{
  "name": "Products row",
  "tag": "section",
  "class": "shopify-section-products-row",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Best Sellers" },
    {
      "type": "collection",
      "id": "collection",
      "label": "Source collection",
      "info": "Pick the collection whose products show in this row"
    },
    {
      "type": "range",
      "id": "product_limit",
      "label": "Number of products",
      "min": 2, "max": 12, "step": 1, "default": 4
    },
    { "type": "text", "id": "view_all_label", "label": "View All label", "default": "View All" },
    { "type": "text", "id": "empty_message", "label": "Message when no products", "default": "No products in this collection yet." }
  ],
  "presets": [
    {
      "name": "Products row",
      "category": "Collections"
    }
  ]
}
{% endschema %}
