{%- comment -%}
  ------------------------------------------------------------
  Header / Navigation
  Two-row layout cloned from kinetic-motorcycles.webflow.io
    • Top row (black): Logo + Search + Cart
    • Bottom row (white): Main nav links
  ------------------------------------------------------------
{%- endcomment -%}

<header class="km-header" data-km-header>
  {%- comment -%} Top row — dark bar with logo, search, icons {%- endcomment -%}
  <div class="km-header__top">
    <div class="km-container km-header__top-inner">
      <a href="{{ routes.root_url }}" class="km-header__logo" aria-label="{{ shop.name }}">
        {%- if section.settings.logo != blank -%}
          {{ section.settings.logo | image_url: width: 400 | image_tag:
            loading: 'eager',
            width: 200,
            height: 74,
            alt: shop.name,
            class: 'km-header__logo-img'
          }}
        {%- else -%}
          <img src="{{ 'logo.webp' | asset_url }}" alt="{{ shop.name }}" width="200" height="74" class="km-header__logo-img">
        {%- endif -%}
      </a>

      <div class="km-header__search-wrap" data-km-search>
        <form action="{{ routes.search_url }}" method="get" role="search" class="km-header__search">
          {%- render 'icon', icon: 'search' -%}
          <input
            type="search"
            name="q"
            value="{{ search.terms | escape }}"
            placeholder="{{ section.settings.search_placeholder | default: 'Search performance hardware...' }}"
            aria-label="{{ 'general.accessibility.search' | t }}"
            class="km-header__search-input"
            autocomplete="off"
            data-km-search-input
          >
          <input type="hidden" name="type" value="product">
          <input type="hidden" name="options[prefix]" value="last">
        </form>
        <div class="km-header__search-results" data-km-search-results hidden>
          <div class="km-header__search-inner" data-km-search-inner></div>
        </div>
      </div>

      <div class="km-header__actions">
        {%- if section.settings.show_account -%}
          <a href="{{ routes.account_url }}" aria-label="Account" class="km-header__icon-btn">
            {%- render 'icon', icon: 'user' -%}
          </a>
        {%- endif -%}
        <a href="{{ routes.cart_url }}" aria-label="Cart" class="km-header__icon-btn km-header__cart">
          {%- render 'icon', icon: 'cart' -%}
          {%- if cart.item_count > 0 -%}
            <span class="km-header__cart-count" data-km-cart-count>{{ cart.item_count }}</span>
          {%- endif -%}
        </a>
        <button type="button" class="km-header__menu-toggle" data-km-menu-toggle aria-expanded="false" aria-label="{{ 'general.accessibility.menu' | t }}">
          {%- render 'icon', icon: 'menu' -%}
        </button>
      </div>
    </div>
  </div>

  {%- comment -%} Bottom row — white bar with nav links + COLLECTIONS mega menu {%- endcomment -%}
  <div class="km-header__bottom">
    <div class="km-container">
      <nav class="km-header__nav" role="navigation" aria-label="Primary" data-km-menu>
        <ul class="km-header__menu">

          <li class="km-header__menu-item km-header__menu-item--mega">
            <a href="/collections" class="km-header__menu-link km-header__menu-link--has-dropdown">
              COLLECTIONS
              {%- render 'icon', icon: 'chevron-down' -%}
            </a>
            {% render 'header-megamenu' %}
          </li>

          <li class="km-header__menu-item">
            <a href="/pages/reviews" class="km-header__menu-link">REVIEW</a>
          </li>
          <li class="km-header__menu-item">
            <a href="/pages/faq" class="km-header__menu-link">FAQ</a>
          </li>
          <li class="km-header__menu-item">
            <a href="/blogs" class="km-header__menu-link">BLOGS</a>
          </li>
          <li class="km-header__menu-item">
            <a href="/pages/about" class="km-header__menu-link">ABOUT</a>
          </li>
        </ul>
      </nav>
    </div>
  </div>
</header>

<style>
  .km-header {
    position: sticky;
    top: 0;
    z-index: 1000;
    background: var(--km-body-bg);
    transition: box-shadow var(--km-transition);
  }
  .km-header.is-scrolled {
    box-shadow: 0 2px 12px rgba(0,0,0,.08);
  }

  .km-header__top {
    background: var(--km-header-bar);
    color: #fff;
    border-bottom: 2px solid var(--km-accent);
  }
  .km-header__top-inner {
    display: flex;
    align-items: center;
    gap: 24px;
    padding-top: 18px;
    padding-bottom: 18px;
  }

  .km-header__logo { display: block; flex-shrink: 0; }
  .km-header__logo-img { width: auto; height: 72px; object-fit: contain; display: block; }

  .km-header__search-wrap {
    position: relative;
    flex: 1;
    max-width: 720px;
    margin: 0 auto;
  }
  .km-header__search {
    position: relative;
    display: flex;
    align-items: center;
    background: var(--km-body-bg);
    border-radius: var(--km-radius-pill);
    padding: 10px 20px;
    gap: 10px;
  }
  .km-header__search svg { color: var(--km-text); flex-shrink: 0; }
  .km-header__search-input {
    flex: 1;
    border: 0;
    background: transparent;
    outline: none;
    font: inherit;
    font-size: 14px;
    color: var(--km-text);
    padding: 4px 0;
  }
  .km-header__search-input::placeholder { color: #9ca3af; }

  /* Predictive search dropdown (matches Webflow's dark results panel) */
  .km-header__search-results {
    position: absolute;
    top: calc(100% + 10px);
    left: 0;
    right: 0;
    background: #000;
    color: #fff;
    border-radius: 14px;
    box-shadow: 0 20px 60px rgba(0, 0, 0, .45);
    max-height: 70vh;
    overflow-y: auto;
    z-index: 200;
  }
  .km-header__search-results[hidden] { display: none; }
  .km-header__search-inner { padding: 8px 0; }
  .km-search-result {
    display: grid;
    grid-template-columns: 72px 1fr auto;
    align-items: center;
    gap: 18px;
    padding: 14px 20px;
    text-decoration: none;
    color: #fff;
    border-bottom: 1px solid rgba(255,255,255,.08);
    transition: background .15s ease;
  }
  .km-search-result:last-child { border-bottom: 0; }
  .km-search-result:hover,
  .km-search-result.is-active { background: rgba(255,255,255,.06); }
  .km-search-result__img {
    width: 72px; height: 72px; border-radius: 8px; object-fit: cover;
    background: #111; display: block;
  }
  .km-search-result__body { display: flex; flex-direction: column; gap: 4px; min-width: 0; }
  .km-search-result__name {
    font-size: 14px; font-weight: 600; color: #fff;
    overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
  }
  .km-search-result__price {
    font-size: 13px; color: #fff; font-weight: 500; white-space: nowrap;
  }
  .km-search-result__price-compare {
    font-size: 12px; color: rgba(255,255,255,.5);
    text-decoration: line-through; margin-right: 8px;
  }
  .km-search-footer {
    display: block;
    padding: 14px 20px;
    text-align: center;
    font-size: 13px;
    font-weight: 700;
    color: var(--km-accent, #FBB03D);
    text-decoration: none;
    border-top: 1px solid rgba(255,255,255,.1);
    letter-spacing: .04em;
  }
  .km-search-footer:hover { color: #fff; }
  .km-search-empty {
    padding: 24px 20px;
    text-align: center;
    color: rgba(255,255,255,.7);
    font-size: 14px;
  }

  .km-header__actions { display: flex; align-items: center; gap: 14px; }
  .km-header__icon-btn {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    color: #fff;
    transition: background var(--km-transition);
  }
  .km-header__icon-btn:hover { background: rgba(255,255,255,.1); }
  .km-header__cart-count {
    position: absolute;
    top: 4px;
    right: 4px;
    min-width: 18px;
    height: 18px;
    padding: 0 5px;
    border-radius: 9px;
    background: var(--km-accent);
    color: #000;
    font-size: 11px;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .km-header__menu-toggle {
    display: none;
    width: 44px; height: 44px;
    border: 0;
    background: transparent;
    color: #fff;
    border-radius: 50%;
    align-items: center;
    justify-content: center;
  }

  .km-header__bottom {
    background: var(--km-surface);
    border-bottom: 2px solid var(--km-accent);
    position: relative;
  }
  .km-header__nav { display: flex; justify-content: center; }
  .km-header__menu {
    display: flex;
    list-style: none;
    margin: 0;
    padding: 0;
    gap: 44px;
  }
  .km-header__menu-link {
    display: block;
    padding: 12px 0;
    font-size: 13px;
    letter-spacing: .12em;
    font-weight: 700;
    text-transform: uppercase;
    color: var(--km-heading);
    position: relative;
  }
  .km-header__menu-link::after {
    content: '';
    position: absolute;
    left: 0;
    right: 100%;
    bottom: 4px;
    height: 2px;
    background: var(--km-primary);
    transition: right var(--km-transition);
  }
  .km-header__menu-link:hover::after { right: 0; }
  .km-header__menu-link--has-dropdown {
    display: inline-flex;
    align-items: center;
    gap: 4px;
  }
  .km-header__menu-link--has-dropdown svg {
    width: 12px; height: 12px;
    transition: transform .25s ease;
  }

  /* MEGA MENU */
  .km-header__menu-item--mega { position: static; }
  .km-mega {
    position: absolute;
    top: 100%;
    left: 0; right: 0;
    background: #fff;
    border-top: 1px solid var(--km-border);
    border-bottom: 4px solid var(--km-accent);
    box-shadow: 0 12px 32px rgba(0,0,0,.08);
    opacity: 0;
    visibility: hidden;
    transform: translateY(-8px);
    transition: opacity .2s ease, visibility .2s ease, transform .2s ease;
    z-index: 999;
  }
  .km-header__menu-item--mega:hover .km-mega,
  .km-header__menu-item--mega:focus-within .km-mega {
    opacity: 1; visibility: visible; transform: translateY(0);
  }
  .km-header__menu-item--mega:hover .km-header__menu-link--has-dropdown svg {
    transform: rotate(180deg);
  }
  .km-mega__inner { padding: 36px 32px 28px; }
  .km-mega__grid {
    display: grid;
    grid-template-columns: repeat(8, minmax(0, 1fr));
    gap: 28px 24px;
  }
  .km-mega__col { min-width: 0; }
  .km-mega__brand {
    display: block;
    font-size: 13px;
    font-weight: 800;
    letter-spacing: .14em;
    text-transform: uppercase;
    color: var(--km-heading);
    text-decoration: none;
    margin-bottom: 14px;
    padding-bottom: 10px;
    border-bottom: 2px solid var(--km-accent);
  }
  .km-mega__brand:hover { color: var(--km-accent); }
  .km-mega__list {
    list-style: none;
    padding: 0; margin: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .km-mega__list a {
    display: block;
    font-size: 13px;
    font-weight: 500;
    color: var(--km-text);
    text-decoration: none;
    line-height: 1.4;
    transition: color .15s ease;
  }
  .km-mega__list a:hover { color: var(--km-heading); text-decoration: underline; }
  .km-mega__footer {
    margin-top: 24px;
    padding-top: 16px;
    border-top: 1px solid var(--km-border);
    display: flex;
    justify-content: flex-end;
  }
  .km-mega__view-all {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 12px;
    font-weight: 800;
    letter-spacing: .12em;
    text-transform: uppercase;
    color: var(--km-heading);
    text-decoration: none;
  }
  .km-mega__view-all:hover { color: var(--km-accent); }
  .km-mega__view-all svg { width: 14px; height: 14px; }

  @media (max-width: 1100px) {
    .km-mega__grid { grid-template-columns: repeat(4, 1fr); }
  }

  @media (max-width: 900px) {
    .km-header__top-inner { gap: 12px; padding-top: 12px; padding-bottom: 12px; }
    .km-header__logo-img { height: 44px; }
    .km-header__search-wrap { max-width: none; }
    .km-header__search { padding: 8px 14px; }
    .km-header__menu-toggle { display: inline-flex; }
    .km-header__bottom { display: none; }
    .km-header__nav.is-open {
      position: fixed;
      inset: 0;
      background: #fff;
      z-index: 999;
      padding: 80px 24px 24px;
    }
    .km-header__menu { flex-direction: column; gap: 0; }
    .km-header__menu-link { padding: 16px 0; border-bottom: 1px solid var(--km-border); }
  }

  @media (max-width: 520px) {
    .km-header__search svg { display: none; }
  }
</style>

<script>
  (function () {
    var root = document.querySelector('[data-km-search]');
    if (!root) return;
    var input = root.querySelector('[data-km-search-input]');
    var panel = root.querySelector('[data-km-search-results]');
    var inner = root.querySelector('[data-km-search-inner]');
    var form = root.querySelector('form');
    var debounceTimer = null;
    var currentReq = null;
    var activeIndex = -1;
    var lastQuery = '';

    function escHtml(s) {
      return String(s == null ? '' : s)
        .replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;').replace(/'/g, '&#39;');
    }

    function formatMoney(cents) {
      var n = (Number(cents) || 0) / 100;
      return '$ ' + n.toFixed(2) + ' USD';
    }

    function closePanel() {
      panel.hidden = true;
      inner.innerHTML = '';
      activeIndex = -1;
    }

    function openPanel() { panel.hidden = false; }

    function render(q, products) {
      if (!products || products.length === 0) {
        inner.innerHTML = '<div class="km-search-empty">No products found for &ldquo;' + escHtml(q) + '&rdquo;</div>';
        openPanel();
        return;
      }
      var html = '';
      products.forEach(function (p) {
        var img = (p.featured_image || p.image || '');
        var price = formatMoney(p.price);
        var compare = p.compare_at_price_min && p.compare_at_price_min > p.price
          ? formatMoney(p.compare_at_price_min) : '';
        html += '<a class="km-search-result" href="' + escHtml(p.url) + '">'
          + (img ? '<img class="km-search-result__img" src="' + escHtml(img) + '" alt="' + escHtml(p.title) + '" loading="lazy">' : '<span class="km-search-result__img"></span>')
          + '<div class="km-search-result__body">'
          + '<div class="km-search-result__name">' + escHtml(p.title) + '</div>'
          + '</div>'
          + '<div class="km-search-result__price">'
          + (compare ? '<span class="km-search-result__price-compare">' + compare + '</span>' : '')
          + price
          + '</div>'
          + '</a>';
      });
      html += '<a class="km-search-footer" href="/search?q=' + encodeURIComponent(q) + '&type=product">See all results for &ldquo;' + escHtml(q) + '&rdquo; →</a>';
      inner.innerHTML = html;
      openPanel();
    }

    function fetchResults(q) {
      if (currentReq && currentReq.abort) { try { currentReq.abort(); } catch (e) {} }
      var url = '/search/suggest.json?q=' + encodeURIComponent(q)
        + '&resources[type]=product'
        + '&resources[limit]=8'
        + '&resources[options][unavailable_products]=last'
        + '&resources[options][fields]=title,product_type,variants.title,vendor';
      var ctrl = (typeof AbortController !== 'undefined') ? new AbortController() : null;
      currentReq = ctrl;
      fetch(url, ctrl ? { signal: ctrl.signal } : undefined)
        .then(function (r) { return r.json(); })
        .then(function (data) {
          if (lastQuery !== q) return;
          var products = (data && data.resources && data.resources.results && data.resources.results.products) || [];
          render(q, products);
        })
        .catch(function () { /* ignore aborts/errors */ });
    }

    input.addEventListener('input', function () {
      var q = input.value.trim();
      lastQuery = q;
      clearTimeout(debounceTimer);
      if (q.length < 2) { closePanel(); return; }
      debounceTimer = setTimeout(function () { fetchResults(q); }, 180);
    });

    input.addEventListener('focus', function () {
      if (input.value.trim().length >= 2 && inner.innerHTML) openPanel();
    });

    document.addEventListener('click', function (e) {
      if (!root.contains(e.target)) closePanel();
    });

    input.addEventListener('keydown', function (e) {
      var items = inner.querySelectorAll('.km-search-result');
      if (e.key === 'Escape') { closePanel(); input.blur(); return; }
      if (!items.length) return;
      if (e.key === 'ArrowDown') {
        e.preventDefault();
        activeIndex = Math.min(activeIndex + 1, items.length - 1);
      } else if (e.key === 'ArrowUp') {
        e.preventDefault();
        activeIndex = Math.max(activeIndex - 1, -1);
      } else if (e.key === 'Enter' && activeIndex >= 0) {
        e.preventDefault();
        window.location.href = items[activeIndex].getAttribute('href');
        return;
      } else { return; }
      items.forEach(function (el, i) { el.classList.toggle('is-active', i === activeIndex); });
      if (activeIndex >= 0) items[activeIndex].scrollIntoView({ block: 'nearest' });
    });
  })();
</script>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo"
    },
    {
      "type": "text",
      "id": "search_placeholder",
      "label": "Search placeholder",
      "default": "Search performance hardware..."
    },
    {
      "type": "checkbox",
      "id": "show_account",
      "label": "Show account icon",
      "default": false
    }
  ],
  "blocks": [
    {
      "type": "link",
      "name": "Menu link",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Collections"
        },
        {
          "type": "url",
          "id": "url",
          "label": "Link"
        }
      ]
    }
  ],
  "default": {
    "blocks": [
      { "type": "link", "settings": { "label": "COLLECTIONS", "url": "/collections" } },
      { "type": "link", "settings": { "label": "REVIEW", "url": "/pages/reviews" } },
      { "type": "link", "settings": { "label": "FAQ", "url": "/pages/faq" } },
      { "type": "link", "settings": { "label": "BLOGS", "url": "/blogs" } },
      { "type": "link", "settings": { "label": "ABOUT", "url": "/pages/about" } }
    ]
  }
}
{% endschema %}
