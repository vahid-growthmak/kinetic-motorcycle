{%- comment -%}
  Blog Index — editable section with configurable heading, intro text, and articles per page.
{%- endcomment -%}
<section class="km-section km-blog-index" id="Section-{{ section.id }}">
  <div class="km-container">
    <header class="km-blog-index__hero">
      <h1 class="km-blog-index__h1">{{ section.settings.heading | default: 'Blogs' }}</h1>
      {%- if section.settings.intro != blank -%}
        <p class="km-blog-index__lede">{{ section.settings.intro }}</p>
      {%- endif -%}
    </header>

    {%- paginate blog.articles by section.settings.articles_per_page -%}
      {%- if blog.articles.size > 0 -%}
        <div class="km-blog-index__grid">
          {%- for article in blog.articles -%}
            <article class="km-blog-index__card">
              <a href="{{ article.url }}" class="km-blog-index__media">
                {%- if article.image != blank -%}
                  {{ article.image | image_url: width: 1200 | image_tag:
                     loading: 'lazy',
                     sizes: '(min-width: 1200px) 450px, (min-width: 768px) 50vw, 100vw',
                     widths: '400, 600, 800, 1200',
                     alt: article.title, class: 'km-blog-index__img' }}
                {%- endif -%}
              </a>
              <div class="km-blog-index__body">
                <div class="km-blog-index__date">{{ article.published_at | date: '%b %d, %Y' }}</div>
                <h2 class="km-blog-index__t"><a href="{{ article.url }}">{{ article.title }}</a></h2>
                <a href="{{ article.url }}" class="km-blog-index__more">
                  {{ section.settings.read_more | default: 'Read More' }}
                  {%- render 'icon', icon: 'arrow-right' -%}
                </a>
              </div>
            </article>
          {%- endfor -%}
        </div>
      {%- else -%}
        <div class="km-blog-index__empty">
          <p>{{ section.settings.empty_message | default: 'No articles published yet. Check back soon!' }}</p>
        </div>
      {%- endif -%}

      {%- if paginate.pages > 1 -%}
        <nav class="km-blog-index__pagination">{{ paginate | default_pagination }}</nav>
      {%- endif -%}
    {%- endpaginate -%}
  </div>
</section>

<style>
  .km-blog-index { padding: 80px 0; background: #fff; }
  .km-blog-index__hero { text-align: center; max-width: 100%; margin: 0 auto 56px; }
  .km-blog-index__h1 { font-size: clamp(36px, 5vw, 56px); font-weight: 700; letter-spacing: -.02em; color: #000; margin: 0 0 18px; }
  .km-blog-index__lede { font-size: 17px; line-height: 1.7; color: var(--km-text, #4B5563); margin: 0; }
  .km-blog-index__grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 32px; }
  .km-blog-index__card { display: flex; flex-direction: column; gap: 16px; transition: transform .25s ease; }
  .km-blog-index__card:hover { transform: translateY(-3px); }
  .km-blog-index__media { display: block; aspect-ratio: 4 / 3; overflow: hidden; border-radius: 20px; background: var(--km-body-bg, #EDEDED); }
  .km-blog-index__img { width: 100%; height: 100%; object-fit: cover; transition: transform .4s ease; }
  .km-blog-index__card:hover .km-blog-index__img { transform: scale(1.04); }
  .km-blog-index__body { padding: 0 4px; display: flex; flex-direction: column; gap: 12px; }
  .km-blog-index__date { font-size: 12px; font-weight: 700; letter-spacing: .12em; text-transform: uppercase; color: var(--km-accent, #FBB03D); }
  .km-blog-index__t { font-size: 20px; font-weight: 700; line-height: 1.25; color: #000; margin: 0; }
  .km-blog-index__t a { color: inherit; text-decoration: none; }
  .km-blog-index__t a:hover { color: var(--km-accent, #FBB03D); }
  .km-blog-index__more { display: inline-flex; align-items: center; gap: 6px; font-size: 13px; font-weight: 700; color: #000; text-decoration: none; }
  .km-blog-index__empty { text-align: center; padding: 60px 20px; color: var(--km-text, #4B5563); }
  .km-blog-index__pagination { margin-top: 48px; display: flex; justify-content: center; }
  @media (max-width: 900px) { .km-blog-index__grid { grid-template-columns: 1fr; } }
</style>

{% schema %}
{
  "name": "Blog Index",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Blogs" },
    { "type": "textarea", "id": "intro", "label": "Introduction text", "default": "This is where we share what matters to riders and builders. From technical insights and build perspectives to practical guides and industry news — every article is written to help you ride better, build smarter, and get more from your machine." },
    { "type": "range", "id": "articles_per_page", "label": "Articles per page", "min": 3, "max": 18, "step": 3, "default": 9 },
    { "type": "text", "id": "read_more", "label": "Read more label", "default": "Read More" },
    { "type": "text", "id": "empty_message", "label": "Empty state message", "default": "No articles published yet. Check back soon!" }
  ]
}
{% endschema %}
