          "settings": {
            "heading": "Designed & Built in the USA",
            "text": "Every Kinetic product is designed and manufactured in the United States. Keeping our work in-house allows us to control quality, refine fitment, and stand behind every part we make.",
            "icon": "globe"
          }
        },
        "card_2": {
          "type": "card",
          "settings": {
            "heading": "A Decade of Hands-On Experience",
            "text": "Founded in 2013. A decade of machining, installing, riding and refining components on real bikes — not just in a lab. That experience shows in the quality of every part we ship.",
            "icon": "star"
          }
        },
        "card_3": {
          "type": "card",
          "settings": {
            "heading": "Designed by Riders & Builders",
            "text": "Every product is shaped by hands-on building and riding experience, with practical decisions made where it matters most.",
            "icon": "check"
          }
        }
