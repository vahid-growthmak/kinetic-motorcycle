{%- comment -%}
  ------------------------------------------------------------
  Reviews — "What Our Customers Say" (matches live Kinetic layout)
  Left-aligned heading, prev/next arrows on the right
  2-column testimonial cards, each with:
    • 5 gold stars (or block rating)
    • Quote
    • Author name
    • Product / bike line
  NO photos. NO verified badges.
  ------------------------------------------------------------
{%- endcomment -%}

<section class="km-section km-reviews" id="Section-{{ section.id }}">
  <div class="km-container">
    <div class="km-reviews__top">
      <h2 class="km-reviews__heading">{{ section.settings.heading | default: 'What Our Customers Say' }}</h2>
      {%- if section.settings.show_arrows and section.blocks.size > 0 -%}
        <div class="km-reviews__nav" aria-hidden="true">
          <button type="button" class="km-reviews__arrow" data-km-prev aria-label="Previous review">
            {%- render 'icon', icon: 'arrow-right' -%}
          </button>
          <button type="button" class="km-reviews__arrow" data-km-next aria-label="Next review">
            {%- render 'icon', icon: 'arrow-right' -%}
          </button>
        </div>
      {%- endif -%}
    </div>

    {%- if section.blocks.size > 0 -%}
      <div class="km-reviews__grid" data-km-reviews>
        {%- for block in section.blocks -%}
          {%- if block.type == 'review' -%}
            <article class="km-reviews__card" {{ block.shopify_attributes }}>
              {%- assign rating = block.settings.rating | default: 5 -%}
              <div class="km-reviews__stars" aria-label="{{ rating }} out of 5 stars">
                {%- for i in (1..5) -%}<span class="km-reviews__star{% if i > rating %} km-reviews__star--off{% endif %}">{%- render 'icon', icon: 'star' -%}</span>{%- endfor -%}
              </div>
              <p class="km-reviews__quote">{{ block.settings.quote }}</p>
              <div class="km-reviews__meta">
                <div class="km-reviews__author">{{ block.settings.author }}</div>
                {%- if block.settings.product != blank -%}<div class="km-reviews__product">{{ block.settings.product }}</div>{%- endif -%}
              </div>
            </article>
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- else -%}
      <div class="km-reviews__judgeme" data-jdgm-limit="{{ section.settings.judgeme_limit | default: 4 }}">
        <div class='jdgm-all-reviews-widget'></div>
      </div>
    {%- endif -%}
  </div>
</section>

<style>
  .km-reviews { background: var(--km-body-bg); }

  .km-reviews__top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 36px;
    gap: 20px;
    flex-wrap: wrap;
  }
  .km-reviews__heading {
    font-size: clamp(26px, 3vw, 36px);
    font-weight: 700;
    letter-spacing: -.015em;
    color: var(--km-heading);
    margin: 0;
  }

  .km-reviews__nav { display: flex; gap: 8px; }
  .km-reviews__arrow {
    width: 40px; height: 40px;
    border-radius: 50%;
    border: 1px solid var(--km-border);
    background: transparent;
    color: var(--km-heading);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: background var(--km-transition, .2s ease), border-color var(--km-transition, .2s ease);
  }
  .km-reviews__arrow:first-child svg { transform: rotate(180deg); }
  .km-reviews__arrow:hover { background: var(--km-heading); color: #fff; border-color: var(--km-heading); }

  .km-reviews__grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 48px 60px;
  }

  .km-reviews__card {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .km-reviews__stars {
    display: inline-flex;
    gap: 3px;
    color: var(--km-accent);
  }
  .km-reviews__star--off { color: var(--km-border); }

  .km-reviews__quote {
    font-size: 16px;
    line-height: 1.6;
    color: var(--km-text);
    margin: 0;
    font-weight: 500;
  }

  .km-reviews__meta {
    margin-top: 4px;
  }
  .km-reviews__author {
    font-weight: 700;
    color: var(--km-heading);
    font-size: 15px;
    line-height: 1.2;
  }
  .km-reviews__product {
    font-size: 13px;
    color: var(--km-text);
    margin-top: 4px;
  }

  @media (max-width: 700px) {
    .km-reviews__grid { grid-template-columns: 1fr; gap: 36px; }
  }
</style>

{%- if section.blocks.size == 0 -%}
<script>
(() => {
  const root = document.querySelector('#Section-{{ section.id }} .km-reviews__judgeme');
  if (!root) return;
  const limit = parseInt(root.dataset.jdgmLimit || '4', 10);
  const apply = () => {
    const reviews = root.querySelectorAll('.jdgm-rev');
    if (!reviews.length) return false;
    reviews.forEach((r, i) => { r.style.display = i < limit ? '' : 'none'; });
    return true;
  };
  if (apply()) return;
  const obs = new MutationObserver(() => { if (apply()) obs.disconnect(); });
  obs.observe(root, { childList: true, subtree: true });
  setTimeout(() => obs.disconnect(), 15000);
})();
</script>
{%- endif -%}

{% schema %}
{
  "name": "Reviews",
  "settings": [
    { "type": "text",     "id": "heading",     "label": "Heading", "default": "What Our Customers Say" },
    { "type": "checkbox", "id": "show_arrows", "label": "Show prev/next arrows (only when manual review blocks are added below)", "default": true },
    { "type": "header",   "content": "Dynamic reviews" },
    { "type": "paragraph","content": "When no manual review blocks are added below, this section pulls live reviews from Judge.me automatically." },
    { "type": "range",    "id": "judgeme_limit", "label": "Judge.me reviews to show", "min": 2, "max": 8, "step": 2, "default": 4 }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        { "type": "range",    "id": "rating",  "label": "Rating (stars)", "min": 1, "max": 5, "step": 1, "default": 5 },
        { "type": "textarea", "id": "quote",   "label": "Quote",   "default": "Little hiccup in the delivery, but as usual Kinetic made haste to correct the missing brake line from my order." },
        { "type": "text",     "id": "author",  "label": "Author",  "default": "Christopher Cook" },
        { "type": "text",     "id": "product", "label": "Product / bike line", "default": "Composite Wide Grip for Harley Sportster" }
      ]
    }
  ],
  "max_blocks": 8,
  "presets": [
    { "name": "Reviews" }
  ]
}
{% endschema %}
